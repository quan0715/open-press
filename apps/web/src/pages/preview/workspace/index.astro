---
import Layout from "../../../layouts/Layout.astro";
import LandingNav from "../../../components/home/LandingNav.astro";
import LandingFooter from "../../../components/home/LandingFooter.astro";
import { navLinks, homeVersion } from "../../../data/home";

// Demo data — simulates what an actual deployed Workspace's reader
// landing page would receive from public/openpress/workspace.json.
// In the real reader this comes from the engine's per-Press build.
const workspace = {
  name: "Series A launch",
  presses: [
    {
      slug: "proposal",
      title: "Series A 提案書",
      organization: "FooBar Co.",
      author: "Q. Liang",
      page: { label: "A4", width: "210mm", height: "297mm", ratio: "210/297" },
      pageCount: 24,
      kind: "long-form",
    },
    {
      slug: "pitch-deck",
      title: "Investor pitch",
      organization: "FooBar Co.",
      author: "Q. Liang",
      page: { label: "16:9", width: "1920px", height: "1080px", ratio: "16/9" },
      pageCount: 18,
      kind: "slide",
    },
    {
      slug: "social",
      title: "Launch cards",
      organization: "FooBar Co.",
      page: { label: "1080 × 1080", width: "1080px", height: "1080px", ratio: "1/1" },
      pageCount: 6,
      kind: "social",
    },
  ],
};
---

<Layout
  title={`${workspace.name} — Workspace`}
  description="Preview of the OpenPress Workspace gallery — every Press document in this project, click to enter."
>
  <LandingNav links={navLinks} />

  <main class="ws-shell">
    <header class="ws-header">
      <p class="ws-eyebrow">Workspace · Preview</p>
      <h1>{workspace.name}</h1>
      <p class="ws-lede">
        {workspace.presses.length} documents in this project. Click any card to enter the
        full-fidelity reader. This page is a static preview of the layout —
        the real <code>/</code> route of a deployed Workspace renders this from
        <code>public/openpress/workspace.json</code>.
      </p>
    </header>

    <section class="ws-grid" aria-label="Documents">
      {workspace.presses.map((p) => (
        <a class={`ws-card ws-card--${p.kind}`} href={`/preview/workspace/${p.slug}`}>
          <div class="ws-card__thumb" style={`aspect-ratio: ${p.page.ratio};`}>
            <div class="ws-card__thumb-frame">
              <span class="ws-card__thumb-label">{p.page.label}</span>
            </div>
          </div>
          <div class="ws-card__body">
            <p class="ws-card__slug">/{p.slug}</p>
            <h3>{p.title}</h3>
            <p class="ws-card__meta">
              {p.organization}
              {p.author && <span class="ws-card__dot"> · </span>}
              {p.author && <span>{p.author}</span>}
            </p>
            <p class="ws-card__stats">
              {p.pageCount} pages · {p.page.width} × {p.page.height}
            </p>
          </div>
        </a>
      ))}
    </section>

    <section class="ws-meta">
      <h2>How this works</h2>
      <p>
        A multi-document OpenPress project has a single <code>press/index.tsx</code> exporting a
        <a href="/docs/api/workspace"><code>&lt;Workspace&gt;</code></a> with one or more
        <a href="/docs/api/press"><code>&lt;Press&gt;</code></a> children. The build pipeline
        produces one bundle per Press at <code>public/openpress/&lt;slug&gt;/document.json</code>,
        plus a top-level <code>workspace.json</code> manifest that feeds this gallery.
      </p>
      <p>
        For single-document projects, the Workspace has just one Press — the reader skips the
        gallery and lands directly in the document.
      </p>
    </section>
  </main>

  <LandingFooter version={homeVersion} />
</Layout>

<style>
  .ws-shell {
    max-width: 64rem;
    margin: 0 auto;
    padding: var(--op-space-10) var(--op-space-6) var(--op-space-16);
  }

  .ws-header {
    margin-bottom: var(--op-space-8);
    padding-bottom: var(--op-space-7);
    border-bottom: var(--op-border-hairline);
  }
  .ws-eyebrow {
    margin: 0 0 var(--op-space-2);
    color: var(--op-subdued);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ws-header h1 {
    margin: 0 0 var(--op-space-4);
    font-family: var(--op-font-display);
    font-size: var(--op-text-4xl);
    line-height: var(--op-leading-display);
  }
  .ws-lede {
    margin: 0;
    max-width: 48rem;
    color: var(--op-subdued-strong);
    font-size: var(--op-text-lg);
    line-height: var(--op-leading-body);
  }

  .ws-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--op-space-5);
    margin: 0 0 var(--op-space-10);
  }

  .ws-card {
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--op-hairline);
    border-radius: 8px;
    background: var(--op-surface);
    color: var(--op-ink);
    text-decoration: none;
    overflow: hidden;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }
  .ws-card:hover {
    border-color: var(--op-accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px color-mix(in srgb, var(--op-ink) 10%, transparent);
  }
  .ws-card__thumb {
    width: 100%;
    background: linear-gradient(135deg, color-mix(in srgb, var(--op-accent) 14%, var(--op-paper-soft)), var(--op-paper-soft));
    display: grid;
    place-items: center;
    padding: var(--op-space-4);
    border-bottom: 1px solid var(--op-hairline);
  }
  .ws-card__thumb-frame {
    width: 70%;
    height: 70%;
    background: var(--op-paper);
    border: 1px solid color-mix(in srgb, var(--op-accent) 30%, var(--op-hairline));
    border-radius: 3px;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--op-ink) 10%, transparent);
  }
  .ws-card__thumb-label {
    color: var(--op-subdued);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .ws-card__body {
    display: grid;
    gap: 0.4rem;
    padding: var(--op-space-4) var(--op-space-5) var(--op-space-5);
  }
  .ws-card__slug {
    margin: 0;
    color: var(--op-subdued);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .ws-card__body h3 {
    margin: 0;
    color: var(--op-ink-strong);
    font-family: var(--op-font-body);
    font-size: var(--op-text-xl);
    font-weight: 600;
    line-height: 1.3;
  }
  .ws-card__meta {
    margin: 0;
    color: var(--op-subdued-strong);
    font-size: var(--op-text-sm);
  }
  .ws-card__dot {
    color: var(--op-subdued);
  }
  .ws-card__stats {
    margin: 0.2rem 0 0;
    color: var(--op-subdued);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
  }

  .ws-meta {
    margin-top: var(--op-space-10);
    padding-top: var(--op-space-7);
    border-top: var(--op-border-hairline);
  }
  .ws-meta h2 {
    margin: 0 0 var(--op-space-3);
    font-family: var(--op-font-display);
    font-size: var(--op-text-2xl);
    line-height: var(--op-leading-heading);
  }
  .ws-meta p {
    margin: 0 0 var(--op-space-4);
    max-width: 48rem;
    color: var(--op-ink);
    line-height: var(--op-leading-body);
  }
  .ws-meta code {
    padding: 0.1em 0.35em;
    border-radius: 3px;
    background: color-mix(in srgb, var(--op-ink) 8%, transparent);
    font-family: var(--op-font-mono);
    font-size: 0.92em;
  }
</style>
