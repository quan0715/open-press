---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="MDX sources"
  eyebrow="@open-press/core/mdx"
  description="MDX source registration is passed as a prop to <Press>. The engine reads sources to discover content files, compile blocks, and feed them into MdxArea slots — feeding the manuscript helpers, search/replace, and the comment-marker writer."
>
  <div class="callout">
    <strong>1.0 contract.</strong> Sources are now a <code>&lt;Press sources={`{[...]}`}&gt;</code>
    prop — an array, not the named-export record from v0.x. The codemod in v0.10 rewrites the old
    shape. See <a href="/docs/api/press">&lt;Press&gt;</a> for the prop reference.
  </div>

  <ApiEntry
    name="<Press sources>"
    kind="config"
    status="planned"
    since="v1.0"
    importFrom={`<Press sources={[
  mdxSource({ id: "story", preset: "section-folders", root: "chapters" }),
]}>`}
    summary="Array of source registrations passed as a prop on <Press>. Each entry has an explicit id which becomes the MdxArea chainId, the Sections / Toc source key, and the search/replace scope label."
  >
    <p>
      Multiple sources are allowed — each gets its own id. A document with a main body and a
      separate appendix typically declares two sources:
    </p>

    <Example title="Two source roots" language="tsx" code={`<Press
  title="Paper"
  page="a4"
  sources={[
    mdxSource({ id: "story",    preset: "section-folders", root: "chapters" }),
    mdxSource({ id: "appendix", preset: "section-folders", root: "appendix" }),
  ]}
>
  <Sections source="story" />
  <Sections source="appendix" />
</Press>`} />
  </ApiEntry>

  <ApiEntry
    name="export const sources (v0.x shape)"
    kind="config"
    status="deprecated"
    since="v0.x"
    importFrom={`// document/index.tsx (deprecated)
export const sources = {
  story: mdxSource({ preset: "section-folders", root: "chapters" }),
};`}
    summary="The v0.x named-export shape. Works until v1.0; codemod migrates to the new array prop. Keys in the record become the source ids (now explicit via the id field)."
  />

  <ApiEntry
    name="mdxSource"
    kind="function"
    importFrom={'import { mdxSource } from "@open-press/core/mdx";'}
    signature={`mdxSource(options: MdxSourceOptions): SourceRegistration`}
    summary="Register an MDX source tree. Returns the value you store in the sources object — the engine inspects the return value, not the function call itself."
  >
    <PropsTable
      title="Options"
      rows={[
        {
          name: "id",
          type: "string",
          required: true,
          description: "Stable identifier referenced by <code>&lt;MdxArea chainId&gt;</code>, <code>&lt;Sections source&gt;</code>, <code>&lt;Toc source&gt;</code>, and the search/replace CLI. In v0.x this was the key in the <code>sources</code> object; now it's an explicit field.",
        },
        {
          name: "preset",
          type: '"section-folders" | "file-list"',
          required: true,
          description:
            "<strong>section-folders</strong> walks <code>&lt;root&gt;/&lt;NN-slug&gt;/content/*.mdx</code> relative to the document file and produces one section per folder. <strong>file-list</strong> takes an explicit <code>files</code> array — useful when sections aren't folder-shaped.",
        },
        {
          name: "root",
          type: "string",
          description: 'Folder relative to the document file (where <code>&lt;Press&gt;</code> lives). Default <code>"chapters"</code> for <code>section-folders</code>. Ignored by <code>file-list</code>.',
        },
        {
          name: "files",
          type: "string[]",
          description: 'Required when <code>preset: "file-list"</code>. Paths relative to the document file.',
        },
      ]}
    />

    <Example title="Default folder layout (preset: 'section-folders')" language="text" code={`document/
  chapters/
    01-intro/
      content/
        01-overview.mdx
        02-context.mdx
    02-methods/
      content/
        01-design.mdx
    03-results/
      content/
        01-figures.mdx
        02-tables.mdx`} />

    <p>
      Each <code>NN-slug</code> folder maps to one section. Files inside <code>content/</code> are read in
      name order and concatenated into the section's MDX. The <code>NN-</code> prefix sets section order.
    </p>

    <Example title="Explicit file list" language="tsx" code={`mdxSource({
  preset: "file-list",
  files: [
    "intro.mdx",
    "results.mdx",
    "conclusion.mdx",
  ],
});`} />
  </ApiEntry>

  <h2>MDX content rules</h2>

  <p>
    Source MDX files must be <strong>block-only</strong> — JSX components live on their own line, not
    inside paragraphs. The MDX compiler rejects <code>mdxJsxTextElement</code> nodes and reports the file
    + line, because measurement and pagination can only address block-level elements.
  </p>

  <Example title="OK — JSX as block" language="mdx" code={`Some prose.

<TableCaption>Daily ridership</TableCaption>

| Day | Riders |
| --- | --- |
| Mon | 1,204 |
| Tue | 1,317 |`} />

  <Example title="Rejected — inline JSX" language="mdx" code={`Some prose with <Highlight>inline JSX</Highlight> inside a paragraph.
//        ^^^^^^^ MDX compile error: block-only`} />

  <h2>What sources unlock</h2>

  <ul>
    <li>
      <strong>MdxArea</strong> — <code>chainId="story"</code> pulls from the source registered as
      <code>story</code>.
    </li>
    <li>
      <strong>Manuscript helpers</strong> — <code>{`<Sections source="story" page={...} />`}</code>
      iterates the section folders and emits one frame per section.
    </li>
    <li>
      <strong>Search & replace</strong> — the <code>search</code> / <code>replace</code> CLI commands
      walk the registered files; unregistered files aren't reachable.
    </li>
    <li>
      <strong>Inline editing</strong> — the workbench's source-edit endpoint resolves block ids back to
      source files via the same registration.
    </li>
    <li>
      <strong>Comment markers</strong> — <code>@openpress-comment</code> markers are written into the
      source file the block came from.
    </li>
  </ul>

  <h2>What lives outside <code>sources</code></h2>

  <ul>
    <li>
      <strong>React components</strong> — <code>document/components/**/*.tsx</code> is imported normally
      from <code>document/index.tsx</code> and used inside MDX. The components folder is not part of
      <code>sources</code> because nothing's paginated.
    </li>
    <li>
      <strong>Media</strong> — <code>document/media/**</code> is synced into <code>public/openpress/media/</code>
      at export. Reference media in MDX via <code>media/&lt;file&gt;.png</code> (relative) or
      <code>/openpress/media/&lt;file&gt;.png</code> (absolute).
    </li>
    <li>
      <strong>Theme CSS</strong> — <code>document/theme/**</code> is concatenated into the document
      stylesheet bundle by the build, not registered as a source.
    </li>
  </ul>
</DocLayout>
