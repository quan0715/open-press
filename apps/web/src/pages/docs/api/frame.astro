---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="Frame"
  eyebrow="@open-press/core"
  description="One fixed page surface. Every page in the rendered output — cover, content, TOC, slide, social card, back-cover — is a Frame. frameKey is the page's stable address; everything else is presentation."
>
  <ApiEntry
    name="<Frame>"
    kind="component"
    importFrom={'import { Frame } from "@open-press/core";'}
    signature={`<Frame
  frameKey="cover"
  role?="document.cover"
  chrome?={true}
  className?="reader-page--cover"
  page?="slide-16-9"
  ...sectionProps
>
  {/* page contents */}
</Frame>`}
    summary="Renders a single page surface as a <section> with data-openpress-* attributes the engine reads. Pages are addressed by frameKey; the engine measures, allocates content into, and paginates around each frame."
  >
    <PropsTable
      title="Props"
      rows={[
        {
          name: "frameKey",
          type: "string",
          required: true,
          description:
            "Stable identifier for this page. Used as the allocation key, the comment marker address, and the data-openpress-frame-key attribute. Must be non-empty and free of the reserved substring <code>:extended:</code>.",
        },
        {
          name: "children",
          type: "ReactNode",
          required: true,
          description:
            "The page contents. Typically one or more <code>&lt;MdxArea&gt;</code> slots wrapped in a layout (<code>.page-frame</code> / <code>.page-body</code>) plus any header/footer chrome.",
        },
        {
          name: "role",
          type: "string",
          description:
            "Opaque label the renderer puts on <code>data-frame-role</code> and <code>data-page-kind</code>. Style packs use it to scope CSS (e.g. <code>document.cover</code> vs <code>canvas.slide</code>). Convention: <code>&lt;family&gt;.&lt;variant&gt;</code>.",
        },
        {
          name: "chrome",
          type: "boolean",
          default: "true",
          description:
            "When false, sets <code>data-frame-chrome=\"false\"</code> / <code>data-page-footer=\"false\"</code>. Use for canvas-style pages (slides, social cards) where the theme doesn't render header/footer bands.",
        },
        {
          name: "page",
          type: "string | PageGeometry",
          description:
            'Per-frame page geometry override. Accepts the same value as <code>config.page</code> ("a4", "social-square", "slide-16-9", or a custom object). Useful for mixed-format documents — a single Press tree can carry an A4 body with a 16:9 cover.',
        },
        {
          name: "className",
          type: "string",
          description:
            "Appended to the rendered <code>&lt;section class=\"reader-page …\"&gt;</code>. Style packs use this for role-specific styling (<code>reader-page--cover</code>, <code>reader-page--slide</code>).",
        },
        {
          name: "...rest",
          type: "HTMLAttributes",
          description:
            "All other props pass through to the underlying <code>&lt;section&gt;</code>. <code>data-*</code> attributes are commonly used for layout flags read by CSS or the inspector.",
        },
      ]}
    />

    <Example title="A4 content page (manuscript role)" language="tsx">
{`<Frame frameKey="ch-2" role="document.content" className="reader-page--content">
  <div className="page-frame">
    <header className="page-header" aria-hidden="true" />
    <main className="page-body">
      <MdxArea chainId="story" />
    </main>
    <footer className="page-footer">
      <span className="footer-left">{title}</span>
      <span className="footer-right">{pageIndex + 1}/{totalPages}</span>
    </footer>
  </div>
</Frame>`}
    </Example>

    <Example title="Canvas-style slide (no chrome)" language="tsx">
{`<Frame
  frameKey="slide-1"
  role="canvas.slide"
  chrome={false}
  page="slide-16-9"
  className="reader-page--slide"
>
  <div className="page-frame">
    <main className="page-body">
      <MdxArea chainId="slides" overflow="truncate" />
    </main>
  </div>
</Frame>`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="FrameContext"
    kind="context"
    importFrom={'import { FrameContext } from "@open-press/core";'}
    signature={`const frame = useContext(FrameContext);
// -> { frameKey: string; consumeArea(chainId): { indexInFrame, blocks } } | null`}
    summary="The active frame's render context. MdxArea (and TocArea / custom slot helpers) call consumeArea to claim their slot in the engine's allocation table. Available only inside <Frame> children."
  >
    <p>
      <code>consumeArea(chainId)</code> increments the per-chain counter on each call so multiple
      <code>&lt;MdxArea&gt;</code> with the same <code>chainId</code> in one frame map to distinct
      allocation slots in source order.
    </p>
  </ApiEntry>

  <ApiEntry
    name="FRAME_MARKER"
    kind="symbol"
    importFrom={'import { FRAME_MARKER } from "@open-press/core";'}
    summary="Symbol identifier the renderer uses to detect Frame instances during tree walking. Custom frame wrappers can re-export Frame and attach this marker."
  />

  <h2>Data attributes the renderer writes</h2>

  <p>The rendered <code>&lt;section&gt;</code> carries these attributes — selectors in style packs and
  inspector behavior depend on them:</p>

  <PropsTable
    rows={[
      { name: "data-openpress-frame-key", type: "string", description: "Mirrors the <code>frameKey</code> prop." },
      { name: "data-openpress-object-id", type: "string", description: "Page-level object id, used by the inspector and the comment-marker system." },
      { name: "data-frame-role", type: "string", description: "Mirrors the <code>role</code> prop." },
      { name: "data-page-kind", type: "string", description: "Last dot-segment of <code>role</code> (e.g. <code>cover</code> from <code>document.cover</code>)." },
      { name: "data-frame-chrome", type: '"true" | "false"', description: "Reflects the <code>chrome</code> prop." },
      { name: "data-page-footer", type: '"true" | "false"', description: "Identical to <code>data-frame-chrome</code> by default." },
    ]}
  />

  <h2>Role naming convention</h2>

  <p>
    <code>role</code> is a free string, but the framework documents a two-segment convention so style packs
    and docs stay consistent:
  </p>

  <ul>
    <li>
      <strong><code>document.*</code></strong> — long-form pages that flow MDX content through the
      allocator: <code>document.cover</code>, <code>document.toc</code>,
      <code>document.content</code>, <code>document.back-cover</code>.
    </li>
    <li>
      <strong><code>canvas.*</code></strong> — fixed-format pages with one designed surface and
      <code>overflow="truncate"</code> MDX areas: <code>canvas.slide</code>, <code>canvas.post</code>,
      <code>canvas.card</code>.
    </li>
    <li>
      <strong><code>manuscript.*</code></strong> — used by the bundled manuscript helpers
      (<code>manuscript.content</code> from <code>DefaultSectionPage</code>).
    </li>
  </ul>
</DocLayout>
