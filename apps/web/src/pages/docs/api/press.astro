---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="Press"
  eyebrow="@open-press/core"
  description="The document composition boundary. Wrap your entire Press Tree in a single <Press> at the top of document/index.tsx — every Frame underneath shares the same render context, allocation hints, and source registry."
>
  <ApiEntry
    name="<Press>"
    kind="component"
    importFrom={'import { Press } from "@open-press/core";'}
    signature={`<Press allocation?={Allocation} hints?={Hints}>
  {/* document tree: Frames, manuscript helpers */}
</Press>`}
    summary="Top-level React component. Holds the allocation map produced by the measurement pipeline and the source registry your document depends on. Render only one Press per document."
  >
    <PropsTable
      title="Props"
      rows={[
        {
          name: "children",
          type: "ReactNode",
          required: true,
          description:
            "Your document body — typically one or more <code>&lt;Frame&gt;</code> instances or manuscript helpers like <code>&lt;Sections&gt;</code> and <code>&lt;Toc&gt;</code>.",
        },
        {
          name: "allocation",
          type: "Allocation",
          description:
            "Injected by the renderer after measurement. You never pass this manually — the engine wires it in during export. Reading it via <code>PressContext</code> is part of the public surface for custom helpers.",
        },
        {
          name: "hints",
          type: "Hints",
          description:
            "Engine-fed pagination hints (e.g. <code>totalPagesPerChain</code>). Same story as <code>allocation</code> — read via context, do not pass manually.",
        },
      ]}
    />

    <Example title="Minimum document/index.tsx" language="tsx">
{`import { Press, Frame, MdxArea } from "@open-press/core";
import { mdxSource } from "@open-press/core/mdx";

export const config = {
  title: "Hello",
  page: "a4",
};

export const sources = {
  story: mdxSource({ preset: "section-folders", root: "chapters" }),
};

export default function Document() {
  return (
    <Press>
      <Frame frameKey="cover" role="document.cover">
        <h1>Hello</h1>
      </Frame>
      <Frame frameKey="story-1" role="document.content">
        <MdxArea chainId="story" />
      </Frame>
    </Press>
  );
}`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="PressContext"
    kind="context"
    importFrom={'import { PressContext } from "@open-press/core";'}
    signature={`PressContext.Provider value={{ allocation, hints, sources }}
const press = useContext(PressContext);  // -> { allocation, hints, sources } | null`}
    summary="React context that <Press> populates. Read it in custom frame components or manuscript helpers when you need pagination hints or the registered sources map. Most workspaces never touch this directly."
  >
    <Example title="Reading hints from a custom helper" language="tsx">
{`import { useContext } from "react";
import { PressContext } from "@open-press/core";

function ChapterCount() {
  const press = useContext(PressContext);
  const totalPages = press?.hints?.totalPagesPerChain?.["story"] ?? 0;
  return <span>{totalPages} pages</span>;
}`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="PRESS_MARKER"
    kind="symbol"
    importFrom={'import { PRESS_MARKER } from "@open-press/core";'}
    summary="Symbol the renderer uses to detect Press instances when walking the React tree. Exposed for tooling and custom wrappers — you rarely consume it in user code."
  />

  <h2>Notes</h2>

  <ul>
    <li>
      A Press Tree must have exactly one <code>&lt;Press&gt;</code> root. The engine asserts this during
      export.
    </li>
    <li>
      <code>config</code> and <code>sources</code> exports from <code>document/index.tsx</code> are how
      the engine learns metadata and source registrations — they live <em>outside</em> the Press tree, as
      named module exports.
    </li>
    <li>
      Frame ordering inside Press matches output page order. Manuscript helpers like
      <code>&lt;Sections&gt;</code> generate frames at runtime to fill that order with allocated content.
    </li>
  </ul>
</DocLayout>
