---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="Press"
  eyebrow="@open-press/core"
  description="The document composition boundary. In document/index.tsx, wrap the whole document in one <Press>; put covers, content helpers, and back covers underneath it."
>
  <ApiEntry
    name="<Press>"
    kind="component"
    importFrom={'import { Press } from "@open-press/core";'}
    signature={`<Press>
  {/* document tree: Frames, manuscript helpers */}
</Press>`}
    summary="Top-level React component for an OpenPress document. It does not create a page by itself; it defines the tree that the renderer will measure and export. Use exactly one Press per document."
  >
    <PropsTable
      title="Props"
      rows={[
        {
          name: "children",
          type: "ReactNode",
          required: true,
          description:
            "Your document body — typically one or more <code>&lt;Frame&gt;</code> instances or manuscript helpers like <code>&lt;Sections&gt;</code> and <code>&lt;Toc&gt;</code>.",
        },
      ]}
    />

    <Example title="Minimum document/index.tsx" language="tsx" code={`import { Press, Frame } from "@open-press/core";
import { mdxSource } from "@open-press/core/mdx";
import { Sections, Toc } from "@open-press/core/manuscript";

export const config = {
  title: "Hello",
  page: "a4",
};

export const sources = {
  story: mdxSource({ preset: "section-folders", root: "chapters" }),
};

export default function Document() {
  return (
    <Press>
      <Frame frameKey="cover" role="document.cover">
        <h1>Hello</h1>
      </Frame>
      <Toc source="story" maxLevel={2} />
      <Sections source="story" />
      <Frame frameKey="back-cover" role="document.back-cover">
        <p>Done.</p>
      </Frame>
    </Press>
  );
}`} />
  </ApiEntry>

  <h2>Runtime contract</h2>

  <p>
    You do not pass pagination state into <code>&lt;Press&gt;</code>. During export, OpenPress renders
    the tree more than once: first to discover frames and content slots, then again after it knows where
    each source block belongs. That runtime state is internal to the renderer.
  </p>

  <PropsTable
    title="What Press guarantees"
    rows={[
      {
        name: "Tree boundary",
        type: "contract",
        description:
          "Everything that should become part of the document must be rendered under the single <code>&lt;Press&gt;</code> root.",
      },
      {
        name: "Page order",
        type: "contract",
        description:
          "Top-level frames and helpers render in document order. A cover before <code>&lt;Sections&gt;</code> appears before the generated content pages.",
      },
      {
        name: "Shared source registry",
        type: "contract",
        description:
          "Helpers under <code>&lt;Press&gt;</code> can use the <code>sources</code> export from the same <code>document/index.tsx</code> module.",
      },
      {
        name: "Renderer-owned pagination",
        type: "contract",
        description:
          "OpenPress may render the tree repeatedly to calculate page counts and content placement. Authors should describe pages declaratively and avoid render-time side effects.",
      },
    ]}
  />

  <h2>Authoring rules</h2>

  <ul>
    <li>
      A Press Tree must have exactly one <code>&lt;Press&gt;</code> root. OpenPress checks this during
      export.
    </li>
    <li>
      <code>config</code> and <code>sources</code> live outside the Press tree as named exports from
      <code>document/index.tsx</code>.
    </li>
    <li>
      Covers and back covers do not need special APIs. They are ordinary <code>&lt;Frame&gt;</code>
      components placed before or after the content helpers.
    </li>
    <li>
      Do not fetch files, mutate globals, or depend on random values while rendering the Press tree.
      The renderer may run the tree multiple times.
    </li>
  </ul>
</DocLayout>
