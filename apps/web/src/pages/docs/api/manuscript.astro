---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="Manuscript helpers"
  eyebrow="@open-press/core/manuscript"
  description="Optional helpers for long-form section flow. Sections walks a registered source and emits one frame per section, paginating across as many frames as the content needs. Toc + TocArea give you a generated table of contents."
>
  <p>
    Slide and social packs typically skip this module — they declare their pages manually with
    <code>&lt;Frame&gt;</code>. The manuscript layer is for reports, papers, monographs, and books.
  </p>

  <ApiEntry
    name="<Sections>"
    kind="component"
    importFrom={'import { Sections } from "@open-press/core/manuscript";'}
    signature={`<Sections
  source="story"
  page?={SectionsPageComponent}
  opener?={SectionsOpenerComponent}
/>`}
    summary="Iterates a registered MDX source and emits frames for each section, spawning extra frames when content overflows. Each emitted frame renders your page component once per page."
  >
    <PropsTable
      title="Props"
      rows={[
        {
          name: "source",
          type: "string",
          required: true,
          description: "The <code>sourceId</code> registered in <code>press/index.tsx</code> <code>sources</code>.",
        },
        {
          name: "page",
          type: "ComponentType<SectionsPageProps>",
          default: "DefaultSectionPage",
          description:
            "Per-page component the helper renders for each frame it spawns. Receives <code>frameKey</code>, <code>chainId</code>, <code>pageIndex</code>, <code>totalPages</code>, <code>sectionSlug</code>, <code>sectionTitle</code>, <code>sectionTone</code>.",
        },
        {
          name: "opener",
          type: "ComponentType<SectionsOpenerProps>",
          description:
            "Optional component rendered before each section's first content page (chapter opener / divider). Receives <code>frameKey</code>, <code>sectionSlug</code>, <code>sectionTitle</code>, <code>sectionTone</code>.",
        },
      ]}
    />

    <Example title="Use the bundled default page" language="tsx" code={`<Press>
  <Sections source="story" />
</Press>`} />

    <Example title="Custom page component" language="tsx" code={`function ContentPage({
  frameKey, chainId, pageIndex, totalPages, sectionTitle,
}: SectionsPageProps) {
  return (
    <Frame frameKey={frameKey} role="document.content">
      <div className="page-frame">
        <main className="page-body">
          <MdxArea chainId={chainId} />
        </main>
        <footer className="page-footer">
          <span>{sectionTitle}</span>
          <span>{pageIndex + 1}/{totalPages}</span>
        </footer>
      </div>
    </Frame>
  );
}

<Press><Sections source="story" page={ContentPage} /></Press>`} />
  </ApiEntry>

  <ApiEntry
    name="Chapters"
    kind="component"
    importFrom={'import { Chapters } from "@open-press/core/manuscript";'}
    summary="Identical to Sections — alias for vocabulary clarity when your source uses 'chapter' instead of 'section'. ChaptersProps === SectionsProps."
  />

  <ApiEntry
    name="DefaultSectionPage"
    kind="component"
    importFrom={'import { DefaultSectionPage } from "@open-press/core/manuscript";'}
    signature={`<DefaultSectionPage {...sectionsPageProps} />`}
    summary="The fallback page component <Sections> uses when no page prop is supplied. Renders a standard manuscript frame with header / body / footer chrome and a single MdxArea filling the body."
  />

  <ApiEntry
    name="<Toc>"
    kind="component"
    importFrom={'import { Toc } from "@open-press/core/manuscript";'}
    signature={`<Toc
  source="story"
  maxLevel?={3}
  page?={TocPageComponent}
/>`}
    summary="Emits a frame for the table of contents. The engine generates a TOC chain by walking the source's heading structure; Toc allocates that chain into one or more frames."
  >
    <PropsTable
      title="Props"
      rows={[
        {
          name: "source",
          type: "string",
          required: true,
          description: "Source id to build a TOC from.",
        },
        {
          name: "maxLevel",
          type: "number",
          default: "3",
          description: "Deepest heading level included in the TOC. 1 = H1 only, 3 = H1+H2+H3.",
        },
        {
          name: "page",
          type: "ComponentType<TocPageProps>",
          description: "Optional custom TOC page component. Default page renders <code>&lt;TocArea&gt;</code> inside a standard frame.",
        },
      ]}
    />
  </ApiEntry>

  <ApiEntry
    name="<TocArea>"
    kind="component"
    importFrom={'import { TocArea } from "@open-press/core/manuscript";'}
    signature={`<TocArea
  chainId="toc:story"
  maxLevel?={3}
  overflow?="extend"
  className?
/>`}
    summary="A measurable TOC content slot — the TOC equivalent of MdxArea. Use inside a custom <Toc> page component when you need to control the surrounding layout. The default Toc page already wraps a TocArea for you."
  >
    <PropsTable
      title="Props"
      rows={[
        { name: "chainId", type: "string", required: true, description: "TOC chain id — typically <code>toc:&lt;sourceId&gt;</code>." },
        { name: "maxLevel", type: "number", default: "3", description: "Deepest heading level rendered as a TOC entry." },
        { name: "overflow", type: '"extend" | "truncate"', default: '"extend"', description: "Same semantics as <code>MdxArea</code>." },
        { name: "className", type: "string", description: "Appended to the rendered <code>&lt;ol class=\"toc-list\"&gt;</code> wrapper." },
      ]}
    />
  </ApiEntry>

  <h2>Notes</h2>

  <ul>
    <li>
      Manuscript frames carry <code>role="manuscript.content"</code> or <code>role="manuscript.toc"</code>
      by default — style packs use those role strings to scope CSS.
    </li>
    <li>
      The TOC source chain is named <code>toc:&lt;sourceId&gt;</code> and is generated by the engine, not
      registered manually. You can't write into a TOC chain; only the heading walker fills it.
    </li>
    <li>
      Slide / social packs intentionally skip this module. If you find yourself fighting the manuscript
      page component for a fixed-format page, write <code>&lt;Frame&gt;</code> directly with
      <code>chrome={false}</code> + <code>MdxArea overflow="truncate"</code>.
    </li>
  </ul>
</DocLayout>
