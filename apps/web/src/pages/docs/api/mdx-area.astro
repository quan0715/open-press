---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="MdxArea"
  eyebrow="@open-press/core"
  description="A measurable content slot inside a Frame. The engine fills MdxArea instances with allocated blocks from a source chain — your job is to declare where MDX content goes; the engine handles measurement, pagination, and overflow."
>
  <ApiEntry
    name="<MdxArea>"
    kind="component"
    importFrom={'import { MdxArea } from "@open-press/core";'}
    signature={`<MdxArea chainId="story" overflow?="extend" className?="my-area" />`}
    summary="Renders a <div data-openpress-mdx-area> slot inside the active Frame. The engine measures the slot during export, allocates blocks from the named chain, and re-renders with the resolved content."
  >
    <PropsTable
      title="Props"
      rows={[
        {
          name: "chainId",
          type: "string",
          required: true,
          description:
            "The source chain this slot draws from. Sources defined with <code>mdxSource()</code> emit chains named after the source key (e.g. <code>story</code>); manuscript helpers like <code>Sections</code> pass chain ids derived from sections (<code>chapter:intro</code>).",
        },
        {
          name: "overflow",
          type: '"extend" | "truncate"',
          default: '"extend"',
          description:
            "<strong>extend</strong> — when allocated blocks don't fit, the engine spawns more frames (long-form pagination). <strong>truncate</strong> — fit what you can, drop the rest (fixed-format slides / social cards).",
        },
        {
          name: "className",
          type: "string",
          description: "Appended to the rendered <code>&lt;div&gt;</code>. Style packs use this to scope typography or layout for specific slots.",
        },
        {
          name: "...rest",
          type: "HTMLAttributes",
          description: "Pass-through to the underlying <code>&lt;div&gt;</code>.",
        },
      ]}
    />

    <Example title="Long-form content slot (auto-paginates)" language="tsx">
{`<Frame frameKey="ch-1" role="document.content">
  <div className="page-frame">
    <main className="page-body">
      <MdxArea chainId="story" />
    </main>
  </div>
</Frame>`}
    </Example>

    <Example title="Fixed slide slot (truncate on overflow)" language="tsx">
{`<Frame frameKey="slide-1" role="canvas.slide" chrome={false}>
  <div className="page-frame">
    <main className="page-body">
      <MdxArea chainId="slides" overflow="truncate" />
    </main>
  </div>
</Frame>`}
    </Example>
  </ApiEntry>

  <h2>Data attributes the renderer writes</h2>

  <PropsTable
    rows={[
      {
        name: "data-openpress-mdx-area",
        type: '"true"',
        description: "Marker attribute, always present. Selectors target <code>[data-openpress-mdx-area]</code>.",
      },
      {
        name: "data-openpress-mdx-area-chain",
        type: "string",
        description: "Mirrors <code>chainId</code>.",
      },
      {
        name: "data-openpress-mdx-area-index",
        type: "number",
        description:
          "Slot index within the parent frame, in source order. Multiple MdxArea with the same chain in one frame get 0, 1, 2, …",
      },
      {
        name: "data-openpress-object-id",
        type: "string",
        description: "MDX-area-level object id (<code>mdx-area:&lt;frameKey&gt;:&lt;chainId&gt;:&lt;index&gt;</code>) — used by the inspector and comment-marker system.",
      },
      {
        name: "data-openpress-mdx-area-overflow",
        type: '"extend" | "truncate"',
        description: "Mirrors the <code>overflow</code> prop.",
      },
      {
        name: "data-openpress-mdx-area-empty",
        type: '"true" | "false"',
        description: "<code>true</code> while no blocks have been allocated into this slot — useful for showing a placeholder.",
      },
    ]}
  />

  <h2>Notes</h2>

  <ul>
    <li>
      An <code>&lt;MdxArea&gt;</code> outside <code>&lt;Frame&gt;</code> renders as empty — the
      <code>FrameContext</code> is required to learn its slot index.
    </li>
    <li>
      <code>overflow="truncate"</code> is currently silent — content that doesn't fit is dropped without a
      warning. Verify slide and social-card output before deploy.
    </li>
    <li>
      The engine knows TOC chains by id prefix <code>toc:</code>; <code>TocArea</code> (in
      <code>@open-press/core/manuscript</code>) is just an MdxArea pre-configured for that prefix and
      wrapped in an <code>&lt;ol class="toc-list"&gt;</code>.
    </li>
  </ul>
</DocLayout>
