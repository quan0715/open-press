---
import DocLayout from "../../layouts/DocLayout.astro";
import ApiEntry from "../../components/docs/ApiEntry.astro";
import PropsTable from "../../components/docs/PropsTable.astro";
import Example from "../../components/docs/Example.astro";
---

<DocLayout
  title="CLI commands"
  eyebrow="@open-press/cli"
  description="The CLI is organized in three tiers — lifecycle (init / dev / build / preview / typecheck), output targets (pdf, deploy, image planned), and tools (source / inspect / doctor / upgrade) for agents and workbench."
>
  <p>
    OpenPress ships two binaries: <code>npx @open-press/cli init</code> is the external bootstrapper that
    creates a workspace, and <code>node engine/cli.mjs &lt;command&gt;</code> (with matching npm scripts) runs
    everything else from inside a workspace. Both go through the same engine.
  </p>

  <div class="callout">
    <strong>Surface stability.</strong> Tier&nbsp;1 + Tier&nbsp;2 commands are part of the 1.0 contract.
    Tier&nbsp;3 tools are stable but their names may move to <code>verb-noun</code>
    (<code>open-press source search</code>) in v0.10 — the underlying behavior won't change.
  </div>

  <!-- ─────────────────────────── Tier 1 — Lifecycle ─────────────────────────── -->
  <h2>Lifecycle</h2>

  <p>
    The standard Vite-style four-step lifecycle. Every workspace exposes these as plain npm scripts
    with no <code>openpress:</code> prefix.
  </p>

  <ApiEntry
    name="init"
    kind="command"
    importFrom="npx @open-press/cli init <target> [flags]"
    summary="Create a new OpenPress workspace at <target>, optionally pre-loaded with a bundled or GitHub-hosted style pack."
  >
    <PropsTable
      title="Flags"
      rows={[
        {
          name: "<target>",
          type: "string",
          required: true,
          description: "Positional. Target directory — created if missing.",
        },
        {
          name: "--pack",
          type: "string",
          description:
            "Bundled pack name (<code>editorial-monograph</code>, <code>claude-document</code>, <code>academic-paper</code>, <code>social-post</code>, <code>slide-deck</code>) or <code>github:owner/repo[#ref]</code>. Omit for an empty skeleton.",
        },
        { name: "--title", type: "string", description: "Document title — patched into config files." },
        { name: "--subtitle", type: "string", description: "Document subtitle." },
        { name: "--organization", type: "string", description: "Organization name." },
        { name: "--author", type: "string", description: "Author name." },
        { name: "--no-install", type: "flag", description: "Skip <code>npm install</code> after copying template files." },
        { name: "--no-git", type: "flag", description: "Skip <code>git init</code> + initial commit." },
        { name: "--force", type: "flag", description: "Overwrite a non-empty target directory." },
      ]}
    />

    <Example title="Bundled pack" language="bash">
{`npx @open-press/cli init my-paper \\
  --pack academic-paper \\
  --title "Transport models in dense networks" \\
  --organization "Lab"`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="dev"
    kind="command"
    importFrom="npm run dev"
    summary="Start the local workbench at http://127.0.0.1:5173. Hot-reloads CSS and React UI chrome; MDX content edits refresh on save through the engine's source watcher."
  >
    <Example title="Start the workbench" language="bash">
{`npm run dev
# → workbench at http://127.0.0.1:5173/?dev=1
# → public reader at http://127.0.0.1:5173`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="build"
    kind="command"
    importFrom="npm run build"
    summary="Produce the deploy-ready bundle in dist-react/. Chains source validation, MDX → React export, and Vite production build. If validation fails the build aborts."
  >
    <Example title="Build for production" language="bash">
{`npm run build
# → dist-react/ ready to host`}
    </Example>

    <p>
      The intermediate engine steps (<code>export</code>, <code>validate</code>) exist for advanced
      callers but are not user-facing — they run automatically inside <code>build</code>. To validate
      without rendering, run <code>node engine/cli.mjs validate .</code> directly.
    </p>
  </ApiEntry>

  <ApiEntry
    name="preview"
    kind="command"
    importFrom="npm run preview"
    summary="Serve the built dist-react/ output as a static site, without workbench chrome. Use to verify the public reader before deploy."
  />

  <ApiEntry
    name="typecheck"
    kind="command"
    importFrom="npm run typecheck"
    summary="Run TypeScript checks across the workspace tree (tsc --noEmit). Catch type errors that the bundler skips."
  />

  <!-- ─────────────────────── Tier 2 — Output targets ─────────────────────── -->
  <h2>Output targets</h2>

  <p>
    Tier 2 produces a specific deliverable other than the standard HTML bundle. Each target has its
    own heavy dependency (Chromium for PDF/image, an adapter for deploy), so they're kept as
    explicit commands rather than flags on <code>build</code>.
  </p>

  <ApiEntry
    name="openpress:pdf"
    kind="command"
    importFrom="npm run openpress:pdf"
    summary="Generate a PDF locally via Chromium. Output filename comes from config.pdf.filename. Builds first if dist-react/ is stale."
  >
    <PropsTable
      title="Flags"
      rows={[
        { name: "--output", type: "string", description: "Override the output path. Defaults to <code>config.pdf.filename</code> next to the workspace." },
        { name: "--no-build", type: "flag", description: "Reuse the existing <code>dist-react/</code> output instead of re-building." },
        { name: "--host", type: "string", default: '"127.0.0.1"', description: "Static server host used while Chromium is rendering." },
        { name: "--port", type: "string", default: '"5185"', description: "Static server port." },
      ]}
    />
  </ApiEntry>

  <ApiEntry
    name="openpress:image"
    kind="command"
    importFrom="# Planned for v0.10"
    summary="Planned. One PNG per page (or a single composite). Will share the Chromium snapshot stage with openpress:pdf."
  >
    <p>
      Until shipped, render a page in the workbench and use the browser's "Save as image" or a manual
      Playwright script against the <code>preview</code> server.
    </p>
  </ApiEntry>

  <ApiEntry
    name="openpress:deploy"
    kind="command"
    importFrom="npm run openpress:deploy"
    summary="Run the configured deploy adapter. Builds, generates the PDF stage artifact, writes deploy metadata, then hands off to the adapter. Always requires --confirm — there is no silent deploy."
  >
    <PropsTable
      title="Flags"
      rows={[
        {
          name: "--confirm",
          type: "flag",
          description:
            "Required for a real deploy. Skips the interactive prompt; CI should set this only after a separate gate.",
        },
        { name: "--dry-run", type: "flag", description: "Run preflight only; print the command sequence; do not publish." },
      ]}
    />

    <Example title="Dry run from local" language="bash">
{`npm run openpress:deploy:dry-run
# → reports adapter, target, and what would change`}
    </Example>

    <h3>Adapters</h3>

    <p>
      The active adapter is selected by <code>config.deploy.adapter</code>. Each adapter has its own
      config block — see <a href="/docs/config#deploy">Workspace config → Deploy</a>.
    </p>

    <PropsTable
      title="Built-in adapters"
      rows={[
        {
          name: '"cloudflare-pages"',
          type: "shipped",
          description:
            "Calls <code>npx wrangler pages deploy</code>. Required config: <code>projectName</code>. Optional: <code>commitDirty</code>. Requires wrangler login on the deploying machine.",
        },
        {
          name: '"static-dir"',
          type: "planned",
          description:
            "Planned. Copy the deploy stage to a local folder (for hand-off to a separate uploader / S3 sync / etc).",
        },
      ]}
    />
  </ApiEntry>

  <!-- ─────────────────────────── Tier 3 — Tools ─────────────────────────── -->
  <h2>Tools</h2>

  <p>
    Tier 3 commands are utilities for agents, the workbench, and debugging — not part of the
    everyday build loop. They run only via <code>node engine/cli.mjs</code>, not via npm scripts.
    Names may move to <code>verb-noun</code> grouping in v0.10
    (e.g. <code>source search</code>, <code>render inspect</code>, <code>env doctor</code>).
  </p>

  <ApiEntry
    name="search"
    kind="command"
    importFrom="node engine/cli.mjs search . <query> [--json]"
    summary="Full-text search across registered MDX sources. Returns file, line, column, and matched preview for each hit. Used by agents to locate content before editing."
  >
    <PropsTable
      title="Flags"
      rows={[
        { name: "<query>", type: "string", required: true, description: "Plain text or regex pattern." },
        { name: "--json", type: "flag", description: "Emit machine-readable JSON instead of formatted output." },
        { name: "--scope", type: "string", default: '"content"', description: "<code>content</code> = MDX body only; <code>all</code> = include frontmatter and metadata fields." },
        { name: "--case-sensitive", type: "flag", description: "Match case literally." },
      ]}
    />
  </ApiEntry>

  <ApiEntry
    name="replace"
    kind="command"
    importFrom="node engine/cli.mjs replace . <from> <to> [--apply]"
    summary="Search and replace across MDX sources. Previews by default — pass --apply to write. Agents use this for bulk edits without re-implementing diffs."
  >
    <PropsTable
      title="Flags"
      rows={[
        { name: "<from>", type: "string", required: true, description: "Source string or regex." },
        { name: "<to>", type: "string", required: true, description: "Replacement text." },
        { name: "--apply", type: "flag", description: "Write changes. Without this flag, the command only previews." },
        { name: "--scope", type: "string", default: '"content"', description: "Same semantics as search." },
        { name: "--include-code", type: "flag", description: "Also replace inside fenced code blocks (skipped by default)." },
        { name: "--case-sensitive", type: "flag", description: "Match case literally." },
        { name: "--json", type: "flag", description: "Emit JSON report." },
      ]}
    />

    <Example title="Preview, then apply" language="bash">
{`node engine/cli.mjs replace . "old phrase" "new phrase"
# review the diff report

node engine/cli.mjs replace . "old phrase" "new phrase" --apply
# writes the changes`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="inspect"
    kind="command"
    importFrom="node engine/cli.mjs inspect . [--json]"
    summary="Post-render introspection. Builds the workspace, launches headless Chrome, and reports block geometry / comment markers / TOC chain output. Used by the workbench inspector and by agents that need ground-truth layout data."
  >
    <PropsTable
      title="Flags"
      rows={[
        { name: "--json", type: "flag", description: "Emit JSON report. Required when consumed by an agent." },
        { name: "--no-build", type: "flag", description: "Reuse the existing <code>dist-react/</code> build." },
        { name: "--host / --port", type: "string", description: "Static server bind for the headless Chrome session." },
        { name: "--dry-run", type: "flag", description: "Print the underlying command chain without running." },
      ]}
    />

    <p>
      <strong>inspect vs validate.</strong> <code>validate</code> is source-level (config / source refs);
      <code>inspect</code> is post-render (real block positions). Both are legitimate — use validate
      for fast preflight, inspect when an agent needs to know how the page actually paginated.
    </p>
  </ApiEntry>

  <ApiEntry
    name="doctor"
    kind="command"
    importFrom="node engine/cli.mjs doctor ."
    summary="Environment + workspace diagnostic. Reports Node version, package manager, missing deps, wrangler login state, Chromium availability, and other things that commonly block dev / build / deploy."
  />

  <ApiEntry
    name="upgrade"
    kind="command"
    importFrom="node engine/cli.mjs upgrade ."
    summary="Migrate a workspace to the current framework version: refresh the vendored engine/ directory, update template configs, apply migration scripts. Alias: migrate."
  />

  <ApiEntry
    name="skills:sync"
    kind="command"
    importFrom="# Planned for v0.10"
    summary="Planned. Sync .claude/skills/ (and Cursor / Codex equivalents) from the workspace's resolved style pack so AI agents always see the latest authoring rules. Currently the only way is to re-run init in a temp folder and diff."
  />
</DocLayout>
