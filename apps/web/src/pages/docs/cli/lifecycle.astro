---
import DocLayout from "../../../layouts/DocLayout.astro";
import ApiEntry from "../../../components/docs/ApiEntry.astro";
import PropsTable from "../../../components/docs/PropsTable.astro";
import Example from "../../../components/docs/Example.astro";
---

<DocLayout
  title="Lifecycle"
  eyebrow="CLI · Tier 1"
  description="The five standard commands every workspace exposes — init / dev / build / preview / typecheck. Same shape as Vite or Astro, no openpress: prefix."
>
  <p>
    Tier 1 covers the everyday workspace loop: create one, develop in it, ship it, verify it.
    Each command below has a matching <code>npm run</code> script in the scaffolded
    <code>package.json</code>, so this is the surface most authors and CI scripts use.
  </p>

  <ApiEntry
    name="init"
    kind="command"
    importFrom="npx @open-press/cli init <target> [flags]"
    summary="Create a new OpenPress workspace at <target>, optionally pre-loaded with a bundled or GitHub-hosted style pack. Copies templates, patches metadata, runs npm install + git init by default."
  >
    <PropsTable
      title="Positional + content flags"
      rows={[
        {
          name: "<target>",
          type: "string",
          required: true,
          description: "Target directory — created if missing. Pass <code>--force</code> to scaffold into a non-empty dir.",
        },
        {
          name: "--pack",
          type: "string",
          description:
            "Bundled pack name (<code>editorial-monograph</code>, <code>claude-document</code>, <code>academic-paper</code>, <code>social-post</code>, <code>slide-deck</code>) or <code>github:owner/repo[#ref]</code> for a remote pack. Omit for an empty skeleton.",
        },
        { name: "--title", type: "string", description: "Document title — patched into <code>openpress.config.mjs</code> and metadata files." },
        { name: "--subtitle", type: "string", description: "Document subtitle." },
        { name: "--organization", type: "string", description: "Organization name." },
        { name: "--author", type: "string", description: "Author name." },
      ]}
    />

    <PropsTable
      title="Behavior flags"
      rows={[
        {
          name: "--force",
          type: "flag",
          description:
            "Allow scaffolding into a non-empty target directory. Without this, init aborts if the target has existing files (anything except a lone empty <code>.git/</code> is considered non-empty).",
        },
        {
          name: "--no-install",
          type: "flag",
          description:
            "Skip the automatic <code>npm install</code> after template copy. Use when you're working offline, managing deps with pnpm/bun yourself, or scripting init from a parent monorepo.",
        },
        {
          name: "--no-git",
          type: "flag",
          description:
            "Skip <code>git init</code> + the initial commit. Use when scaffolding inside an existing repo, or when your tooling manages git state separately.",
        },
      ]}
    />

    <Example title="Bundled pack with metadata" language="bash">
{`npx @open-press/cli init my-paper \\
  --pack academic-paper \\
  --title "Transport models in dense networks" \\
  --organization "Lab"`}
    </Example>

    <Example title="Scaffold into existing repo" language="bash">
{`# Inside an existing git repo, no auto-commit, manage deps yourself:
npx @open-press/cli init ./docs \\
  --pack editorial-monograph \\
  --no-git \\
  --no-install
pnpm install`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="dev"
    kind="command"
    importFrom="npm run dev"
    summary="Start the local workbench at http://127.0.0.1:5173. Hot-reloads CSS, theme tokens, and React UI chrome; MDX content edits refresh through the engine's source watcher."
  >
    <Example title="Start the workbench" language="bash">
{`npm run dev
# → workbench at http://127.0.0.1:5173/?dev=1
# → public reader at http://127.0.0.1:5173`}
    </Example>

    <p>
      The query string <code>?dev=1</code> toggles the workbench shell (inspector, source-edit
      endpoint, comment markers). Strip it to see what a reader will see.
    </p>
  </ApiEntry>

  <ApiEntry
    name="build"
    kind="command"
    importFrom="npm run build"
    summary="Produce the deploy-ready bundle in dist-react/. Chains source validation, MDX → React export, and Vite production build. If validation fails, the build aborts before Vite runs."
  >
    <Example title="Build for production" language="bash">
{`npm run build
# → dist-react/ ready to host`}
    </Example>

    <p>
      The intermediate engine steps (<code>export</code>, <code>validate</code>) exist for advanced
      callers but are not user-facing — they run automatically inside <code>build</code>. To validate
      without rendering, call <code>node engine/cli.mjs validate .</code> directly; that's mostly a
      CI lint or agent preflight.
    </p>
  </ApiEntry>

  <ApiEntry
    name="preview"
    kind="command"
    importFrom="npm run preview"
    summary="Serve dist-react/ as a static site without workbench chrome. Use to verify the public reader matches expectations before deploy."
  >
    <Example title="Preview after build" language="bash">
{`npm run build
npm run preview
# → reader at http://127.0.0.1:4173 (no workbench)`}
    </Example>
  </ApiEntry>

  <ApiEntry
    name="typecheck"
    kind="command"
    importFrom="npm run typecheck"
    summary="Run TypeScript checks across the workspace tree. Literally tsc --noEmit -p tsconfig.json — catches type errors that the bundler doesn't surface (unused exports, prop mismatches, narrowed types broken by edits)."
  >
    <p>
      <strong>What it does NOT do:</strong> validate MDX content shape, resolve cross-section links,
      or check theme tokens — those belong to <a href="/docs/cli/tools">Tier 3 tools</a>
      (<code>validate</code>, <code>inspect</code>). Typecheck is purely about TypeScript correctness.
    </p>
  </ApiEntry>
</DocLayout>
