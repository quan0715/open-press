---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";

const version = "0.3.0";
const workflowPrompts = {
  initialization:
    "Using OpenPress, help me initialize a document workspace. Ask for title, audience, language, and style pack, then create the starter project with a first outline.",
  expansion:
    "Use OpenPress writing and hierarchy skills. Turn the current outline into chapter 1, keep confirmed facts unchanged, and mark missing details as [TODO].",
  deploy:
    "Use OpenPress deploy flow. Run validation, render the web reader, export the PDF, and prepare a Cloudflare Pages deploy dry run before publishing.",
};
---

<Layout>
  <header class="nav">
    <div class="op-page nav__inner">
      <a class="nav__brand" href="/" aria-label="open-press">
        open-press
      </a>
      <nav class="nav__links">
        <a href="https://open-press-story.pages.dev">Document</a>
        <a href="/showcase">Showcase</a>
        <a href="https://github.com/quan0715/open-press">GitHub</a>
        <a href="https://www.npmjs.com/package/@open-press/cli">npm</a>
        <a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">v{version}</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">OpenPress · document tree · rendered output · v{version}</p>
          <h1 class="hero__title">
            OpenPress turns a
            <span class="hero__title-accent">document tree</span>
            into publishable pages.
          </h1>

          <p class="hero__kicker">
            Chapters live as MDX, design decisions live as tokens, and the same
            workspace renders fixed-layout A4 pages, PDF, and a public web
            reader.
          </p>

          <div class="hero__actions">
            <div class="hero__command">
              <CodeBlock command="npx skills add quan0715/open-press" />
            </div>
            <a class="hero__example" href="https://open-press-story.pages.dev">
              View live example
            </a>
          </div>

          <figure class="hero__artifact" aria-label="OpenPress document tree rendering flow">
            <div class="hero__source-panel">
              <p class="hero__artifact-label">document tree</p>
              <ol class="hero__tree" aria-hidden="true">
                <li><span>document/</span></li>
                <li class="hero__tree-child"><span>chapters/</span></li>
                <li class="hero__tree-leaf"><span>01-introduction.mdx</span></li>
                <li class="hero__tree-leaf hero__tree-leaf--active"><span>02-workflow.mdx</span></li>
                <li class="hero__tree-child"><span>tokens/</span></li>
                <li class="hero__tree-leaf"><span>theme.ts</span></li>
                <li><span>openpress.config.ts</span></li>
              </ol>
              <div class="hero__source-card hero__source-card--tokens" aria-hidden="true">
                <span>theme.accent = "brick"</span>
                <span>page.margin = "wide"</span>
              </div>
              <div class="hero__source-card hero__source-card--mdx" aria-hidden="true">
                <span># Workflow</span>
                <span>&lt;Callout tone="note" /&gt;</span>
              </div>
            </div>
            <div class="hero__render-panel" aria-hidden="true">
              <p class="hero__artifact-label">rendered page</p>
              <div class="hero__render-page">
                <span class="hero__render-rule"></span>
                <span class="hero__render-title">Workflow</span>
                <span class="hero__render-accent"></span>
                <span class="hero__render-line hero__render-line--long"></span>
                <span class="hero__render-line"></span>
                <span class="hero__render-callout"></span>
                <span class="hero__render-footer"></span>
              </div>
            </div>
          </figure>

          <p class="hero__hint op-meta">
            Click to copy · skills install under <code>.agents/skills/</code>,
            auto-detected by Claude Code, Cursor, Codex, Gemini CLI, Cline,
            Continue, and 50+ other AI agents.
          </p>

          <ul class="hero__signals" aria-label="OpenPress product highlights">
            <li>Chapters map to the document table of contents</li>
            <li>Theme tokens control page rhythm, type, and accent</li>
            <li>MDX changes re-render into A4 pages and the web reader</li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="product-features">
      <div class="op-page">
        <div class="op-content-wide">
          <p class="op-eyebrow">Why OpenPress</p>
          <h2 class="product-features__title">
            Your agent edits source; OpenPress renders the document.
          </h2>

          <div class="product-feature-grid">
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--tree" aria-hidden="true">
                <span>document/</span>
                <span>chapters/</span>
                <span>01-intro.mdx</span>
                <span>02-workflow.mdx</span>
              </div>
              <p class="product-feature__kicker">Document tree</p>
              <h3>Chapters are a navigable structure.</h3>
              <p>
                The source mirrors the table of contents: cover, chapters,
                appendix, assets, and config stay in predictable places.
              </p>
            </article>
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--tokens" aria-hidden="true">
                <span>accent</span>
                <span>type scale</span>
                <span>margin</span>
                <span>folio</span>
              </div>
              <p class="product-feature__kicker">Theme tokens</p>
              <h3>Design changes are controlled inputs.</h3>
              <p>
                Typography, margins, accent color, and page rhythm live in
                tokens instead of being scattered across one-off CSS edits.
              </p>
            </article>
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--mdx" aria-hidden="true">
                <span># Chapter</span>
                <span>&lt;Figure /&gt;</span>
                <span>&lt;Callout /&gt;</span>
              </div>
              <p class="product-feature__kicker">MDX content</p>
              <h3>Content changes render into pages.</h3>
              <p>
                A chapter file can mix prose, figures, callouts, and tables;
                preview shows exactly what changed before PDF export.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="workflow">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">Init -> author -> publish</p>
          <h2 class="workflow__title">
            Talk to the agent. Then inspect the page.
          </h2>
          <p class="workflow__lede">
            Copy the prompt for the stage you are in. The agent writes into the
            workspace; OpenPress keeps the result page-safe, reviewable, and
            ready to deploy.
          </p>

          <ol class="workflow__steps">
            <li>
              <span class="workflow__num">1.</span>
              <div>
                <h3 class="workflow__label">Init the workspace</h3>
                <p>
                  Start from title, audience, language, and style pack. The init
                  flow creates a real file structure instead of a blank canvas.
                </p>
                <div class="workflow__prompt-box">
                  <blockquote class="workflow__prompt">
                    {workflowPrompts.initialization}
                  </blockquote>
                  <button
                    class="workflow__copy"
                    type="button"
                    data-copy-prompt={workflowPrompts.initialization}
                    aria-label="Copy project initialization prompt"
                  >
                    <svg class="workflow__copy-icon workflow__copy-icon--copy" viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="8" y="8" width="11" height="11" rx="1.5"></rect>
                      <path d="M5 15V5h10"></path>
                    </svg>
                    <svg class="workflow__copy-icon workflow__copy-icon--check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m5 13 4 4L19 7"></path>
                    </svg>
                    <span class="workflow__copy-label">Copy project initialization prompt</span>
                  </button>
                </div>
              </div>
            </li>
            <li>
              <span class="workflow__num">2.</span>
              <div>
                <h3 class="workflow__label">Author with the agent</h3>
                <p>
                  Work chapter by chapter. Ask for structure, examples,
                  captions, comparison tables, and tone changes while preview
                  remains the source of truth.
                </p>
                <div class="workflow__prompt-box">
                  <blockquote class="workflow__prompt">
                    {workflowPrompts.expansion}
                  </blockquote>
                  <button
                    class="workflow__copy"
                    type="button"
                    data-copy-prompt={workflowPrompts.expansion}
                    aria-label="Copy edit and expand prompt"
                  >
                    <svg class="workflow__copy-icon workflow__copy-icon--copy" viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="8" y="8" width="11" height="11" rx="1.5"></rect>
                      <path d="M5 15V5h10"></path>
                    </svg>
                    <svg class="workflow__copy-icon workflow__copy-icon--check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m5 13 4 4L19 7"></path>
                    </svg>
                    <span class="workflow__copy-label">Copy edit and expand prompt</span>
                  </button>
                </div>
              </div>
            </li>
            <li>
              <span class="workflow__num">3.</span>
              <div>
                <h3 class="workflow__label">Export and deploy</h3>
                <p>
                  Validate the workspace, render the public reader, export the
                  PDF, and deploy only after confirming the target Pages project.
                </p>
                <div class="workflow__prompt-box">
                  <blockquote class="workflow__prompt">
                    {workflowPrompts.deploy}
                  </blockquote>
                  <button
                    class="workflow__copy"
                    type="button"
                    data-copy-prompt={workflowPrompts.deploy}
                    aria-label="Copy export and deploy prompt"
                  >
                    <svg class="workflow__copy-icon workflow__copy-icon--copy" viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="8" y="8" width="11" height="11" rx="1.5"></rect>
                      <path d="M5 15V5h10"></path>
                    </svg>
                    <svg class="workflow__copy-icon workflow__copy-icon--check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m5 13 4 4L19 7"></path>
                    </svg>
                    <span class="workflow__copy-label">Copy export and deploy prompt</span>
                  </button>
                </div>
                <p class="workflow__commands">
                  <code>openpress:validate</code>
                  <code>openpress:render</code>
                  <code>openpress:pdf</code>
                  <code>openpress:deploy</code>
                </p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="features">
      <div class="op-page">
        <div class="op-content-wide">
          <p class="op-eyebrow">Bring your own agent</p>
          <h2 class="features__title">OpenPress gives it the document rules.</h2>

          <div class="feature-grid">
            <article class="feature">
              <h3 class="feature__h">openpress-writing</h3>
              <p class="feature__p">
                Audience, narrative, captions, factual boundaries. Loads
                portable writing skills (繁中, teaching notes) per content type.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-design</h3>
              <p class="feature__p">
                Theme tokens, page surfaces, PDF-safe CSS. Tells the agent
                which CSS layer owns which decision.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-document-hierarchy</h3>
              <p class="feature__p">
                H1/H2/H3/H4 model, TOC depth, appendix placement. Stops the
                agent from making every algorithm a chapter.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-diagram-drawing</h3>
              <p class="feature__p">
                When a figure belongs vs a table vs prose. Diagram bodies stay
                semantic; explanation moves to captions.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-deploy</h3>
              <p class="feature__p">
                Public-release gate. Forces confirmation naming the target
                Cloudflare Pages project before any deploy.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">chinese-ai-writing-polish</h3>
              <p class="feature__p">
                Removes AI-like patterns from 繁體中文 professional writing.
                Auto-loaded when the document language is Chinese.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="cta">
      <div class="op-page">
        <div class="op-content cta__inner">
          <p class="op-eyebrow">No project yet?</p>
          <h2 class="cta__title">Author a document in the next minute.</h2>
          <p class="cta__lede">
            One command creates the workspace; your agent takes it from there.
          </p>
          <CodeBlock command="npx @open-press/cli init my-doc --pack editorial-monograph" />
          <p class="cta__sub op-meta">
            Available style packs: <code>editorial-monograph</code> (formal
            long-form) and <code>claude-document</code> (warm working notes).
          </p>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="op-page footer__inner">
      <div class="footer__brand">
        <p class="footer__name">open-press</p>
        <p class="op-meta">AI-first fixed-layout documents · v{version}</p>
      </div>
      <ul class="footer__links">
        <li><a href="https://open-press-story.pages.dev">Document</a></li>
        <li><a href="/showcase">Showcase</a></li>
        <li><a href="https://github.com/quan0715/open-press">GitHub</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/cli">@open-press/cli</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/core">@open-press/core</a></li>
        <li><a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">Changelog</a></li>
        <li><a href="https://github.com/quan0715/open-press/issues">Issues</a></li>
      </ul>
      <p class="footer__legal op-meta">
        © 2026 quan0715 · MIT License
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* ── Nav ────────────────────────────────────────────────────────────── */
  .nav {
    border-bottom: var(--op-border-hairline);
    background: var(--op-paper);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--op-space-5);
    gap: var(--op-space-6);
  }
  .nav__brand {
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
    text-decoration: none;
    letter-spacing: var(--op-tracking-tight);
    white-space: nowrap;
  }
  .nav__links {
    display: flex;
    gap: var(--op-space-6);
    font-size: var(--op-text-sm);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav__links a {
    color: var(--op-ink);
    text-decoration: none;
  }
  .nav__links a:hover {
    color: var(--op-accent);
  }

  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    padding-block: var(--op-space-32) var(--op-space-16);
  }
  .hero__title {
    margin-top: var(--op-space-4);
  }
  .hero__title-accent {
    color: var(--op-accent);
    font-style: italic;
    font-family: var(--op-font-display);
  }
  .hero__kicker {
    margin-top: var(--op-space-6);
    font-size: var(--op-text-lg);
    line-height: var(--op-leading-body);
    color: var(--op-subdued-strong);
    max-width: 38rem;
  }
  .hero__actions {
    margin-top: var(--op-space-10);
    display: grid;
    gap: var(--op-space-4);
    max-width: 42rem;
  }
  .hero__command {
    min-width: 0;
  }
  .hero__example {
    display: inline-flex;
    justify-self: start;
    align-items: center;
    min-height: 2.75rem;
    padding-inline: var(--op-space-4);
    border: var(--op-border-hairline-strong);
    color: var(--op-ink);
    background: var(--op-paper-soft);
    font-weight: var(--op-weight-medium);
    text-decoration: none;
    transition: border-color var(--op-duration-fast) var(--op-ease),
      color var(--op-duration-fast) var(--op-ease);
  }
  .hero__example:hover {
    border-color: var(--op-accent);
    color: var(--op-accent);
    text-decoration: none;
  }
  .hero__hint {
    margin-top: var(--op-space-3);
    max-width: 38rem;
  }
  .hero__hint code {
    background: var(--op-paper-soft);
    border: 1px solid var(--op-hairline);
    padding: 0 var(--op-space-1);
    border-radius: var(--op-radius-sm);
  }
  .hero__signals {
    list-style: none;
    padding: 0;
    margin: var(--op-space-8) 0 0;
    display: grid;
    gap: var(--op-space-3);
    max-width: 42rem;
  }
  .hero__signals li {
    border-top: var(--op-border-hairline);
    padding-top: var(--op-space-3);
    color: var(--op-ink);
    font-size: var(--op-text-sm);
  }
  .hero__artifact {
    margin-top: var(--op-space-8);
    display: grid;
    grid-template-columns: minmax(15rem, 0.92fr) minmax(15rem, 1fr);
    gap: var(--op-space-6);
    align-items: stretch;
    max-width: 46rem;
  }
  .hero__source-panel,
  .hero__render-panel {
    min-height: 20rem;
    border: var(--op-border-hairline-strong);
    background: var(--op-paper-soft);
    padding: var(--op-space-5);
    display: grid;
    align-content: start;
    gap: var(--op-space-4);
  }
  .hero__artifact-label {
    margin: 0;
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
    color: var(--op-subdued);
  }
  .hero__tree {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--op-space-2);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    color: var(--op-ink);
  }
  .hero__tree li {
    display: block;
  }
  .hero__tree span {
    display: inline-flex;
    max-width: 100%;
    min-height: 1.5rem;
    align-items: center;
    border: 1px solid transparent;
    padding-inline: var(--op-space-2);
  }
  .hero__tree-child {
    padding-left: var(--op-space-4);
  }
  .hero__tree-leaf {
    padding-left: var(--op-space-8);
  }
  .hero__tree-leaf--active span {
    border-color: var(--op-accent);
    background: var(--op-accent-soft);
    color: var(--op-ink-strong);
  }
  .hero__source-card {
    display: grid;
    gap: var(--op-space-2);
    border-left: 2px solid var(--op-hairline-strong);
    padding-left: var(--op-space-3);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    color: var(--op-subdued-strong);
  }
  .hero__source-card--tokens {
    border-color: var(--op-accent);
  }
  .hero__source-card--mdx {
    background: var(--op-surface);
    border: var(--op-border-hairline);
    padding: var(--op-space-3);
  }
  .hero__render-panel {
    background:
      linear-gradient(var(--op-hairline) 1px, transparent 1px) 0 4.15rem / 100% 3rem,
      var(--op-paper-soft);
  }
  .hero__render-page {
    position: relative;
    min-height: 16.25rem;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
    padding: var(--op-space-5);
    overflow: hidden;
  }
  .hero__render-rule,
  .hero__render-title,
  .hero__render-accent,
  .hero__render-line,
  .hero__render-callout,
  .hero__render-footer {
    position: absolute;
    display: block;
  }
  .hero__render-rule {
    left: var(--op-space-5);
    right: var(--op-space-5);
    top: var(--op-space-5);
    height: 1px;
    background: var(--op-ink);
  }
  .hero__render-title {
    left: var(--op-space-5);
    top: 4rem;
    font-family: var(--op-font-display);
    font-size: var(--op-text-2xl);
    color: var(--op-ink-strong);
  }
  .hero__render-accent {
    left: var(--op-space-5);
    top: 7.1rem;
    width: 4.75rem;
    height: 0.45rem;
    background: var(--op-accent);
  }
  .hero__render-line {
    left: var(--op-space-5);
    top: 9rem;
    width: 62%;
    height: 1px;
    background: var(--op-hairline-strong);
  }
  .hero__render-line--long {
    top: 8.1rem;
    width: 78%;
  }
  .hero__render-callout {
    left: var(--op-space-5);
    right: var(--op-space-5);
    bottom: 3.6rem;
    height: 2.35rem;
    border-left: 2px solid var(--op-accent);
    background: var(--op-accent-soft);
  }
  .hero__render-footer {
    left: var(--op-space-5);
    right: var(--op-space-5);
    bottom: var(--op-space-5);
    height: 1px;
    background: var(--op-hairline-strong);
  }

  @media (max-width: 720px) {
    .nav__inner {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--op-space-4);
    }
    .nav__links {
      justify-content: flex-start;
      gap: var(--op-space-4);
    }
    .hero {
      padding-block: var(--op-space-16) var(--op-space-10);
    }
    .hero__actions,
    .hero__signals {
      max-width: none;
    }
    .hero__artifact {
      grid-template-columns: 1fr;
      gap: var(--op-space-4);
      max-width: none;
    }
    .hero__source-panel,
    .hero__render-panel {
      min-height: auto;
      padding: var(--op-space-4);
      gap: var(--op-space-4);
    }
    .hero__render-page {
      min-height: 13.5rem;
    }
  }

  /* ── Product features ───────────────────────────────────────────────── */
  .product-features {
    padding-block: var(--op-space-16);
  }
  .product-features__title {
    margin-top: var(--op-space-4);
    margin-bottom: var(--op-space-12);
    max-width: 42rem;
  }
  .product-feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--op-space-8);
  }
  .product-feature {
    border-top: var(--op-border-hairline-strong);
    padding-top: var(--op-space-5);
  }
  .product-feature__visual {
    height: 7.5rem;
    margin-bottom: var(--op-space-6);
    border: var(--op-border-hairline);
    background: var(--op-paper-soft);
    overflow: hidden;
    display: grid;
    align-content: start;
    gap: var(--op-space-2);
    padding: var(--op-space-4);
  }
  .product-feature__visual span {
    display: block;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
    min-height: 1.25rem;
