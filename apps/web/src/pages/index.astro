---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";

const version = "0.3.0";
const workflowPrompts = {
  initialization:
    "Using OpenPress, help me set up a new document workspace for a public user guide. Ask me for missing title, audience, and style pack choices, then initialize the project.",
  expansion:
    "Use OpenPress writing and hierarchy skills. Expand chapter 1 into a reader-friendly guide, keep confirmed facts unchanged, and mark missing details as [TODO].",
  deploy:
    "Use OpenPress deploy flow. Run validation, render the web reader, export the PDF, and prepare a Cloudflare Pages deploy dry-run before publishing.",
};
---

<Layout>
  <header class="nav">
    <div class="op-page nav__inner">
      <a class="nav__brand" href="/" aria-label="open-press">
        open-press
      </a>
      <nav class="nav__links">
        <a href="https://open-press-story.pages.dev">Document</a>
        <a href="/showcase">Showcase</a>
        <a href="https://github.com/quan0715/open-press">GitHub</a>
        <a href="https://www.npmjs.com/package/@open-press/cli">npm</a>
        <a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">v{version}</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">OpenPress · Open source · MIT · v{version}</p>
          <h1 class="hero__title">
            OpenPress is an AI-first
            <span class="hero__title-accent">document framework</span>.
          </h1>

          <p class="hero__kicker">
            Build fixed-layout A4 documents with your agent, then preview,
            export to PDF, and deploy as a public web reader.
          </p>

          <div class="hero__actions">
            <div class="hero__command">
              <CodeBlock command="npx skills add quan0715/open-press" />
            </div>
            <a class="hero__example" href="https://open-press-story.pages.dev">
              View live example
            </a>
          </div>

          <figure class="hero__artifact">
            <img
              class="hero__artifact-cover"
              src="/openpress-cover-preview.svg"
              width="1190"
              height="1684"
              alt="OpenPress document cover preview"
              loading="eager"
              decoding="async"
            />
            <div class="hero__artifact-reader" aria-hidden="true">
              <div class="hero__reader-bar">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="hero__reader-spread">
                <span class="hero__reader-page hero__reader-page--cover"></span>
                <span class="hero__reader-page"></span>
                <span class="hero__reader-page hero__reader-page--accent"></span>
              </div>
              <div class="hero__reader-lines">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
          </figure>

          <p class="hero__hint op-meta">
            Click to copy · skills install under <code>.agents/skills/</code>,
            auto-detected by Claude Code, Cursor, Codex, Gemini CLI, Cline,
            Continue, and 50+ other AI agents.
          </p>

          <ul class="hero__signals" aria-label="OpenPress product highlights">
            <li>Write with Claude Code, Cursor, Codex</li>
            <li>Fixed A4 pages, PDF export, web reader</li>
            <li>Deployable workspaces for serious documents</li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="product-features">
      <div class="op-page">
        <div class="op-content-wide">
          <p class="op-eyebrow">Features</p>
          <h2 class="product-features__title">
            A document system built for AI-assisted publishing.
          </h2>

          <div class="product-feature-grid">
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--agent" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <p class="product-feature__kicker">Agent-native</p>
              <h3>Start from intent, not blank pages.</h3>
              <p>
                OpenPress gives your agent skills, prompts, and document
                conventions so it can ask the right setup questions before
                writing.
              </p>
            </article>
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--layout" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <p class="product-feature__kicker">Fixed layout</p>
              <h3>A4 pages stay inspectable.</h3>
              <p>
                Chapters, covers, figures, and tables live in a real preview
                loop, so layout problems show up before the final PDF.
              </p>
            </article>
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--output" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <p class="product-feature__kicker">Portable output</p>
              <h3>One source, web reader and PDF.</h3>
              <p>
                Publish a public reader, archive a PDF, or keep iterating in
                the same workspace without rebuilding the document by hand.
              </p>
            </article>
            <article class="product-feature">
              <div class="product-feature__visual product-feature__visual--style" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <p class="product-feature__kicker">Style packs</p>
              <h3>Design stays reusable.</h3>
              <p>
                Theme tokens and starter documents make visual direction
                repeatable across user guides, notes, proposals, and books.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="workflow">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">Try it · copy these into your AI agent</p>
          <h2 class="workflow__title">
            Generate a serious document in three steps.
          </h2>
          <p class="workflow__lede">
            Paste the prompt for your current stage. OpenPress keeps the agent
            focused on document structure, page-safe design, and publishable
            output.
          </p>

          <ol class="workflow__steps">
            <li>
              <span class="workflow__num">1.</span>
              <div>
                <h3 class="workflow__label">Project initialization</h3>
                <p>
                  Start a workspace from a style pack after the agent
                  understands your audience, language, document type, and
                  title.
                </p>
                <div class="workflow__prompt-box">
                  <blockquote class="workflow__prompt">
                    {workflowPrompts.initialization}
                  </blockquote>
                  <button
                    class="workflow__copy"
                    type="button"
                    data-copy-prompt={workflowPrompts.initialization}
                    aria-label="Copy project initialization prompt"
                  >
                    <svg class="workflow__copy-icon workflow__copy-icon--copy" viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="8" y="8" width="11" height="11" rx="1.5"></rect>
                      <path d="M5 15V5h10"></path>
                    </svg>
                    <svg class="workflow__copy-icon workflow__copy-icon--check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m5 13 4 4L19 7"></path>
                    </svg>
                    <span class="workflow__copy-label">Copy project initialization prompt</span>
                  </button>
                </div>
              </div>
            </li>
            <li>
              <span class="workflow__num">2.</span>
              <div>
                <h3 class="workflow__label">Edit and expand</h3>
                <p>
                  Work chapter by chapter. Expand outlines, adjust tone, add
                  comparison tables, and refine structure while the document
                  remains visible.
                </p>
                <div class="workflow__prompt-box">
                  <blockquote class="workflow__prompt">
                    {workflowPrompts.expansion}
                  </blockquote>
                  <button
                    class="workflow__copy"
                    type="button"
                    data-copy-prompt={workflowPrompts.expansion}
                    aria-label="Copy edit and expand prompt"
                  >
                    <svg class="workflow__copy-icon workflow__copy-icon--copy" viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="8" y="8" width="11" height="11" rx="1.5"></rect>
                      <path d="M5 15V5h10"></path>
                    </svg>
                    <svg class="workflow__copy-icon workflow__copy-icon--check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m5 13 4 4L19 7"></path>
                    </svg>
                    <span class="workflow__copy-label">Copy edit and expand prompt</span>
                  </button>
                </div>
              </div>
            </li>
            <li>
              <span class="workflow__num">3.</span>
              <div>
                <h3 class="workflow__label">Export and deploy</h3>
                <p>
                  Validate the workspace, render the public reader, export the
                  PDF, and deploy only after confirming the target Pages project.
                </p>
                <div class="workflow__prompt-box">
                  <blockquote class="workflow__prompt">
                    {workflowPrompts.deploy}
                  </blockquote>
                  <button
                    class="workflow__copy"
                    type="button"
                    data-copy-prompt={workflowPrompts.deploy}
                    aria-label="Copy export and deploy prompt"
                  >
                    <svg class="workflow__copy-icon workflow__copy-icon--copy" viewBox="0 0 24 24" aria-hidden="true">
                      <rect x="8" y="8" width="11" height="11" rx="1.5"></rect>
                      <path d="M5 15V5h10"></path>
                    </svg>
                    <svg class="workflow__copy-icon workflow__copy-icon--check" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m5 13 4 4L19 7"></path>
                    </svg>
                    <span class="workflow__copy-label">Copy export and deploy prompt</span>
                  </button>
                </div>
                <p class="workflow__commands">
                  <code>openpress:validate</code>
                  <code>openpress:render</code>
                  <code>openpress:pdf</code>
                  <code>openpress:deploy</code>
                </p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="features">
      <div class="op-page">
        <div class="op-content-wide">
          <p class="op-eyebrow">What your agent gets</p>
          <h2 class="features__title">12 SKILL files. Every layer of writing a serious document.</h2>

          <div class="feature-grid">
            <article class="feature">
              <h3 class="feature__h">openpress-writing</h3>
              <p class="feature__p">
                Audience, narrative, captions, factual boundaries. Loads
                portable writing skills (繁中, teaching notes) per content type.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-design</h3>
              <p class="feature__p">
                Theme tokens, page surfaces, PDF-safe CSS. Tells the agent
                which CSS layer owns which decision.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-document-hierarchy</h3>
              <p class="feature__p">
                H1/H2/H3/H4 model, TOC depth, appendix placement. Stops the
                agent from making every algorithm a chapter.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-diagram-drawing</h3>
              <p class="feature__p">
                When a figure belongs vs a table vs prose. Diagram bodies stay
                semantic; explanation moves to captions.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-deploy</h3>
              <p class="feature__p">
                Public-release gate. Forces confirmation naming the target
                Cloudflare Pages project before any deploy.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">chinese-ai-writing-polish</h3>
              <p class="feature__p">
                Removes AI-like patterns from Traditional Chinese professional
                writing. Auto-loaded when the document language is Chinese.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <section class="cta">
      <div class="op-page">
        <div class="op-content cta__inner">
          <p class="op-eyebrow">No project yet?</p>
          <h2 class="cta__title">Scaffold a fresh workspace.</h2>
          <p class="cta__lede">
            One command. Skills, framework, starter document, all wired up.
          </p>
          <CodeBlock command="npx @open-press/cli init my-doc --pack editorial-monograph" />
          <p class="cta__sub op-meta">
            Available style packs: <code>editorial-monograph</code> (formal
            long-form) and <code>claude-document</code> (warm working notes).
          </p>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="op-page footer__inner">
      <div class="footer__brand">
        <p class="footer__name">open-press</p>
        <p class="op-meta">AI-first fixed-layout documents · v{version}</p>
      </div>
      <ul class="footer__links">
        <li><a href="https://open-press-story.pages.dev">Document</a></li>
        <li><a href="/showcase">Showcase</a></li>
        <li><a href="https://github.com/quan0715/open-press">GitHub</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/cli">@open-press/cli</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/core">@open-press/core</a></li>
        <li><a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">Changelog</a></li>
        <li><a href="https://github.com/quan0715/open-press/issues">Issues</a></li>
      </ul>
      <p class="footer__legal op-meta">
        © 2026 quan0715 · MIT License
      </p>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    border-bottom: var(--op-border-hairline);
    background: var(--op-paper);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--op-space-5);
    gap: var(--op-space-6);
  }
  .nav__brand {
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
    text-decoration: none;
    letter-spacing: var(--op-tracking-tight);
    white-space: nowrap;
  }
  .nav__links {
    display: flex;
    gap: var(--op-space-6);
    font-size: var(--op-text-sm);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav__links a {
    color: var(--op-ink);
    text-decoration: none;
  }
  .nav__links a:hover {
    color: var(--op-accent);
  }

  .hero {
    padding-block: var(--op-space-24) var(--op-space-16);
  }
  .hero__title {
    margin-top: var(--op-space-4);
  }
  .hero__title-accent {
    color: var(--op-accent);
    font-style: italic;
    font-family: var(--op-font-display);
  }
  .hero__kicker {
    margin-top: var(--op-space-6);
    font-size: var(--op-text-lg);
    line-height: var(--op-leading-body);
    color: var(--op-subdued-strong);
    max-width: 38rem;
  }
  .hero__actions {
    margin-top: var(--op-space-10);
    display: grid;
    gap: var(--op-space-4);
    max-width: 42rem;
  }
  .hero__command {
    min-width: 0;
  }
  .hero__example {
    display: inline-flex;
    justify-self: start;
    align-items: center;
    min-height: 2.75rem;
    padding-inline: var(--op-space-4);
    border: var(--op-border-hairline-strong);
    color: var(--op-ink);
    background: var(--op-paper-soft);
    font-weight: var(--op-weight-medium);
    text-decoration: none;
    transition: border-color var(--op-duration-fast) var(--op-ease),
      color var(--op-duration-fast) var(--op-ease);
  }
  .hero__example:hover {
    border-color: var(--op-accent);
    color: var(--op-accent);
    text-decoration: none;
  }
  .hero__artifact {
    margin-top: var(--op-space-8);
    display: grid;
    grid-template-columns: minmax(8rem, 0.38fr) 1fr;
    gap: var(--op-space-6);
    align-items: stretch;
    max-width: 42rem;
  }
  .hero__artifact-cover {
    width: 100%;
    aspect-ratio: 0.707;
    object-fit: cover;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
  }
  .hero__artifact-reader {
    min-height: 12rem;
    border: var(--op-border-hairline-strong);
    background:
      linear-gradient(var(--op-hairline) 1px, transparent 1px) 0 4.15rem / 100% 3rem,
      var(--op-paper-soft);
    padding: var(--op-space-5);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--op-space-5);
  }
  .hero__reader-bar {
    display: flex;
    gap: var(--op-space-2);
  }
  .hero__reader-bar span {
    width: 0.55rem;
    height: 0.55rem;
    border: 1px solid var(--op-hairline-strong);
    border-radius: 999px;
  }
  .hero__reader-spread {
    display: grid;
    grid-template-columns: 0.8fr 1fr 0.8fr;
    gap: var(--op-space-4);
    align-items: end;
  }
  .hero__reader-page {
    min-height: 8rem;
    border: var(--op-border-hairline);
    background:
      linear-gradient(var(--op-ink) 0 0) 18% 26% / 48% 1px no-repeat,
      linear-gradient(var(--op-hairline-strong) 0 0) 18% 42% / 64% 1px no-repeat,
      linear-gradient(var(--op-hairline-strong) 0 0) 18% 54% / 52% 1px no-repeat,
      var(--op-surface);
  }
  .hero__reader-page--cover {
    min-height: 9.5rem;
    background:
      linear-gradient(var(--op-accent) 0 0) 20% 72% / 44% 0.45rem no-repeat,
      linear-gradient(var(--op-hairline-strong) 0 0) 20% 82% / 62% 1px no-repeat,
      var(--op-accent-soft);
  }
  .hero__reader-page--accent {
    background:
      linear-gradient(var(--op-accent) 0 0) 22% 32% / 32% 0.45rem no-repeat,
      linear-gradient(var(--op-hairline-strong) 0 0) 22% 48% / 56% 1px no-repeat,
      linear-gradient(var(--op-hairline-strong) 0 0) 22% 60% / 48% 1px no-repeat,
      var(--op-surface);
  }
  .hero__reader-lines {
    display: grid;
    gap: var(--op-space-2);
  }
  .hero__reader-lines span {
    height: 1px;
    background: var(--op-hairline-strong);
  }
  .hero__reader-lines span:nth-child(2) {
    width: 74%;
  }
  .hero__reader-lines span:nth-child(3) {
    width: 48%;
  }
  .hero__hint {
    margin-top: var(--op-space-3);
    max-width: 38rem;
  }
  .hero__hint code {
    background: var(--op-paper-soft);
    border: 1px solid var(--op-hairline);
    padding: 0 var(--op-space-1);
    border-radius: var(--op-radius-sm);
  }
  .hero__signals {
    list-style: none;
    padding: 0;
    margin: var(--op-space-8) 0 0;
    display: grid;
    gap: var(--op-space-3);
    max-width: 42rem;
  }
  .hero__signals li {
    border-top: var(--op-border-hairline);
    padding-top: var(--op-space-3);
    color: var(--op-ink);
    font-size: var(--op-text-sm);
  }

  .product-features,
  .workflow,
  .features,
  .cta {
    padding-block: var(--op-space-16);
  }
  .product-features__title,
  .features__title {
    margin-top: var(--op-space-4);
    margin-bottom: var(--op-space-12);
    max-width: 42rem;
  }
  .product-feature-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--op-space-8);
  }
  .product-feature {
    border-top: var(--op-border-hairline-strong);
    padding-top: var(--op-space-5);
  }
  .product-feature__visual {
    position: relative;
    height: 7.5rem;
    margin-bottom: var(--op-space-6);
    border: var(--op-border-hairline);
    background: var(--op-paper-soft);
    overflow: hidden;
  }
  .product-feature__visual span {
    position: absolute;
    display: block;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
  }
  .product-feature__visual--agent span:nth-child(1) {
    width: 3.5rem;
    height: 4.8rem;
    left: 1.4rem;
    top: 1.2rem;
  }
  .product-feature__visual--agent span:nth-child(2) {
    width: 3.2rem;
    height: 1.8rem;
    right: 1.4rem;
    top: 1.4rem;
    background: var(--op-accent-soft);
  }
  .product-feature__visual--agent span:nth-child(3) {
    width: 5.2rem;
    height: 1px;
    left: 5.4rem;
    top: 3.2rem;
    border: none;
    background: var(--op-accent);
  }
  .product-feature__visual--layout span:nth-child(1) {
    width: 4.1rem;
    height: 5.8rem;
    left: 1.6rem;
    top: 0.9rem;
  }
  .product-feature__visual--layout span:nth-child(2) {
    width: 1.8rem;
    height: 5.8rem;
    left: 6.2rem;
    top: 0.9rem;
    background: repeating-linear-gradient(
      to bottom,
      var(--op-hairline-strong) 0,
      var(--op-hairline-strong) 1px,
      transparent 1px,
      transparent 0.72rem
    ),
    var(--op-surface);
  }
  .product-feature__visual--layout span:nth-child(3) {
    width: 2.7rem;
    height: 2rem;
    right: 1.4rem;
    bottom: 1rem;
    background: var(--op-accent-soft);
  }
  .product-feature__visual--output span:nth-child(1) {
    width: 3.6rem;
    height: 4.8rem;
    left: 1.3rem;
    top: 1.3rem;
  }
  .product-feature__visual--output span:nth-child(2) {
    width: 3.6rem;
    height: 4.8rem;
    right: 1.3rem;
    top: 1.3rem;
  }
  .product-feature__visual--output span:nth-child(3) {
    width: 4.2rem;
    height: 1px;
    left: 50%;
    top: 3.7rem;
    transform: translateX(-50%);
    border: none;
    background: var(--op-accent);
  }
  .product-feature__visual--style span:nth-child(1) {
    width: 3rem;
    height: 3rem;
    left: 1.4rem;
    top: 1.4rem;
    background: var(--op-accent);
  }
  .product-feature__visual--style span:nth-child(2) {
    width: 3rem;
    height: 3rem;
    left: 5.2rem;
    top: 1.4rem;
    background: var(--op-accent-soft);
  }
  .product-feature__visual--style span:nth-child(3) {
    width: 6.8rem;
    height: 1px;
    left: 1.4rem;
    bottom: 1.5rem;
    border: none;
    background: var(--op-hairline-strong);
  }
  .product-feature__kicker {
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
    color: var(--op-accent);
    margin-bottom: var(--op-space-4);
  }
  .product-feature h3 {
    font-size: var(--op-text-xl);
    margin-bottom: var(--op-space-3);
  }
  .product-feature p:last-child {
    color: var(--op-subdued-strong);
  }

  .workflow__title {
