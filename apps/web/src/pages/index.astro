---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";

const version = "0.3.0";
---

<Layout>
  <header class="nav">
    <div class="op-page nav__inner">
      <a class="nav__brand" href="/" aria-label="open-press">
        open-press
      </a>
      <nav class="nav__links">
        <a href="https://github.com/quan0715/open-press">GitHub</a>
        <a href="https://www.npmjs.com/package/@open-press/cli">npm</a>
        <a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">v{version}</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- ── Hero — SKILL install is the headline ────────────────────────── -->
    <section class="hero">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">Open source · MIT · v{version}</p>
          <h1 class="hero__title">
            Now Claude Code, Cursor &amp; Codex can write
            <span class="hero__title-accent">serious documents</span>.
          </h1>

          <p class="hero__kicker">
            Install the open-press skills into any project. Your AI agent learns
            how to write fixed-A4 proposals, whitepapers, theses — with PDF
            export, web reader, and deploy gates already wired up.
          </p>

          <div class="hero__command">
            <CodeBlock command="npx skills add quan0715/open-press" />
          </div>

          <p class="hero__hint op-meta">
            Click to copy · skills install under <code>.agents/skills/</code>,
            auto-detected by Claude Code, Cursor, Codex, Gemini CLI, Cline,
            Continue, and 50+ other AI agents.
          </p>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <!-- ── Prompts to copy ─────────────────────────────────────────────── -->
    <section class="prompts">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">Try it · copy these into your AI agent</p>
          <h2 class="prompts__title">Talk to your agent like a writing partner.</h2>
          <p class="prompts__lede">
            After installing skills, open your folder in any AI tool and try
            one of these prompts.
          </p>

          <div class="prompt-stack">
            <article class="prompt">
              <p class="prompt__label">Cold start — start a new project</p>
              <blockquote class="prompt__text">
                Using <code>openpress-init</code>, help me set up a new
                workspace for a Series A investor proposal. Ask me about
                audience, language, and title, then run the init for me.
              </blockquote>
            </article>

            <article class="prompt">
              <p class="prompt__label">Turn existing material into a document</p>
              <blockquote class="prompt__text">
                Take this PDF / these meeting notes / this repo README and
                turn them into chapter 1 of a whitepaper. Preserve confirmed
                facts. Mark missing numbers as <code>[TODO]</code>.
              </blockquote>
            </article>

            <article class="prompt">
              <p class="prompt__label">Iterate on structure</p>
              <blockquote class="prompt__text">
                Use <code>openpress-document-hierarchy</code> and
                <code>openpress-writing</code>. Re-bucket the current chapters
                into a public TOC and a deeper outline; H4 algorithms shouldn't
                show in the formal TOC.
              </blockquote>
            </article>

            <article class="prompt">
              <p class="prompt__label">Visual tweak</p>
              <blockquote class="prompt__text">
                Use <code>openpress-design</code>. Switch the accent color to
                deep green, keep hairlines, and re-check PDF-safe contrast on
                the cover and TOC.
              </blockquote>
            </article>

            <article class="prompt">
              <p class="prompt__label">Ship it</p>
              <blockquote class="prompt__text">
                Use <code>openpress-deploy</code>. Run a dry-run for
                Cloudflare Pages, then wait — don't publish until I confirm
                the project name.
              </blockquote>
            </article>
          </div>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <!-- ── What the agent knows ────────────────────────────────────────── -->
    <section class="features">
      <div class="op-page">
        <div class="op-content-wide">
          <p class="op-eyebrow">What your agent gets</p>
          <h2 class="features__title">12 SKILL files. Every layer of writing a serious document.</h2>

          <div class="feature-grid">
            <article class="feature">
              <h3 class="feature__h">openpress-writing</h3>
              <p class="feature__p">
                Audience, narrative, captions, factual boundaries. Loads
                portable writing skills (繁中, teaching notes) per content type.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-design</h3>
              <p class="feature__p">
                Theme tokens, page surfaces, PDF-safe CSS. Tells the agent
                which CSS layer owns which decision.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-document-hierarchy</h3>
              <p class="feature__p">
                H1/H2/H3/H4 model, TOC depth, appendix placement. Stops the
                agent from making every algorithm a chapter.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-diagram-drawing</h3>
              <p class="feature__p">
                When a figure belongs vs a table vs prose. Diagram bodies stay
                semantic; explanation moves to captions.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">openpress-deploy</h3>
              <p class="feature__p">
                Public-release gate. Forces confirmation naming the target
                Cloudflare Pages project before any deploy.
              </p>
            </article>
            <article class="feature">
              <h3 class="feature__h">chinese-ai-writing-polish</h3>
              <p class="feature__p">
                Removes AI-like patterns from 繁體中文 professional writing.
                Auto-loaded when the document language is Chinese.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <!-- ── Or scaffold fresh ───────────────────────────────────────────── -->
    <section class="cta">
      <div class="op-page">
        <div class="op-content cta__inner">
          <p class="op-eyebrow">No project yet?</p>
          <h2 class="cta__title">Scaffold a fresh workspace.</h2>
          <p class="cta__lede">
            One command. Skills, framework, starter document, all wired up.
          </p>
          <CodeBlock command="npx @open-press/cli init my-doc --pack editorial-monograph" />
          <p class="cta__sub op-meta">
            Available style packs: <code>editorial-monograph</code> (formal
            long-form) and <code>claude-document</code> (warm working notes).
          </p>
        </div>
      </div>
    </section>

    <hr class="op-hairline" />

    <!-- ── How it works (compact) ──────────────────────────────────────── -->
    <section class="how">
      <div class="op-page">
        <div class="op-content">
          <p class="op-eyebrow">How it works</p>
          <h2>SKILL files at the agent layer. Real code at the engine layer.</h2>

          <ol class="how__steps">
            <li>
              <span class="how__num">1.</span>
              <div>
                <p>
                  <code>npx skills add quan0715/open-press</code> installs the
                  framework skill files into <code>.agents/skills/</code> (and
                  symlinks to <code>.claude/skills/</code>, etc., depending on
                  the tools you have). 13 skills total — system, writing,
                  design, deploy, plus portable Chinese / teaching skills.
                </p>
              </div>
            </li>
            <li>
              <span class="how__num">2.</span>
              <div>
                <p>
                  Open the folder in your AI tool. Skills are auto-discovered —
                  zero extra setup for Claude Code, Cursor, Codex, Gemini CLI,
                  Cline, Continue, Warp, and 50+ others.
                </p>
              </div>
            </li>
            <li>
              <span class="how__num">3.</span>
              <div>
                <p>
                  Tell the agent what you want. SKILL files supply routing,
                  voice rules, structural conventions, design tokens, deploy
                  gates. <code>@open-press/core</code> supplies the runtime
                  React components and CLI; <code>@open-press/cli</code>
                  scaffolds new workspaces.
                </p>
              </div>
            </li>
            <li>
              <span class="how__num">4.</span>
              <div>
                <p>
                  Update later: <code>npx skills upgrade</code> for skills,
                  <code>npm update @open-press/core</code> for the runtime.
                  Both respect your hand-written customizations.
                </p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="op-page footer__inner">
      <div class="footer__brand">
        <p class="footer__name">open-press</p>
        <p class="op-meta">AI-first fixed-layout documents · v{version}</p>
      </div>
      <ul class="footer__links">
        <li><a href="https://github.com/quan0715/open-press">GitHub</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/cli">@open-press/cli</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/core">@open-press/core</a></li>
        <li><a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">Changelog</a></li>
        <li><a href="https://github.com/quan0715/open-press/issues">Issues</a></li>
      </ul>
      <p class="footer__legal op-meta">
        © 2026 quan0715 · MIT License
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* ── Nav ────────────────────────────────────────────────────────────── */
  .nav {
    border-bottom: var(--op-border-hairline);
    background: var(--op-paper);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--op-space-5);
  }
  .nav__brand {
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
    text-decoration: none;
    letter-spacing: var(--op-tracking-tight);
  }
  .nav__links {
    display: flex;
    gap: var(--op-space-6);
    font-size: var(--op-text-sm);
  }
  .nav__links a {
    color: var(--op-ink);
    text-decoration: none;
  }
  .nav__links a:hover {
    color: var(--op-accent);
  }

  /* ── Hero ───────────────────────────────────────────────────────────── */
  .hero {
    padding-block: var(--op-space-32) var(--op-space-16);
  }
  .hero__title {
    margin-top: var(--op-space-4);
  }
  .hero__title-accent {
    color: var(--op-accent);
    font-style: italic;
    font-family: var(--op-font-display);
  }
  .hero__kicker {
    margin-top: var(--op-space-6);
    font-size: var(--op-text-lg);
    line-height: var(--op-leading-body);
    color: var(--op-subdued-strong);
    max-width: 38rem;
  }
  .hero__command {
    margin-top: var(--op-space-10);
  }
  .hero__hint {
    margin-top: var(--op-space-3);
    max-width: 38rem;
  }
  .hero__hint code {
    background: var(--op-paper-soft);
    border: 1px solid var(--op-hairline);
    padding: 0 var(--op-space-1);
    border-radius: var(--op-radius-sm);
  }

  @media (max-width: 720px) {
    .hero {
      padding-block: var(--op-space-16) var(--op-space-10);
    }
  }

  /* ── Prompts ────────────────────────────────────────────────────────── */
  .prompts {
    padding-block: var(--op-space-16);
  }
  .prompts__title {
    margin-top: var(--op-space-4);
  }
  .prompts__lede {
    margin-top: var(--op-space-4);
    color: var(--op-subdued-strong);
    max-width: 38rem;
    margin-bottom: var(--op-space-10);
  }
  .prompt-stack {
    display: flex;
    flex-direction: column;
    gap: var(--op-space-8);
  }
  .prompt {
    border-left: 2px solid var(--op-hairline-strong);
    padding-left: var(--op-space-6);
  }
  .prompt__label {
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
    color: var(--op-subdued);
    margin-bottom: var(--op-space-3);
  }
  .prompt__text {
    margin: 0;
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    line-height: 1.4;
    color: var(--op-ink-strong);
    font-style: italic;
  }
  .prompt__text code {
    background: var(--op-paper-soft);
    border: 1px solid var(--op-hairline);
    padding: 0 var(--op-space-1);
    border-radius: var(--op-radius-sm);
    font-style: normal;
    font-size: 0.85em;
    font-family: var(--op-font-mono);
    color: var(--op-accent);
  }

  /* ── Features ───────────────────────────────────────────────────────── */
  .features {
    padding-block: var(--op-space-16);
  }
  .features__title {
    margin-top: var(--op-space-4);
    margin-bottom: var(--op-space-12);
    max-width: 36rem;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--op-space-10) var(--op-space-12);
  }
  .feature {
    padding-block: var(--op-space-2);
  }
  .feature__h {
    font-size: var(--op-text-lg);
    margin-bottom: var(--op-space-3);
    font-family: var(--op-font-mono);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
    letter-spacing: var(--op-tracking-mono);
  }
  .feature__p {
    color: var(--op-ink);
    font-size: var(--op-text-base);
  }

  /* ── CTA (scaffold fresh) ───────────────────────────────────────────── */
  .cta {
    padding-block: var(--op-space-16);
  }
  .cta__inner {
    text-align: left;
  }
  .cta__title {
    margin-top: var(--op-space-4);
    margin-bottom: var(--op-space-4);
  }
  .cta__lede {
    margin-bottom: var(--op-space-8);
    font-size: var(--op-text-lg);
    color: var(--op-subdued-strong);
  }
  .cta__sub {
    margin-top: var(--op-space-4);
    max-width: 38rem;
  }
  .cta__sub code {
    background: var(--op-paper-soft);
    border: 1px solid var(--op-hairline);
    padding: 0 var(--op-space-1);
    border-radius: var(--op-radius-sm);
  }

  /* ── How it works ───────────────────────────────────────────────────── */
  .how {
    padding-block: var(--op-space-16) var(--op-space-24);
  }
  .how h2 {
    margin-top: var(--op-space-4);
    margin-bottom: var(--op-space-12);
  }
  .how__steps {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--op-space-8);
  }
  .how__steps li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--op-space-5);
    padding-bottom: var(--op-space-8);
    border-bottom: var(--op-border-hairline);
  }
  .how__steps li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .how__num {
    font-family: var(--op-font-display);
    font-size: var(--op-text-2xl);
    color: var(--op-accent);
    font-weight: var(--op-weight-medium);
  }
  .how code {
    background: var(--op-paper-soft);
    border: 1px solid var(--op-hairline);
    padding: 0 var(--op-space-1);
    border-radius: var(--op-radius-sm);
  }

  /* ── Footer ─────────────────────────────────────────────────────────── */
  .footer {
    border-top: var(--op-border-hairline);
    padding-block: var(--op-space-12);
    background: var(--op-paper-soft);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: var(--op-space-8);
    align-items: center;
  }
  .footer__brand .footer__name {
    font-family: var(--op-font-display);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
  }
  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--op-space-6);
    justify-content: center;
    flex-wrap: wrap;
    font-size: var(--op-text-sm);
  }
  .footer__links a {
    color: var(--op-ink);
    text-decoration: none;
  }
  .footer__links a:hover {
    color: var(--op-accent);
    text-decoration: underline;
  }
  .footer__legal {
    text-align: right;
  }

  @media (max-width: 720px) {
    .footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer__legal {
      text-align: center;
    }
    .prompt__text {
      font-size: var(--op-text-lg);
    }
  }
</style>
