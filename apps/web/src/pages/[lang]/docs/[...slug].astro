---
import { getCollection, render } from 'astro:content';
import DocLayout from '../../../layouts/DocLayout.astro';
import ApiEntry from '../../../components/docs/ApiEntry.astro';
import PropsTable from '../../../components/docs/PropsTable.astro';
import Example from '../../../components/docs/Example.astro';
import Badge from '../../../components/docs/Badge.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(doc => {
    const idString = doc.id;
    const parts = idString.split('/');
    const lang = parts[0];
    const slugParts = parts.slice(1);
    let slug: string | undefined = slugParts.join('/').replace(/\.mdx$/, '');

    if (slug === 'index' || slug === '') {
      slug = undefined;
    }

    return {
      params: { lang, slug },
      props: { doc },
    };
  });
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<DocLayout
  title={doc.data.title}
  eyebrow={doc.data.eyebrow}
  description={doc.data.description}
>
  <Content components={{ ApiEntry, PropsTable, Example, Badge }} />
</DocLayout>
