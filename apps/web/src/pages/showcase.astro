---
import Layout from "../layouts/Layout.astro";
import { showcases } from "../data/showcases";

const version = "0.3.0";
---

<Layout
  title="Showcase — open-press"
  description="A gallery of public documents built and deployed with OpenPress."
>
  <header class="nav">
    <div class="op-page nav__inner">
      <a class="nav__brand" href="/" aria-label="open-press">
        open-press
      </a>
      <nav class="nav__links" aria-label="Primary navigation">
        <a href="https://open-press-story.pages.dev">Document</a>
        <a aria-current="page" href="/showcase">Showcase</a>
        <a href="https://github.com/quan0715/open-press">GitHub</a>
        <a href="https://www.npmjs.com/package/@open-press/cli">npm</a>
        <a href="https://github.com/quan0715/open-press/blob/main/CHANGELOG.md">v{version}</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="showcase-hero">
      <div class="op-page">
        <div class="showcase-hero__content">
          <p class="op-eyebrow">Showcase</p>
          <h1>Real documents built with OpenPress.</h1>
          <p>
            A small gallery of public OpenPress documents, each published as its
            own deployable web reader or PDF-backed document.
          </p>
        </div>
      </div>
    </section>

    <section class="showcase-gallery" aria-labelledby="showcase-gallery-title">
      <div class="op-page">
        <div class="showcase-gallery__header">
          <h2 id="showcase-gallery-title">Published documents</h2>
          <p class="op-meta">
            Public examples from shipped OpenPress documents.
          </p>
        </div>

        <div class="showcase-grid">
          {showcases.map((item) => (
            <article class="showcase-card">
              <a
                class="showcase-card__cover-link"
                href={item.href}
                target="_blank"
                rel="noreferrer"
                aria-label={`View ${item.title}`}
              >
                <img
                  class="showcase-card__cover"
                  src={item.cover}
                  alt={`${item.title} cover`}
                  loading="lazy"
                  width="1190"
                  height="1684"
                />
              </a>

              <div class="showcase-card__body">
                <h3>{item.title}</h3>
                <p>{item.description}</p>

                <a
                  class="showcase-card__action"
                  href={item.href}
                  target="_blank"
                  rel="noreferrer"
                >
                  View document
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="op-page footer__inner">
      <div class="footer__brand">
        <p class="footer__name">open-press</p>
        <p class="op-meta">AI-first fixed-layout documents · v{version}</p>
      </div>
      <ul class="footer__links">
        <li><a href="/">Home</a></li>
        <li><a href="https://open-press-story.pages.dev">Document</a></li>
        <li><a href="https://github.com/quan0715/open-press">GitHub</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/cli">@open-press/cli</a></li>
        <li><a href="https://www.npmjs.com/package/@open-press/core">@open-press/core</a></li>
      </ul>
      <p class="footer__legal op-meta">
        © 2026 quan0715 · MIT License
      </p>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    border-bottom: var(--op-border-hairline);
    background: var(--op-paper);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--op-space-5);
    gap: var(--op-space-6);
  }
  .nav__brand {
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
    text-decoration: none;
    letter-spacing: var(--op-tracking-tight);
  }
  .nav__links {
    display: flex;
    gap: var(--op-space-6);
    font-size: var(--op-text-sm);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav__links a {
    color: var(--op-ink);
    text-decoration: none;
  }
  .nav__links a:hover,
  .nav__links a[aria-current="page"] {
    color: var(--op-accent);
  }

  .showcase-hero {
    padding-block: var(--op-space-24) var(--op-space-12);
  }
  .showcase-hero__content {
    max-width: var(--op-content-default);
  }
  .showcase-hero h1 {
    margin-top: var(--op-space-4);
    max-width: 13ch;
  }
  .showcase-hero p:not(.op-eyebrow) {
    margin-top: var(--op-space-6);
    max-width: 38rem;
    color: var(--op-subdued-strong);
    font-size: var(--op-text-lg);
  }

  .showcase-gallery {
    padding-block: var(--op-space-12) var(--op-space-24);
    border-top: var(--op-border-hairline);
  }
  .showcase-gallery__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--op-space-8);
    margin-bottom: var(--op-space-10);
  }
  .showcase-gallery__header h2 {
    font-size: var(--op-text-3xl);
  }
  .showcase-gallery__header p {
    max-width: 22rem;
    text-align: right;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 22rem));
    gap: var(--op-space-12) var(--op-space-8);
    align-items: start;
  }
  .showcase-card {
    min-width: 0;
  }
  .showcase-card__cover-link {
    display: block;
    aspect-ratio: 1 / 1.414;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
    text-decoration: none;
    overflow: hidden;
    transition: border-color var(--op-duration-fast) var(--op-ease),
      transform var(--op-duration-fast) var(--op-ease);
  }
  .showcase-card__cover-link:hover {
    border-color: var(--op-accent);
    transform: translateY(-2px);
  }
  .showcase-card__cover {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--op-surface);
  }
  .showcase-card__body {
    padding-top: var(--op-space-5);
  }
  .showcase-card h3 {
    font-size: var(--op-text-2xl);
  }
  .showcase-card p {
    margin-top: var(--op-space-3);
    color: var(--op-subdued-strong);
  }
  .showcase-card__action {
    display: inline-flex;
    margin-top: var(--op-space-5);
    color: var(--op-accent);
    font-weight: var(--op-weight-medium);
  }

  .footer {
    border-top: var(--op-border-hairline);
    padding-block: var(--op-space-12);
    background: var(--op-paper-soft);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: var(--op-space-8);
    align-items: center;
  }
  .footer__brand .footer__name {
    font-family: var(--op-font-display);
    font-weight: var(--op-weight-medium);
    color: var(--op-ink-strong);
  }
  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--op-space-6);
    justify-content: center;
    flex-wrap: wrap;
    font-size: var(--op-text-sm);
  }
  .footer__links a {
    color: var(--op-ink);
    text-decoration: none;
  }
  .footer__links a:hover {
    color: var(--op-accent);
  }
  .footer__legal {
    text-align: right;
  }

  @media (max-width: 720px) {
    .nav__inner {
      align-items: flex-start;
      flex-direction: column;
    }
    .nav__links {
      justify-content: flex-start;
      gap: var(--op-space-4);
    }
    .showcase-hero {
      padding-block: var(--op-space-16) var(--op-space-10);
    }
    .showcase-hero h1 {
      max-width: 12ch;
    }
    .showcase-gallery__header {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--op-space-3);
    }
    .showcase-gallery__header p {
      text-align: left;
    }
    .showcase-grid {
      grid-template-columns: 1fr;
    }
    .footer__inner {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .footer__links {
      justify-content: flex-start;
      gap: var(--op-space-4);
    }
    .footer__legal {
      text-align: left;
    }
  }
</style>
