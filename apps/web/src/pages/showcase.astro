---
import LandingFooter from "../components/home/LandingFooter.astro";
import LandingNav from "../components/home/LandingNav.astro";
import Layout from "../layouts/Layout.astro";
import { homeVersion } from "../data/home";
import { showcases } from "../data/showcases";

const showcaseNav = [
  { label: "Home", href: "/" },
  { label: "Use cases", href: "/#use-cases" },
  { label: "AutoPaging", href: "/#autopaging" },
  { label: "Packages", href: "/#packages" },
  { label: "GitHub", href: "https://github.com/quan0715/open-press" },
  { label: "npm", href: "https://www.npmjs.com/package/@open-press/cli" },
];

const initial = showcases[0];
---

<Layout
  title="OpenPress Showcase — documents, prompts, and embedded readers"
  description="Explore OpenPress documents inside the website with source context, sample prompts, and embedded reader previews."
  canonical="https://open-press.dev/showcase"
  image="/openpress-og.svg"
  keywords={["OpenPress showcase", "AI document examples", "fixed-layout PDF examples", "OpenPress prompts"]}
>
  <LandingNav links={showcaseNav} />

  <main>
    <section class="showcase-shell" aria-labelledby="showcase-title">
      <div class="op-page showcase-shell__inner">
        <aside class="showcase-panel">
          <p class="op-eyebrow">Showcase</p>
          <h1 id="showcase-title">Live documents</h1>
          <p class="showcase-panel__lede">
            Choose a document, inspect the context and prompt, then preview the
            embedded reader without leaving the OpenPress site.
          </p>

          <div class="showcase-tabs" role="tablist" aria-label="Showcase documents">
            {showcases.map((item, index) => (
              <button
                type="button"
                class="showcase-tab"
                data-showcase-tab={item.slug}
                aria-selected={index === 0 ? "true" : "false"}
              >
                <span>{`0${index + 1}`}</span>
                {item.title}
              </button>
            ))}
          </div>

          <div class="showcase-details">
            {showcases.map((item, index) => (
              <article
                class="showcase-detail"
                data-showcase-detail={item.slug}
                hidden={index !== 0}
              >
                <p class="showcase-detail__type">{item.documentType}</p>
                <h2>{item.title}</h2>
                <p>{item.description}</p>

                <div class="prompt-box">
                  <div class="prompt-box__head">
                    <p>Example prompt</p>
                    <button type="button" data-copy-prompt={item.prompt}>Copy</button>
                  </div>
                  <blockquote>{item.prompt}</blockquote>
                </div>

                <dl>
                  <div>
                    <dt>Audience</dt>
                    <dd>{item.audience}</dd>
                  </div>
                  <div>
                    <dt>Source material</dt>
                    <dd>{item.sourceMaterial}</dd>
                  </div>
                </dl>

                <a class="live-link" href={item.href} target="_blank" rel="noreferrer">
                  Open live reader
                </a>
              </article>
            ))}
          </div>
        </aside>

        <section class="reader-preview" aria-label="Embedded document preview">
          <div class="reader-preview__bar">
            <span>embedded reader / PDF-backed preview</span>
            <a id="reader-preview-link" href={initial.href} target="_blank" rel="noreferrer">Open full screen</a>
          </div>
          <div class="reader-preview__frame-shell">
            <iframe
              id="reader-preview-frame"
              src={initial.embedHref}
              title={`${initial.title} embedded reader preview`}
              loading="eager"
            ></iframe>
          </div>
        </section>
      </div>
    </section>
    <script id="showcase-data" type="application/json" is:inline set:html={JSON.stringify(showcases)} />
  </main>

  <LandingFooter version={homeVersion} />
</Layout>

<style>
  :global(body) {
    background:
      linear-gradient(90deg, rgba(12, 14, 17, 0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(12, 14, 17, 0.035) 1px, transparent 1px),
      var(--op-paper);
    background-size: 4.5rem 4.5rem;
  }

  .showcase-shell {
    padding-block: var(--op-space-12) var(--op-space-16);
  }
  .showcase-shell__inner {
    display: grid;
    grid-template-columns: minmax(22rem, 0.48fr) minmax(0, 1fr);
    gap: var(--op-space-8);
    align-items: start;
  }
  .showcase-panel {
    position: sticky;
    top: 5.5rem;
    max-height: calc(100svh - 7rem);
    overflow: auto;
    scrollbar-gutter: stable;
    border: var(--op-border-hairline-strong);
    background: color-mix(in srgb, var(--op-surface) 92%, var(--op-paper));
    padding: var(--op-space-6);
  }
  .showcase-panel h1 {
    margin-top: var(--op-space-4);
    max-width: none;
    font-size: clamp(2.5rem, 3.5vw, 3.6rem);
    line-height: 1.02;
    letter-spacing: 0;
  }
  .showcase-panel__lede {
    margin-top: var(--op-space-5);
    color: var(--op-subdued-strong);
    font-size: var(--op-text-lg);
  }
  .showcase-tabs {
    display: flex;
    gap: var(--op-space-2);
    margin-top: var(--op-space-6);
    overflow-x: auto;
    padding-bottom: var(--op-space-2);
    scroll-snap-type: inline mandatory;
  }
  .showcase-tab {
    flex: 0 0 13rem;
    display: grid;
    grid-template-columns: 1.8rem 1fr;
    gap: var(--op-space-2);
    min-height: 3.75rem;
    border: var(--op-border-hairline);
    background: var(--op-paper);
    color: var(--op-ink);
    padding: var(--op-space-3);
    scroll-snap-align: start;
    text-align: left;
    cursor: pointer;
  }
  .showcase-tab span {
    color: var(--op-accent);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
  }
  .showcase-tab[aria-selected="true"] {
    border-color: var(--op-accent);
    background: var(--op-surface);
    color: var(--op-ink-strong);
  }
  .showcase-details {
    margin-top: var(--op-space-5);
  }
  .showcase-detail__type {
    color: var(--op-accent);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
  }
  .showcase-detail h2 {
    margin-top: var(--op-space-3);
    font-size: var(--op-text-2xl);
    letter-spacing: 0;
  }
  .showcase-detail > p:not(.showcase-detail__type) {
    margin-top: var(--op-space-3);
    color: var(--op-subdued-strong);
  }
  .showcase-detail dl {
    display: grid;
    gap: var(--op-space-3);
    margin-top: var(--op-space-5);
  }
  .showcase-detail dl div {
    padding-top: var(--op-space-3);
    border-top: var(--op-border-hairline);
  }
  .showcase-detail dt {
    color: var(--op-subdued);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
  }
  .showcase-detail dd {
    margin: var(--op-space-2) 0 0;
    color: var(--op-ink);
  }
  .prompt-box {
    margin-top: var(--op-space-5);
    border: var(--op-border-hairline-strong);
    background: var(--op-ink-strong);
    color: var(--op-ink-on-dark);
  }
  .prompt-box__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--op-space-4);
    border-bottom: 1px solid color-mix(in srgb, var(--op-ink-on-dark) 20%, transparent);
    padding: var(--op-space-3) var(--op-space-4);
  }
  .prompt-box__head p {
    color: var(--op-subdued-on-dark);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
  }
  .prompt-box button {
    border: 1px solid color-mix(in srgb, var(--op-ink-on-dark) 36%, transparent);
    background: transparent;
    color: var(--op-ink-on-dark);
    padding: var(--op-space-1) var(--op-space-3);
    cursor: pointer;
  }
  .prompt-box blockquote {
    margin: 0;
    padding: var(--op-space-4);
    color: var(--op-ink-on-dark);
    font-family: var(--op-font-display);
    font-size: var(--op-text-base);
    line-height: 1.42;
    overflow-wrap: anywhere;
  }
  .live-link {
    display: inline-flex;
    margin-top: var(--op-space-5);
    color: var(--op-ink-strong);
    font-weight: var(--op-weight-semibold);
  }
  .reader-preview {
    min-width: 0;
    min-height: calc(100svh - 7rem);
    overflow: hidden;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
  }
  .reader-preview__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--op-space-4);
    min-height: 3.2rem;
    border-bottom: var(--op-border-hairline);
    padding-inline: var(--op-space-4);
  }
  .reader-preview__bar span {
    color: var(--op-subdued);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
  }
  .reader-preview__bar a {
    color: var(--op-ink-strong);
    font-size: var(--op-text-sm);
    font-weight: var(--op-weight-semibold);
  }
  .reader-preview__frame-shell {
    width: 100%;
    height: calc(100svh - 10.2rem);
    min-height: 46rem;
    overflow: hidden;
    background: white;
  }
  .reader-preview iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: white;
  }

  @media (max-width: 1080px) {
    .showcase-shell__inner {
      grid-template-columns: 1fr;
    }
    .showcase-panel {
      position: static;
      max-height: none;
    }
    .reader-preview__frame-shell {
      height: 44rem;
      min-height: 0;
    }
  }

  @media (max-width: 720px) {
    .showcase-shell {
      padding-block: var(--op-space-8) var(--op-space-12);
    }
    .showcase-panel {
      padding: var(--op-space-4);
    }
    .reader-preview__bar {
      align-items: flex-start;
      flex-direction: column;
      padding-block: var(--op-space-3);
    }
    .reader-preview__frame-shell {
      height: 26.6rem;
    }
    .reader-preview iframe {
      width: 56rem;
      height: 70rem;
      transform: scale(0.38);
      transform-origin: top left;
    }
  }
</style>

<script>
  type ShowcaseRuntimeItem = {
    slug: string;
    title: string;
    href: string;
    embedHref: string;
  };

  const dataEl = document.querySelector<HTMLScriptElement>("#showcase-data");
  const items = (dataEl ? JSON.parse(dataEl.textContent ?? "[]") : []) as ShowcaseRuntimeItem[];
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-showcase-tab]"));
  const details = Array.from(document.querySelectorAll<HTMLElement>("[data-showcase-detail]"));
  const frame = document.querySelector<HTMLIFrameElement>("#reader-preview-frame");
  const fullLink = document.querySelector<HTMLAnchorElement>("#reader-preview-link");

  const activate = (slug: string) => {
    const item = items.find((entry) => entry.slug === slug) ?? items[0];
    const selectedTab = tabs.find((tab) => tab.dataset.showcaseTab === item.slug);
    tabs.forEach((tab) => {
      tab.setAttribute("aria-selected", String(tab.dataset.showcaseTab === item.slug));
    });
    selectedTab?.scrollIntoView({ block: "nearest", inline: "nearest" });
    details.forEach((detail) => {
      detail.hidden = detail.dataset.showcaseDetail !== item.slug;
    });
    if (frame) {
      frame.src = item.embedHref;
      frame.title = `${item.title} embedded reader preview`;
    }
    if (fullLink) {
      fullLink.href = item.href;
    }
    if (location.hash.slice(1) !== item.slug) {
      history.replaceState(null, "", `#${item.slug}`);
    }
  };

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => activate(tab.dataset.showcaseTab ?? items[0].slug));
  });

  document.querySelectorAll<HTMLButtonElement>("[data-copy-prompt]").forEach((button) => {
    button.addEventListener("click", async () => {
      const text = button.dataset.copyPrompt ?? "";
      try {
        await navigator.clipboard.writeText(text);
        button.textContent = "Copied";
        setTimeout(() => {
          button.textContent = "Copy";
        }, 1400);
      } catch {
        button.textContent = "Select";
      }
    });
  });

  const initialSlug = location.hash.slice(1);
  if (initialSlug) {
    activate(initialSlug);
  }

  window.addEventListener("hashchange", () => {
    activate(location.hash.slice(1));
  });
</script>
