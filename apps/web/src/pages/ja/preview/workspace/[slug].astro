---
import Layout from "../../../../layouts/Layout.astro";
import LandingNav from "../../../../components/home/LandingNav.astro";
import LandingFooter from "../../../../components/home/LandingFooter.astro";
import { navLinks, homeVersion } from "../../../../data/home";

const lang = Astro.currentLocale || "zh-tw";
const links = navLinks[lang as keyof typeof navLinks] || navLinks["zh-tw"];

export function getStaticPaths() {
  return [
    {
      params: { slug: "proposal" },
      props: {
        title: "Series A 提案書",
        page: { label: "A4 portrait", width: "210mm", height: "297mm", ratio: "210/297" },
        kind: "long-form",
        sections: [
          "Executive summary",
          "Problem",
          "Solution",
          "Market & traction",
          "Team",
          "Financials",
          "The ask",
        ],
      },
    },
    {
      params: { slug: "pitch-deck" },
      props: {
        title: "Investor pitch",
        page: { label: "16:9 slides", width: "1920px", height: "1080px", ratio: "16/9" },
        kind: "slide",
        sections: [
          "Vision",
          "Problem in one slide",
          "Demo",
          "Numbers",
          "Why now",
          "Team",
          "Ask",
        ],
      },
    },
    {
      params: { slug: "social" },
      props: {
        title: "Launch cards",
        page: { label: "1080 × 1080", width: "1080px", height: "1080px", ratio: "1/1" },
        kind: "social",
        sections: ["Announcement", "Quote card", "Stat card", "CTA card"],
      },
    },
  ];
}

const { slug } = Astro.params;
const props = Astro.props as {
  title: string;
  page: { label: string; width: string; height: string; ratio: string };
  kind: string;
  sections: string[];
};
---

<Layout
  title={`${props.title} — Workspace preview`}
  description="OpenPress Workspace per-Press preview."
>
  <LandingNav links={links} />

  <main class="max-w-[64rem] mx-auto pt-10 px-6 pb-16">
    <header class="mb-7 pb-6 border-b border-hairline">
      <p class="m-0 mb-3 text-subdued font-mono text-xs font-semibold tracking-[0.08em]">
        <a class="text-subdued-strong no-underline hover:text-accent transition-colors duration-150 ease-out" href="/preview/workspace/">← Series A launch</a>
        <span class="text-hairline-strong"> / </span>
        <span>/{slug}</span>
      </p>
      <h1 class="m-0 mb-3 font-display text-3xl leading-display">{props.title}</h1>
      <p class="m-0 text-subdued font-mono text-sm">
        {props.page.label} · {props.page.width} × {props.page.height}
      </p>
    </header>

    <section class="grid place-items-center p-6 bg-[linear-gradient(135deg,color-mix(in_srgb,var(--color-accent)_10%,var(--color-paper-soft)),var(--color-paper-soft))] border border-hairline rounded-lg mb-10" aria-label="Document preview">
      <div class="w-[min(100%,32rem)] bg-paper border border-[color-mix(in_srgb,var(--color-accent)_25%,var(--color-hairline))] rounded-[4px] overflow-hidden shadow-[0_10px_30px_color-mix(in_srgb,var(--color-ink)_10%,transparent)] grid grid-rows-[auto_1fr]" style={`aspect-ratio: ${props.page.ratio};`}>
        <div class="py-2 px-[0.9rem] border-b border-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] text-subdued font-mono text-[0.7rem] font-semibold tracking-[0.06em] uppercase">
          <span>{props.page.label}</span>
        </div>
        <div class="py-6 px-7 grid content-center gap-3 overflow-hidden">
          <h2 class="m-0 mb-2 text-ink-strong font-display text-2xl leading-[1.2]">{props.title}</h2>
          <ol class="m-0 pl-[1.2rem] text-ink text-sm leading-[1.7]">
            {props.sections.map((s) => (
              <li>{s}</li>
            ))}
          </ol>
          <p class="mt-4 mb-0 text-subdued text-xs italic">
            Static preview. A deployed Workspace renders the full Press tree here.
          </p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="m-0 mb-3 font-display text-xl leading-heading">What renders here in a real deployment</h2>
      <p class="m-0 mb-4 max-w-[48rem] text-ink leading-body">
        Each <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">&lt;Press&gt;</code> slug becomes a route in the deployed reader. The reader
        loads <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">public/openpress/{slug}/document.json</code>, renders the Frames in order,
        and exposes the inspector / comment-marker chrome on the local
        <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">/&lt;press-slug&gt;/preview</code> workbench route.
      </p>
      <p class="m-0 mb-4 max-w-[48rem] text-ink leading-body">
        The preview above shows the chrome shape (page geometry, section outline) but not
        the actual paginated content — that would come from the Press build pipeline.
      </p>
      <p class="m-0 mb-4 max-w-[48rem] text-ink leading-body">
        <a class="text-accent no-underline font-semibold hover:underline" href="/preview/workspace/">← Back to the Workspace gallery</a>
      </p>
    </section>
  </main>

  <LandingFooter version={homeVersion} />
</Layout>
