---
import Layout from "../../../../layouts/Layout.astro";
import LandingNav from "../../../../components/home/LandingNav.astro";
import LandingFooter from "../../../../components/home/LandingFooter.astro";
import { navLinks, homeVersion } from "../../../../data/home";

const lang = Astro.currentLocale || "zh-tw";
const links = navLinks[lang as keyof typeof navLinks] || navLinks["zh-tw"];

// Demo data — simulates what an actual deployed Workspace's reader
// landing page would receive from public/openpress/workspace.json.
// In the real reader this comes from the engine's per-Press build.
const workspace = {
  name: "Series A launch",
  presses: [
    {
      slug: "proposal",
      title: "Series A 提案書",
      organization: "FooBar Co.",
      author: "Q. Liang",
      page: { label: "A4", width: "210mm", height: "297mm", ratio: "210/297" },
      pageCount: 24,
      kind: "long-form",
    },
    {
      slug: "pitch-deck",
      title: "Investor pitch",
      organization: "FooBar Co.",
      author: "Q. Liang",
      page: { label: "16:9", width: "1920px", height: "1080px", ratio: "16/9" },
      pageCount: 18,
      kind: "slide",
    },
    {
      slug: "social",
      title: "Launch cards",
      organization: "FooBar Co.",
      page: { label: "1080 × 1080", width: "1080px", height: "1080px", ratio: "1/1" },
      pageCount: 6,
      kind: "social",
    },
  ],
};
---

<Layout
  title={`${workspace.name} — Workspace`}
  description="Preview of the OpenPress Workspace gallery — every Press document in this project, click to enter."
>
  <LandingNav links={links} />

  <main class="max-w-[64rem] mx-auto pt-10 px-6 pb-16">
    <header class="mb-8 pb-7 border-b border-hairline">
      <p class="m-0 mb-2 text-subdued font-mono text-xs font-semibold tracking-[0.08em] uppercase">Workspace · Preview</p>
      <h1 class="m-0 mb-4 font-display text-4xl leading-display">{workspace.name}</h1>
      <p class="m-0 max-w-[48rem] text-subdued-strong text-lg leading-body">
        {workspace.presses.length} documents in this project. Click any card to enter the
        full-fidelity reader. This page is a static preview of the layout —
        the real <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">/</code> route of a deployed Workspace renders this from
        <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">public/openpress/workspace.json</code>.
      </p>
    </header>

    <section class="grid grid-cols-[repeat(auto-fit,minmax(18rem,1fr))] gap-5 m-0 mb-10" aria-label="Documents">
      {workspace.presses.map((p) => (
        <a class={`grid grid-rows-[auto_1fr] border border-hairline rounded-lg bg-surface text-ink no-underline overflow-hidden transition-all duration-[160ms] ease-out hover:border-accent hover:-translate-y-[2px] hover:shadow-[0_6px_24px_color-mix(in_srgb,var(--color-ink)_10%,transparent)] ws-card--${p.kind}`} href={`/preview/workspace/${p.slug}`}>
          <div class="w-full bg-[linear-gradient(135deg,color-mix(in_srgb,var(--color-accent)_14%,var(--color-paper-soft)),var(--color-paper-soft))] grid place-items-center p-4 border-b border-hairline" style={`aspect-ratio: ${p.page.ratio};`}>
            <div class="w-[70%] h-[70%] bg-paper border border-[color-mix(in_srgb,var(--color-accent)_30%,var(--color-hairline))] rounded-[3px] grid place-items-center shadow-[0_4px_14px_color-mix(in_srgb,var(--color-ink)_10%,transparent)]">
              <span class="text-subdued font-mono text-xs font-semibold tracking-[0.06em] uppercase">{p.page.label}</span>
            </div>
          </div>
          <div class="grid gap-[0.4rem] p-4 px-5 pb-5">
            <p class="m-0 text-subdued font-mono text-xs font-semibold tracking-[0.04em]">/{p.slug}</p>
            <h3 class="m-0 text-ink-strong font-body text-xl font-semibold leading-[1.3]">{p.title}</h3>
            <p class="m-0 text-subdued-strong text-sm">
              {p.organization}
              {p.author && <span class="text-subdued"> · </span>}
              {p.author && <span>{p.author}</span>}
            </p>
            <p class="mt-[0.2rem] text-subdued font-mono text-xs">
              {p.pageCount} pages · {p.page.width} × {p.page.height}
            </p>
          </div>
        </a>
      ))}
    </section>

    <section class="mt-10 pt-7 border-t border-hairline">
      <h2 class="m-0 mb-3 font-display text-2xl leading-heading">How this works</h2>
      <p class="m-0 mb-4 max-w-[48rem] text-ink leading-body">
        A multi-document OpenPress project has a single <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">press/index.tsx</code> exporting a
        <a class="text-accent underline decoration-1 underline-offset-[3px] transition-colors duration-150 ease-out hover:text-accent-hover hover:decoration-2" href="/docs/api/workspace"><code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">&lt;Workspace&gt;</code></a> with one or more
        <a class="text-accent underline decoration-1 underline-offset-[3px] transition-colors duration-150 ease-out hover:text-accent-hover hover:decoration-2" href="/docs/api/press"><code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">&lt;Press&gt;</code></a> children. The build pipeline
        produces one bundle per Press at <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">public/openpress/&lt;slug&gt;/document.json</code>,
        plus a top-level <code class="py-[0.1em] px-[0.35em] rounded-[3px] bg-[color-mix(in_srgb,var(--color-ink)_8%,transparent)] font-mono text-[0.92em]">workspace.json</code> manifest that feeds this gallery.
      </p>
      <p class="m-0 mb-4 max-w-[48rem] text-ink leading-body">
        For single-document projects, the Workspace has just one Press — the reader skips the
        gallery and lands directly in the document.
      </p>
    </section>
  </main>

  <LandingFooter version={homeVersion} />
</Layout>
