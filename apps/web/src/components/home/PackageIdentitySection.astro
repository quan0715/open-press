---
import LogoMark from "./LogoMark.astro";
import SectionHeading from "./SectionHeading.astro";

interface PackageItem {
  name: string;
  role: string;
  message: string;
  href: string;
}

interface Props {
  packages: PackageItem[];
}

const { packages } = Astro.props;
---

<section class="py-24 border-t border-hairline bg-[linear-gradient(180deg,color-mix(in_srgb,var(--op-paper-soft)_70%,white),var(--op-paper))] max-[720px]:py-16" id="packages" aria-labelledby="packages-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="Package identity"
      title="One family for the OpenPress stack."
      id="packages-title"
      split
      body="CLI, core, skills, and starter examples share one document identity."
    />

    <div class="grid grid-cols-[minmax(19rem,0.6fr)_minmax(0,1fr)] gap-8 mt-12 max-[1080px]:grid-cols-1">
      <article class="border border-hairline-strong bg-surface p-6">
        <LogoMark label="OpenPress" />
        <p class="mt-8 text-ink-strong font-display text-2xl leading-[1.2]">
          Serious documents with AI, without losing the source.
        </p>
      </article>

      <div class="grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
        {packages.map((item) => (
          <a class="block min-h-[10.5rem] border border-hairline-strong bg-[color-mix(in_srgb,var(--op-surface)_86%,var(--op-paper))] p-5 text-ink no-underline hover:border-accent hover:no-underline" href={item.href}>
            <p class="text-accent font-mono text-xs tracking-wide uppercase">{item.role}</p>
            <h3 class="mt-4 text-xl tracking-normal">{item.name}</h3>
            <span class="block mt-5 text-subdued-strong">{item.message}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
