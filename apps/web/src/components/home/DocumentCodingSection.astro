---
import SectionHeading from "./SectionHeading.astro";
---

<section class="py-24 border-b border-hairline bg-[color-mix(in_srgb,var(--op-paper)_78%,var(--op-surface))] max-[720px]:py-16" id="document-code" aria-labelledby="document-code-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="Document as code"
      title="A document is a source tree."
      id="document-code-title"
      split
      body="OpenPress gives AI a real workspace: structure, chapters, assets, and output each have a place."
    />

    <div class="mt-12" data-coding-carousel>
      <div class="grid grid-cols-2 gap-3 max-[720px]:grid-cols-1" role="tablist" aria-label="OpenPress document coding layers">
        <button type="button" class="grid grid-cols-[2.5rem_1fr] gap-3 items-start border border-hairline-strong bg-surface p-4 text-left cursor-pointer aria-selected:border-accent aria-selected:bg-[color-mix(in_srgb,var(--op-surface)_86%,var(--op-accent-soft))]" id="coding-tab-tree" data-coding-tab="tree" role="tab" aria-selected="true" aria-controls="coding-panel-tree">
          <span class="text-accent font-mono text-xs">01</span>
          <strong class="col-start-2 block text-ink-strong font-display text-xl font-medium leading-[1.05]">Press Tree</strong>
          <small class="col-start-2 block mt-2 text-subdued-strong text-sm">Defines the document skeleton</small>
        </button>
        <button type="button" class="grid grid-cols-[2.5rem_1fr] gap-3 items-start border border-hairline-strong bg-surface p-4 text-left cursor-pointer aria-selected:border-accent aria-selected:bg-[color-mix(in_srgb,var(--op-surface)_86%,var(--op-accent-soft))]" id="coding-tab-mdx" data-coding-tab="mdx" role="tab" aria-selected="false" aria-controls="coding-panel-mdx">
          <span class="text-accent font-mono text-xs">02</span>
          <strong class="col-start-2 block text-ink-strong font-display text-xl font-medium leading-[1.05]">Chapter Source</strong>
          <small class="col-start-2 block mt-2 text-subdued-strong text-sm">Renders content into designed pages</small>
        </button>
      </div>

      <article class="[&.is-active]:grid hidden grid-cols-[minmax(18rem,0.48fr)_minmax(0,1fr)] gap-6 items-stretch mt-5 border border-hairline-strong bg-surface p-5 max-[1120px]:grid-cols-1 max-[720px]:p-4 is-active" id="coding-panel-tree" data-coding-panel="tree" role="tabpanel" aria-labelledby="coding-tab-tree">
        <div class="flex flex-col gap-5 border-r border-hairline py-2 pr-5 pl-0 max-[1120px]:border-r-0 max-[1120px]:border-b max-[1120px]:p-0 max-[1120px]:pb-5">
          <p class="op-eyebrow">Press Tree</p>
          <h3 class="mt-4 text-[clamp(2.2rem,4vw,4rem)] tracking-normal leading-[1.05]">The agent edits the book, not a blob.</h3>
          <p class="mt-5 text-subdued-strong text-lg">Cover, TOC, sections, and back cover stay addressable.</p>
        </div>

        <div class="min-w-0 grid grid-cols-[11rem_minmax(0,1fr)_10rem] gap-5 items-stretch max-[1120px]:grid-cols-1">
          <div class="grid content-start gap-2 border border-hairline-strong bg-paper p-4 max-[1120px]:grid-cols-2 max-[720px]:grid-cols-1" aria-label="OpenPress workspace files">
            <p class="m-0 mb-2 text-accent font-mono text-xs tracking-wide max-[1120px]:col-span-full max-[720px]:col-auto">openpress/</p>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">press/index.tsx</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">press/userstory/chapters/</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">press/media/</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">press/theme/</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">dist-react/ + pdf</span>
          </div>

          <pre class="min-w-0 max-h-[36rem] m-0 overflow-auto border border-hairline-strong bg-ink-strong text-ink-on-dark p-5 text-[clamp(0.72rem,0.95vw,0.9rem)] leading-[1.62] whitespace-pre max-[720px]:whitespace-pre-wrap"><code class="text-inherit">{`export default function UserStoryWorkspace() {
  return (
    <Workspace>
      <Press
        slug="userstory"
        title="User Story"
        page="a4"
        sources={[
          mdxSource({
            id: "story",
            preset: "section-folders",
            root: "userstory/chapters",
          }),
        ]}
      >
        <Cover />
        <Toc source="story" maxLevel={2} />
        <Sections source="story" />
        <BackCover />
      </Press>
    </Workspace>
  );
}`}</code></pre>

          <div class="grid content-center gap-3 max-[1120px]:grid-cols-4 max-[720px]:grid-cols-1" aria-label="Press Tree output order">
            <span class="grid place-items-center min-h-[5.6rem] border border-hairline-strong bg-paper text-ink-strong font-display text-xl text-center">Cover</span>
            <span class="grid place-items-center min-h-[5.6rem] border border-hairline-strong bg-paper text-ink-strong font-display text-xl text-center">TOC</span>
            <span class="grid place-items-center min-h-[5.6rem] border border-hairline-strong bg-paper text-ink-strong font-display text-xl text-center">Sections</span>
            <span class="grid place-items-center min-h-[5.6rem] border border-hairline-strong bg-paper text-ink-strong font-display text-xl text-center">Back cover</span>
          </div>
        </div>
      </article>

      <article class="[&.is-active]:grid hidden grid-cols-[minmax(18rem,0.48fr)_minmax(0,1fr)] gap-6 items-stretch mt-5 border border-hairline-strong bg-surface p-5 max-[1120px]:grid-cols-1 max-[720px]:p-4" id="coding-panel-mdx" data-coding-panel="mdx" role="tabpanel" aria-labelledby="coding-tab-mdx" hidden>
        <div class="flex flex-col gap-5 border-r border-hairline py-2 pr-5 pl-0 max-[1120px]:border-r-0 max-[1120px]:border-b max-[1120px]:p-0 max-[1120px]:pb-5">
          <p class="op-eyebrow">Chapter Source</p>
          <h3 class="mt-4 text-[clamp(2.2rem,4vw,4rem)] tracking-normal leading-[1.05]">Content becomes pages only after it is rendered.</h3>
          <p class="mt-5 text-subdued-strong text-lg">Chapters stay readable while the output stays designed.</p>
        </div>

        <div class="min-w-0 grid grid-cols-[11rem_minmax(0,0.9fr)_auto_minmax(15rem,0.72fr)] gap-5 items-stretch bg-[linear-gradient(90deg,rgba(12,14,17,0.035)_1px,transparent_1px),linear-gradient(180deg,rgba(12,14,17,0.035)_1px,transparent_1px)] bg-[size:3rem_3rem] max-[1120px]:grid-cols-1">
          <div class="grid content-start gap-2 border border-hairline-strong bg-paper p-4 max-[1120px]:grid-cols-2 max-[720px]:grid-cols-1" aria-label="Chapter source files">
            <p class="m-0 mb-2 text-accent font-mono text-xs tracking-wide max-[1120px]:col-span-full max-[720px]:col-auto">chapters/</p>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">01-intro/content.mdx</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">02-workbench/content.mdx</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">components/figures.tsx</span>
            <span class="block border-t border-hairline py-2 text-subdued-strong font-mono text-[0.72rem] leading-[1.35] break-words">citations/notes.md</span>
          </div>

          <pre class="min-w-0 max-h-[36rem] m-0 overflow-auto border border-hairline-strong bg-ink-strong text-ink-on-dark p-5 text-[clamp(0.72rem,0.95vw,0.9rem)] leading-[1.62] whitespace-pre max-[720px]:whitespace-pre-wrap"><code class="text-inherit">{`## User Story 01

Turn assignment notes into a report with
cover, TOC, chapters, figures, and PDF.

<ZeroToOpenPressFigure />

<TableCaption>Workflow</TableCaption>`}</code></pre>

          <div class="grid place-items-center text-accent font-mono text-xs tracking-wide text-center uppercase before:content-[''] before:block before:w-[1px] before:h-[5rem] before:bg-hairline-strong after:content-[''] after:block after:w-[1px] after:h-[5rem] after:bg-hairline-strong max-[720px]:grid-cols-[1fr_auto_1fr] max-[720px]:gap-3 max-[720px]:before:w-full max-[720px]:before:h-[1px] max-[720px]:after:w-full max-[720px]:after:h-[1px]" aria-hidden="true">
            <span class="my-3 max-[720px]:my-0">render</span>
          </div>

          <div class="self-center w-[min(100%,20rem)] aspect-[1/1.414] mx-auto border border-hairline-strong bg-[linear-gradient(180deg,white,var(--op-paper))] p-5 shadow-[0_1rem_2.8rem_rgba(7,16,20,0.12)]" aria-label="Rendered dogfood page preview">
            <p class="text-accent font-mono text-[0.64rem] tracking-wide uppercase">User Story 01</p>
            <h4 class="mt-3 text-ink-strong font-display text-[clamp(1.35rem,2vw,1.9rem)] font-medium leading-[1.12]">社科院學生的經濟學期末報告</h4>
            <p class="mt-3 text-subdued-strong text-sm leading-[1.42]">Notes become a structured report.</p>
            <div class="grid grid-cols-3 gap-2 min-h-[6rem] mt-5 border-y border-hairline py-3" aria-hidden="true">
              <span class="grid place-items-center bg-[color-mix(in_srgb,var(--op-accent)_18%,var(--op-paper))] before:content-[''] before:w-[52%] before:aspect-square before:border before:border-[color-mix(in_srgb,var(--op-accent)_60%,var(--op-paper))] before:bg-surface"></span>
              <span class="grid place-items-center bg-[color-mix(in_srgb,var(--op-accent)_18%,var(--op-paper))] before:content-[''] before:w-[52%] before:aspect-square before:border before:border-[color-mix(in_srgb,var(--op-accent)_60%,var(--op-paper))] before:bg-surface"></span>
              <span class="grid place-items-center bg-[color-mix(in_srgb,var(--op-accent)_18%,var(--op-paper))] before:content-[''] before:w-[52%] before:aspect-square before:border before:border-[color-mix(in_srgb,var(--op-accent)_60%,var(--op-paper))] before:bg-surface"></span>
            </div>
            <div class="grid grid-cols-2 gap-2 mt-5 font-mono text-[0.64rem]" aria-hidden="true">
              <span class="block border border-hairline p-2 text-subdued-strong">前置準備</span>
              <span class="block border border-hairline p-2 text-subdued-strong">作業摘要</span>
              <span class="block border border-hairline p-2 text-subdued-strong">OpenPress 協作</span>
              <span class="block border border-hairline p-2 text-subdued-strong">正式報告</span>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  const carousel = document.querySelector<HTMLElement>("[data-coding-carousel]");
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-coding-tab]"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-coding-panel]"));

  const activateCodingPanel = (id: string) => {
    tabs.forEach((tab) => {
      tab.setAttribute("aria-selected", String(tab.dataset.codingTab === id));
    });
    panels.forEach((panel) => {
      const active = panel.dataset.codingPanel === id;
      panel.hidden = !active;
      panel.classList.toggle("is-active", active);
    });
  };

  if (carousel) {
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => activateCodingPanel(tab.dataset.codingTab ?? "tree"));
    });
  }
</script>
