---
import SectionHeading from "./SectionHeading.astro";
---

<section class="document-coding" id="document-code" aria-labelledby="document-code-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="Document as code"
      title="A document is a source tree."
      id="document-code-title"
      split
      body="OpenPress gives AI a real workspace: structure, chapters, assets, and output each have a place."
    />

    <div class="coding-carousel" data-coding-carousel>
      <div class="coding-tabs" role="tablist" aria-label="OpenPress document coding layers">
        <button type="button" class="coding-tab" id="coding-tab-tree" data-coding-tab="tree" role="tab" aria-selected="true" aria-controls="coding-panel-tree">
          <span>01</span>
          <strong>Press Tree</strong>
          <small>Defines the document skeleton</small>
        </button>
        <button type="button" class="coding-tab" id="coding-tab-mdx" data-coding-tab="mdx" role="tab" aria-selected="false" aria-controls="coding-panel-mdx">
          <span>02</span>
          <strong>Chapter Source</strong>
          <small>Renders content into designed pages</small>
        </button>
      </div>

      <article class="coding-panel is-active" id="coding-panel-tree" data-coding-panel="tree" role="tabpanel" aria-labelledby="coding-tab-tree">
        <div class="coding-panel__copy">
          <p class="op-eyebrow">Press Tree</p>
          <h3>The agent edits the book, not a blob.</h3>
          <p>Cover, TOC, sections, and back cover stay addressable.</p>
        </div>

        <div class="coding-panel__stage">
          <div class="workspace-tree" aria-label="OpenPress workspace files">
            <p>openpress/</p>
            <span>press/index.tsx</span>
            <span>press/userstory/chapters/</span>
            <span>press/media/</span>
            <span>press/theme/</span>
            <span>dist-react/ + pdf</span>
          </div>

          <pre class="code-window"><code>{`export default function UserStoryWorkspace() {
  return (
    <Workspace>
      <Press
        slug="userstory"
        title="User Story"
        page="a4"
        sources={[
          mdxSource({
            id: "story",
            preset: "section-folders",
            root: "userstory/chapters",
          }),
        ]}
      >
        <Cover />
        <Toc source="story" maxLevel={2} />
        <Sections source="story" />
        <BackCover />
      </Press>
    </Workspace>
  );
}`}</code></pre>

          <div class="tree-preview" aria-label="Press Tree output order">
            <span>Cover</span>
            <span>TOC</span>
            <span>Sections</span>
            <span>Back cover</span>
          </div>
        </div>
      </article>

      <article class="coding-panel" id="coding-panel-mdx" data-coding-panel="mdx" role="tabpanel" aria-labelledby="coding-tab-mdx" hidden>
        <div class="coding-panel__copy">
          <p class="op-eyebrow">Chapter Source</p>
          <h3>Content becomes pages only after it is rendered.</h3>
          <p>Chapters stay readable while the output stays designed.</p>
        </div>

        <div class="coding-panel__stage coding-panel__stage--render">
          <div class="workspace-tree" aria-label="Chapter source files">
            <p>chapters/</p>
            <span>01-intro/content.mdx</span>
            <span>02-workbench/content.mdx</span>
            <span>components/figures.tsx</span>
            <span>citations/notes.md</span>
          </div>

          <pre class="code-window mdx-window"><code>{`## User Story 01

Turn assignment notes into a report with
cover, TOC, chapters, figures, and PDF.

<ZeroToOpenPressFigure />

<TableCaption>Workflow</TableCaption>`}</code></pre>

          <div class="render-arrow" aria-hidden="true">
            <span>render</span>
          </div>

          <div class="report-page" aria-label="Rendered dogfood page preview">
            <p class="report-page__kicker">User Story 01</p>
            <h4>社科院學生的經濟學期末報告</h4>
            <p>Notes become a structured report.</p>
            <div class="report-page__figure" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="report-page__table" aria-hidden="true">
              <span>前置準備</span>
              <span>作業摘要</span>
              <span>OpenPress 協作</span>
              <span>正式報告</span>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .document-coding {
    padding-block: var(--op-space-24);
    border-bottom: var(--op-border-hairline);
    background: color-mix(in srgb, var(--op-paper) 78%, var(--op-surface));
  }
  .coding-carousel {
    margin-top: var(--op-space-12);
  }
  .coding-tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--op-space-3);
  }
  .coding-tab {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--op-space-3);
    align-items: start;
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
    padding: var(--op-space-4);
    text-align: left;
    cursor: pointer;
  }
  .coding-tab span {
    color: var(--op-accent);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
  }
  .coding-tab strong {
    grid-column: 2;
    display: block;
    color: var(--op-ink-strong);
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    font-weight: var(--op-weight-medium);
    line-height: 1.05;
  }
  .coding-tab small {
    grid-column: 2;
    display: block;
    margin-top: var(--op-space-2);
    color: var(--op-subdued-strong);
    font-size: var(--op-text-sm);
  }
  .coding-tab[aria-selected="true"] {
    border-color: var(--op-accent);
    background: color-mix(in srgb, var(--op-surface) 86%, var(--op-accent-soft));
  }
  .coding-panel {
    grid-template-columns: minmax(18rem, 0.48fr) minmax(0, 1fr);
    gap: var(--op-space-6);
    align-items: stretch;
    margin-top: var(--op-space-5);
    border: var(--op-border-hairline-strong);
    background: var(--op-surface);
    padding: var(--op-space-5);
  }
  .coding-panel.is-active {
    display: grid;
  }
  .coding-panel[hidden] {
    display: none;
  }
  .coding-panel__copy {
    display: flex;
    flex-direction: column;
    gap: var(--op-space-5);
    border-right: var(--op-border-hairline);
    padding: var(--op-space-2) var(--op-space-5) var(--op-space-2) 0;
  }
  .coding-panel__copy h3 {
    margin-top: var(--op-space-4);
    font-size: clamp(2.2rem, 4vw, 4rem);
    letter-spacing: 0;
    line-height: 1.05;
  }
  .coding-panel__copy p:not(.op-eyebrow) {
    margin-top: var(--op-space-5);
    color: var(--op-subdued-strong);
    font-size: var(--op-text-lg);
  }
  .coding-panel__stage {
    min-width: 0;
    display: grid;
    grid-template-columns: 11rem minmax(0, 1fr) 10rem;
    gap: var(--op-space-5);
    align-items: stretch;
  }
  .workspace-tree {
    display: grid;
    align-content: start;
    gap: var(--op-space-2);
    border: var(--op-border-hairline-strong);
    background: var(--op-paper);
    padding: var(--op-space-4);
  }
  .workspace-tree p {
    margin: 0 0 var(--op-space-2);
    color: var(--op-accent);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
  }
  .workspace-tree span {
    display: block;
    border-top: var(--op-border-hairline);
    padding-block: var(--op-space-2);
    color: var(--op-subdued-strong);
    font-family: var(--op-font-mono);
    font-size: 0.72rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }
  .code-window {
    min-width: 0;
    max-height: 36rem;
    margin: 0;
    overflow: auto;
    border: var(--op-border-hairline-strong);
    background: var(--op-ink-strong);
    color: var(--op-ink-on-dark);
    padding: var(--op-space-5);
    font-size: clamp(0.72rem, 0.95vw, 0.9rem);
    line-height: 1.62;
    white-space: pre;
  }
  .code-window code {
    font-size: inherit;
  }
  .tree-preview {
    display: grid;
    align-content: center;
    gap: var(--op-space-3);
  }
  .tree-preview span {
    display: grid;
    place-items: center;
    min-height: 5.6rem;
    border: var(--op-border-hairline-strong);
    background: var(--op-paper);
    color: var(--op-ink-strong);
    font-family: var(--op-font-display);
    font-size: var(--op-text-xl);
    text-align: center;
  }
  .coding-panel__stage--render {
    grid-template-columns: 11rem minmax(0, 0.9fr) auto minmax(15rem, 0.72fr);
    background:
      linear-gradient(90deg, rgba(12, 14, 17, 0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(12, 14, 17, 0.035) 1px, transparent 1px);
    background-size: 3rem 3rem;
  }
  .render-arrow {
    display: grid;
    place-items: center;
    color: var(--op-accent);
    font-family: var(--op-font-mono);
    font-size: var(--op-text-xs);
    letter-spacing: var(--op-tracking-wide);
    text-align: center;
    text-transform: uppercase;
  }
  .render-arrow::before,
  .render-arrow::after {
    content: "";
    display: block;
    width: 1px;
    height: 5rem;
    background: var(--op-hairline-strong);
  }
  .render-arrow span {
    margin-block: var(--op-space-3);
  }
  .report-page {
    align-self: center;
    width: min(100%, 20rem);
    aspect-ratio: 1 / 1.414;
    margin-inline: auto;
    border: var(--op-border-hairline-strong);
    background: linear-gradient(180deg, white, var(--op-paper));
    padding: var(--op-space-5);
    box-shadow: 0 1rem 2.8rem rgba(7, 16, 20, 0.12);
  }
  .report-page__kicker {
    color: var(--op-accent);
    font-family: var(--op-font-mono);
    font-size: 0.64rem;
    letter-spacing: var(--op-tracking-wide);
    text-transform: uppercase;
  }
  .report-page h4 {
    margin-top: var(--op-space-3);
    color: var(--op-ink-strong);
    font-family: var(--op-font-display);
    font-size: clamp(1.35rem, 2vw, 1.9rem);
    font-weight: var(--op-weight-medium);
    line-height: 1.12;
  }
  .report-page p:not(.report-page__kicker) {
    margin-top: var(--op-space-3);
    color: var(--op-subdued-strong);
    font-size: var(--op-text-sm);
    line-height: 1.42;
  }
  .report-page__figure {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--op-space-2);
    min-height: 6rem;
    margin-top: var(--op-space-5);
    border-block: var(--op-border-hairline);
    padding-block: var(--op-space-3);
  }
  .report-page__figure span {
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--op-accent) 18%, var(--op-paper));
  }
  .report-page__figure span::before {
    content: "";
    width: 52%;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--op-accent) 60%, var(--op-paper));
    background: var(--op-surface);
  }
  .report-page__table {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--op-space-2);
    margin-top: var(--op-space-5);
    font-family: var(--op-font-mono);
    font-size: 0.64rem;
  }
  .report-page__table span {
    display: block;
    border: var(--op-border-hairline);
    padding: var(--op-space-2);
    color: var(--op-subdued-strong);
  }

  @media (max-width: 1120px) {
    .coding-panel,
    .coding-panel.is-active,
    .coding-panel__stage,
    .coding-panel__stage--render {
      grid-template-columns: 1fr;
    }
    .coding-panel__copy {
      border-right: 0;
      border-bottom: var(--op-border-hairline);
      padding: 0 0 var(--op-space-5);
    }
    .tree-preview {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .workspace-tree {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .workspace-tree p {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 720px) {
    .document-coding {
      padding-block: var(--op-space-16);
    }
    .coding-tabs,
    .tree-preview,
    .workspace-tree {
      grid-template-columns: 1fr;
    }
    .workspace-tree p {
      grid-column: auto;
    }
    .coding-panel {
      padding: var(--op-space-4);
    }
    .code-window {
      white-space: pre-wrap;
    }
    .render-arrow {
      grid-template-columns: 1fr auto 1fr;
      gap: var(--op-space-3);
    }
    .render-arrow::before,
    .render-arrow::after {
      width: 100%;
      height: 1px;
    }
  }
</style>

<script>
  const carousel = document.querySelector<HTMLElement>("[data-coding-carousel]");
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-coding-tab]"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-coding-panel]"));

  const activateCodingPanel = (id: string) => {
    tabs.forEach((tab) => {
      tab.setAttribute("aria-selected", String(tab.dataset.codingTab === id));
    });
    panels.forEach((panel) => {
      const active = panel.dataset.codingPanel === id;
      panel.hidden = !active;
      panel.classList.toggle("is-active", active);
    });
  };

  if (carousel) {
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => activateCodingPanel(tab.dataset.codingTab ?? "tree"));
    });
  }
</script>
