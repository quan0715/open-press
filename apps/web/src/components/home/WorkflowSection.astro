---
import SectionHeading from "./SectionHeading.astro";

interface PromptStep {
  label: string;
  text: string;
}

interface Props {
  steps: PromptStep[];
}

const { steps } = Astro.props;
---

<section class="py-24 bg-ink-strong text-ink-on-dark [&_.op-eyebrow]:text-subdued-on-dark [&_p:not(.op-eyebrow)]:text-subdued-on-dark [&_h2]:text-ink-on-dark max-[720px]:py-16" id="workflow" aria-labelledby="workflow-title">
  <div class="op-page grid grid-cols-[minmax(0,0.72fr)_minmax(22rem,1fr)] gap-16 items-start max-[1080px]:grid-cols-1">
    <SectionHeading
      eyebrow="Human judgment + AI iteration"
      title="A practical loop for formal documents."
      id="workflow-title"
      body="Bring material, shape the document, then review the output."
    />

    <ol class="grid gap-5 p-0 m-0 list-none">
      {steps.map((step, index) => (
        <li class="grid grid-cols-[3rem_1fr] gap-5 p-5 border border-[color-mix(in_srgb,var(--op-ink-on-dark)_20%,transparent)] bg-[color-mix(in_srgb,var(--op-ink-on-dark)_5%,transparent)] max-[720px]:grid-cols-1">
          <span class="grid place-items-center w-[2.25rem] h-[2.25rem] border border-accent-soft text-accent-soft font-mono">{index + 1}</span>
          <div>
            <h3 class="mb-2 text-xl text-ink-on-dark">{step.label}</h3>
            <p class="text-subdued-on-dark">{step.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
