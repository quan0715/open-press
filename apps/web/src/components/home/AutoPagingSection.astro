---
import SectionHeading from "./SectionHeading.astro";

interface Step {
  label: string;
  title: string;
  body: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="py-24 bg-paper-soft border-y border-hairline max-[720px]:py-16" id="autopaging" aria-labelledby="autopaging-title">
  <div class="op-page grid grid-cols-[minmax(0,0.78fr)_minmax(24rem,1fr)] gap-12 items-start max-[1080px]:grid-cols-1">
    <div>
      <SectionHeading
        eyebrow="Core algorithm"
        title="AutoPaging keeps long AI documents editable."
        id="autopaging-title"
        body="Split the story into chapters, render real HTML, then fit it into fixed pages."
      />
    </div>

    <div class="relative border border-hairline-strong bg-surface p-6 overflow-hidden max-[720px]:p-4" aria-label="AutoPaging step animation">
      <div class="grid gap-2 w-[min(58%,20rem)] max-[720px]:w-full">
        <span class="block border border-hairline bg-paper-soft px-3 py-2 font-mono text-xs">chapter 01</span>
        <span class="block border border-hairline bg-paper-soft px-3 py-2 font-mono text-xs">chapter 02</span>
        <span class="block border border-hairline bg-paper-soft px-3 py-2 font-mono text-xs">figure + caption</span>
        <span class="block border border-hairline bg-paper-soft px-3 py-2 font-mono text-xs">table block</span>
      </div>
      <div class="grid grid-cols-3 gap-3 mt-8">
        <div class="aspect-[1/1.414] border border-hairline-strong bg-[linear-gradient(180deg,white,var(--op-paper))] p-3 [&>span]:block [&>span]:h-[0.55rem] [&>span]:mb-2 [&>span]:bg-hairline [&>span]:origin-left [&>span]:animate-[page-fill_4.8s_ease-in-out_infinite] [&>span:nth-child(2)]:w-[82%] [&>span:nth-child(2)]:[animation-delay:0.22s] [&>span:nth-child(3)]:w-[64%] [&>span:nth-child(3)]:[animation-delay:0.44s]">
          <span></span><span></span><span></span>
        </div>
        <div class="aspect-[1/1.414] border border-hairline-strong bg-[linear-gradient(180deg,white,var(--op-paper))] p-3 [&>span]:block [&>span]:h-[0.55rem] [&>span]:mb-2 [&>span]:bg-hairline [&>span]:origin-left [&>span]:animate-[page-fill_4.8s_ease-in-out_infinite] [&>span]:[animation-delay:0.8s] [&>span:nth-child(2)]:w-[82%] [&>span:nth-child(3)]:w-[64%]">
          <span></span><span></span><span></span>
        </div>
        <div class="aspect-[1/1.414] border border-hairline-strong bg-[linear-gradient(180deg,white,var(--op-paper))] p-3 [&>span]:block [&>span]:h-[0.55rem] [&>span]:mb-2 [&>span]:bg-hairline [&>span]:origin-left [&>span]:animate-[page-fill_4.8s_ease-in-out_infinite] [&>span]:[animation-delay:1.45s] [&>span:nth-child(2)]:w-[82%] [&>span:nth-child(3)]:w-[64%]">
          <span></span><span></span><span></span>
        </div>
      </div>
      <ol class="grid gap-4 p-0 mt-8 list-none">
        {steps.map((step, index) => (
          <li style={`--step-index: ${index}`} class="border-l-[3px] border-hairline-strong pl-4 animate-[step-pulse_6.4s_ease-in-out_infinite] [animation-delay:calc(var(--step-index)*1.4s)]">
            <p class="text-accent font-mono text-xs tracking-wide uppercase">{step.label}</p>
            <h3 class="mt-2 text-lg tracking-normal">{step.title}</h3>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
