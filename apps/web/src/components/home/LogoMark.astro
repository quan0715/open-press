---
interface Props {
  label?: string;
}

const { label = "OpenPress" } = Astro.props;
---

<span class="inline-flex items-center gap-3 text-ink-strong" aria-label={label}>
  <svg class="w-[2.15rem] h-[2.15rem] flex-none fill-none stroke-current stroke-[2.2] [stroke-linecap:square] [stroke-linejoin:miter]" viewBox="0 0 64 64" role="img" aria-hidden="true">
    <rect class="fill-surface" x="11" y="8" width="34" height="48" rx="1.5"></rect>
    <path d="M45 8v13h13"></path>
    <path class="stroke-[1.8]" d="M18 24h25M18 32h33M18 40h22"></path>
    <path class="stroke-accent" d="M46 21h12v27H46"></path>
  </svg>
  <span class="font-display text-xl font-semibold tracking-normal">{label}</span>
</span>
