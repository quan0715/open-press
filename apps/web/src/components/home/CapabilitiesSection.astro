---
import SectionHeading from "./SectionHeading.astro";

interface Props {
  items: string[][];
}

const { items } = Astro.props;
---

<section class="py-24 max-[720px]:py-16" aria-labelledby="capabilities-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="What makes OpenPress different"
      title="The AI gets rules. The document gets a system."
      id="capabilities-title"
      split
      body="A workspace for repeatable AI document work."
    />

    <div class="grid grid-cols-3 gap-5 mt-12 max-[1080px]:grid-cols-2 max-[720px]:grid-cols-1">
      {items.map(([title, body]) => (
        <article class="min-h-[10rem] border border-hairline-strong bg-[color-mix(in_srgb,var(--op-surface)_84%,var(--op-paper))] p-5">
          <h3 class="text-xl tracking-normal">{title}</h3>
          <p class="mt-5 text-subdued-strong">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
