---
const methodRows = [
  {
    label: "Bring the material",
    title: "Idea, brief, or source folder",
    body: "Start from notes, chapters, screenshots, data, or an installed creative skill.",
  },
  {
    label: "Let the agent shape it",
    title: "Story, sections, and page components",
    body: "The agent turns the brief into MDX, TSX components, theme tokens, and media choices.",
  },
  {
    label: "Use OpenPress to finish",
    title: "Inspect, edit, validate, export",
    body: "OpenPress keeps the source editable, renders fixed pages, and outputs PNG, PDF, or web readers.",
  },
];

const contractRows = [
  ["Agent first", "Your coding agent operates the workspace from skills, prompts, and source files."],
  ["Shared contract", "A common base for pages, slides, MDX sections, themes, comments, and output."],
  ["Human editable", "Review source, adjust copy, keep layout decisions visible, then render again."],
  ["No shadow pipeline", "Do not patch screenshots or generated HTML; fix the source and export through OpenPress."],
];

const outputWall = {
  image: "/outputs/dogfood-output-wall.png",
  alt: "Perspective wall of Page, Slide, and Buzz dogfood Press PNG exports",
};

const heroRotatingWords = ["Press", "Page", "Slide", "Buzz"];
const openPressSkillCommand = "npx -y skills@latest add quan0715/open-press";
---

<section class="refresh-hero" aria-labelledby="home-title">
  <div class="op-page refresh-hero__inner">
    <div class="refresh-hero__copy">
      <p class="op-eyebrow">OpenPress 1.0 · agent-first document package</p>
      <h1 id="home-title" class="hero-title">
        <span class="hero-title__visible" aria-hidden="true">
          <span>Open Press</span>
          <span>Code as your</span>
          <span class="hero-title__rotator">
            {heroRotatingWords.map((word, index) => (
              <span style={`--word-index: ${index}`}>{word}</span>
            ))}
          </span>
        </span>
        <span class="visually-hidden">Open Press. Code as your Press, Page, Slide, or Buzz.</span>
      </h1>
      <p>
        Bring an idea, a brief, or a folder of sources. Your agent shapes the story;
        OpenPress turns it into pages you can inspect, edit, and export.
      </p>
      <div class="refresh-actions" aria-label="Primary actions">
        <a class="refresh-actions__primary" href="/docs/getting-started">Start with skills</a>
        <a class="refresh-actions__secondary" href="/docs">Read docs</a>
      </div>
    </div>

    <figure class="hero-artwork" aria-label="OpenPress source-to-publication artwork">
      <img src="/art/openpress-hero-art.png" alt="Abstract artwork of source fragments becoming finished publication pages" loading="eager" decoding="async" />
    </figure>
  </div>
</section>

<section class="start-section" id="start" aria-labelledby="start-title">
  <div class="op-page start-section__grid">
    <div>
      <p class="op-eyebrow">Start</p>
      <h2 id="start-title">Start with one prompt.</h2>
      <p>
        New to OpenPress? Install the skill, restart your agent, and ask it to create
        the workspace. Learn the CLI after you see the first page.
      </p>
    </div>

    <div class="starter-card" aria-label="Beginner start path">
      <p class="starter-card__label">Beginner path</p>
      <ol>
        <li>
          <strong>Install the OpenPress skill.</strong>
          <div class="copy-line">
            <code>{openPressSkillCommand}</code>
            <button type="button" data-copy-command={openPressSkillCommand}>Copy</button>
          </div>
        </li>
        <li>
          <strong>Ask your agent.</strong>
          <span>Create an OpenPress document from my notes. Set up the workspace, run preview, and tell me what to edit.</span>
        </li>
      </ol>
      <a href="/docs/getting-started">Open quick start</a>
    </div>
  </div>
</section>

<section class="method-section" id="flow" aria-labelledby="flow-title">
  <div class="op-page method-section__inner">
    <div class="section-heading">
      <p class="op-eyebrow">How it works</p>
      <h2 id="flow-title">Brief to publication.</h2>
      <p>
        OpenPress is not another creative skill. It is the shared workspace those skills
        can rely on when a document needs real pages, source control, and repeatable output.
      </p>
    </div>

    <div class="method-list" aria-label="OpenPress workflow">
      {methodRows.map((row) => (
        <article>
          <p>{row.label}</p>
          <h3>{row.title}</h3>
          <span>{row.body}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="tree-section" aria-labelledby="tree-title">
  <div class="op-page">
    <div class="section-heading">
      <p class="op-eyebrow">The difference</p>
      <h2 id="tree-title">DOM tree vs Press tree.</h2>
      <p>
        AI can generate HTML. OpenPress gives the agent a document-shaped app tree
        where pages, components, and MDX sources stay inspectable.
      </p>
    </div>

    <div class="tree-compare" aria-label="HTML DOM tree and OpenPress app tree comparison">
