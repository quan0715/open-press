<script is:inline>
  document.addEventListener("click", async (event) => {
    const button = event.target.closest("[data-copy-command]");
    if (!button) return;

    const command = button.getAttribute("data-copy-command");
    if (!command) return;

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(command);
      } else {
        throw new Error("Clipboard API unavailable");
      }
      const original = button.textContent;
      button.textContent = "Copied";
      window.setTimeout(() => {
        button.textContent = original || "Copy";
      }, 1400);
    } catch {
      const textarea = document.createElement("textarea");
      textarea.value = command;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();
      const copied = document.execCommand("copy");
      document.body.removeChild(textarea);
      button.textContent = copied ? "Copied" : "Select";
      if (copied) {
        window.setTimeout(() => {
          button.textContent = "Copy";
        }, 1400);
      }
    }
  });

  const codeWindows = Array.from(document.querySelectorAll("[data-code-reveal]"));
  if (codeWindows.length > 0) {
    const revealCodeWindow = (codeWindow) => {
      window.requestAnimationFrame(() => {
        codeWindow.classList.add("is-visible");
      });
    };

    if ("IntersectionObserver" in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            revealCodeWindow(entry.target);
            revealObserver.unobserve(entry.target);
          }
        },
        { threshold: 0.24 },
      );

      for (const codeWindow of codeWindows) {
        revealObserver.observe(codeWindow);
      }
    } else {
      const revealVisibleCodeWindows = () => {
        for (const codeWindow of codeWindows) {
          if (codeWindow.classList.contains("is-visible")) continue;
          const box = codeWindow.getBoundingClientRect();
          if (box.top < window.innerHeight * 0.82 && box.bottom > 0) {
            revealCodeWindow(codeWindow);
          }
        }
      };

      window.addEventListener("scroll", revealVisibleCodeWindows, { passive: true });
      window.addEventListener("resize", revealVisibleCodeWindows);
      revealVisibleCodeWindows();
    }

    window.setTimeout(() => {
      for (const codeWindow of codeWindows) {
        if (!codeWindow.classList.contains("is-visible")) {
          revealCodeWindow(codeWindow);
        }
      }
    }, 1800);
  }
</script>

