<span class="code-line" style="--line-index: 12">      <span class="code-tag">&lt;section</span> <span class="code-attr">class</span>=<span class="code-value">"page page-02"</span><span class="code-tag">&gt;</span></span>
<span class="code-line" style="--line-index: 13">        <span class="code-tag">&lt;article</span> <span class="code-attr">class</span>=<span class="code-value">"chapter"</span><span class="code-tag">&gt;</span></span>
<span class="code-line" style="--line-index: 14">          <span class="code-tag">&lt;h2&gt;</span>1. Morning surface temperature<span class="code-tag">&lt;/h2&gt;</span></span>
<span class="code-line" style="--line-index: 15">          <span class="code-tag">&lt;p&gt;</span>Paragraph copied into the page body.<span class="code-tag">&lt;/p&gt;</span></span>
<span class="code-line" style="--line-index: 16">          <span class="code-tag">&lt;p&gt;</span>Another paragraph with <span class="code-tag">&lt;a</span> <span class="code-attr">href</span>=<span class="code-value">"#note-1"</span><span class="code-tag">&gt;</span>a note link<span class="code-tag">&lt;/a&gt;</span>.<span class="code-tag">&lt;/p&gt;</span></span>
<span class="code-line" style="--line-index: 17">          <span class="code-tag">&lt;ul&gt;</span><span class="code-tag">&lt;li&gt;</span>shade<span class="code-tag">&lt;/li&gt;</span><span class="code-tag">&lt;li&gt;</span>asphalt<span class="code-tag">&lt;/li&gt;</span><span class="code-tag">&lt;/ul&gt;</span></span>
<span class="code-line" style="--line-index: 18">        <span class="code-tag">&lt;/article&gt;</span></span>
<span class="code-line" style="--line-index: 19">      <span class="code-tag">&lt;/section&gt;</span></span>
<span class="code-line code-line--page" style="--line-index: 20">      <span class="code-comment">&lt;!-- page split: generated table --&gt;</span></span>
<span class="code-line" style="--line-index: 21">      <span class="code-tag">&lt;section</span> <span class="code-attr">class</span>=<span class="code-value">"page page-03"</span><span class="code-tag">&gt;</span></span>
<span class="code-line" style="--line-index: 22">        <span class="code-tag">&lt;table&gt;</span></span>
<span class="code-line" style="--line-index: 23">          <span class="code-tag">&lt;thead&gt;&lt;tr&gt;&lt;th&gt;</span>Time<span class="code-tag">&lt;/th&gt;&lt;th&gt;</span>Shade<span class="code-tag">&lt;/th&gt;&lt;th&gt;</span>Delta<span class="code-tag">&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;</span></span>
<span class="code-line" style="--line-index: 24">          <span class="code-tag">&lt;tbody&gt;</span></span>
<span class="code-line" style="--line-index: 25">            <span class="code-tag">&lt;tr&gt;&lt;td&gt;</span>09:00<span class="code-tag">&lt;/td&gt;&lt;td&gt;</span>partial<span class="code-tag">&lt;/td&gt;&lt;td&gt;</span>-2.1C<span class="code-tag">&lt;/td&gt;&lt;/tr&gt;</span></span>
<span class="code-line" style="--line-index: 26">            <span class="code-tag">&lt;tr&gt;&lt;td&gt;</span>12:00<span class="code-tag">&lt;/td&gt;&lt;td&gt;</span>none<span class="code-tag">&lt;/td&gt;&lt;td&gt;</span>+6.4C<span class="code-tag">&lt;/td&gt;&lt;/tr&gt;</span></span>
<span class="code-line" style="--line-index: 27">          <span class="code-tag">&lt;/tbody&gt;</span></span>
<span class="code-line" style="--line-index: 28">        <span class="code-tag">&lt;/table&gt;</span></span>
