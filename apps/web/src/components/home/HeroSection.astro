---
interface Props {
  version: string;
}

const { version } = Astro.props;
---

<section class="min-h-[min(48rem,calc(100svh-4.5rem))] grid items-center py-16 pb-12 border-b border-hairline-strong max-[720px]:min-h-0 max-[720px]:py-12" aria-labelledby="hero-title">
  <div class="op-page min-w-0 grid grid-cols-[minmax(0,0.9fr)_minmax(18rem,0.42fr)] gap-[clamp(2rem,6vw,6rem)] items-center max-[1080px]:grid-cols-1">
    <div class="max-w-[62rem]">
      <p class="op-eyebrow">Fixed-layout application layer · v{version}</p>
      <h1 id="hero-title" class="max-w-[10.5ch] mt-5 font-body text-[clamp(4.1rem,7.4vw,7.25rem)] font-bold leading-[0.9] tracking-normal break-normal max-[720px]:max-w-none max-[720px]:text-[clamp(3.2rem,14vw,4rem)]">
        OpenPress
        <em class="block mt-2 text-accent font-display text-[0.68em] italic font-normal leading-[0.92]">Substrate for creative skills.</em>
      </h1>
      <p class="max-w-[48rem] mt-8 text-subdued-strong text-[clamp(1.1rem,2vw,1.45rem)] leading-[1.55]">
        Give AI agents the workbench, source contract, renderer, validation, and export path
        they should not reimplement.
      </p>

      <div class="flex flex-wrap gap-3 mt-8 max-[720px]:items-stretch max-[720px]:flex-col" aria-label="Primary actions">
        <a class="inline-flex items-center justify-center min-h-[3rem] px-5 border border-hairline-strong rounded-md font-semibold no-underline transition-all duration-fast ease hover:no-underline active:scale-98 bg-ink-strong text-ink-on-dark hover:bg-[#333333] hover:text-paper hover:border-[#333333] max-[720px]:w-full" href="#start">Start a document</a>
        <a class="inline-flex items-center justify-center min-h-[3rem] px-5 border border-hairline-strong rounded-md font-semibold no-underline transition-all duration-fast ease hover:no-underline active:scale-98 bg-surface text-ink hover:bg-paper-soft max-[720px]:w-full" href="#showcase">View real documents</a>
      </div>
    </div>

    <aside class="min-w-0 w-[min(100%,28rem)] justify-self-end max-[1080px]:w-[min(100%,32rem)] max-[1080px]:justify-self-start" aria-label="OpenPress User Story Book preview">
      <a class="block overflow-hidden border border-hairline-strong bg-surface no-underline rounded-md transition-shadow duration-base ease hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)]" href="/showcase#user-story-book" aria-label="Open the OpenPress User Story Book showcase">
        <div class="flex items-center justify-between gap-4 min-h-[3.5rem] border-b border-hairline px-4 text-subdued font-mono text-xs tracking-wide uppercase">
          <span>Rendered output</span>
          <strong class="text-accent font-medium">Live</strong>
        </div>
        <div class="grid place-items-center h-[clamp(24rem,48svh,34rem)] overflow-hidden p-4 bg-[linear-gradient(90deg,rgba(12,14,17,0.035)_1px,transparent_1px),linear-gradient(180deg,rgba(12,14,17,0.035)_1px,transparent_1px),var(--op-paper)] bg-[size:2.5rem_2.5rem] max-[1080px]:h-[clamp(24rem,58svh,34rem)] max-[720px]:h-[min(28rem,72svh)]">
          <img class="w-auto max-w-full h-full border border-hairline bg-white object-contain"
            src="/showcase/openpress-user-story-book.png"
            alt="OpenPress User Story Book cover"
            width="1190"
            height="1684"
            loading="eager"
          />
        </div>
      </a>
    </aside>
  </div>
</section>
