---
interface UseCase {
  audience: string;
  documents: string;
  source: string;
  outcome: string;
  prompt: string;
}

interface Props {
  items: UseCase[];
}

const { items } = Astro.props;
const countLabel = items.length.toString().padStart(2, "0");
---

<section class="py-24 border-b border-hairline max-[720px]:py-16" id="use-cases" aria-labelledby="use-cases-title">
  <div class="op-page grid grid-cols-[minmax(18rem,0.45fr)_minmax(0,1fr)] gap-[clamp(2rem,6vw,6rem)] items-stretch max-[980px]:grid-cols-1" data-use-case-carousel>
    <div class="flex flex-col justify-between gap-8 min-w-0">
      <div>
        <p class="op-eyebrow">Who is it for?</p>
        <h2 class="max-w-[11ch] mt-4 tracking-normal max-[980px]:max-w-[42rem]" id="use-cases-title">Different people, one polished document.</h2>
        <p class="max-w-[29rem] mt-5 text-subdued-strong text-lg max-[980px]:max-w-[42rem]">
          Pick a role, then give your agent a focused document brief.
        </p>
      </div>

      <div class="flex items-center gap-3" aria-label="Use-case carousel controls">
        <button class="grid place-items-center w-12 h-12 border border-hairline-strong bg-surface text-ink-strong cursor-pointer font-mono text-xl hover:border-accent hover:text-accent focus-visible:border-accent focus-visible:text-accent" type="button" data-use-case-prev aria-label="Previous use case">
          <span aria-hidden="true">&lt;</span>
        </button>
        <output class="text-subdued font-mono text-xs tracking-wide" data-use-case-count aria-live="polite">01 / {countLabel}</output>
        <button class="grid place-items-center w-12 h-12 border border-hairline-strong bg-surface text-ink-strong cursor-pointer font-mono text-xl hover:border-accent hover:text-accent focus-visible:border-accent focus-visible:text-accent" type="button" data-use-case-next aria-label="Next use case">
          <span aria-hidden="true">&gt;</span>
        </button>
      </div>

      <div class="flex flex-wrap gap-2" aria-label="Use-case pages">
        {items.map((item, index) => (
          <button
            type="button"
            class:list={["w-[2.4rem] h-[0.35rem] border-0 bg-hairline cursor-pointer [&.is-active]:bg-accent", index === 0 && "is-active"]}
            data-use-case-dot={index}
            aria-label={`Show ${item.audience}`}
            aria-current={index === 0 ? "true" : "false"}
          ></button>
        ))}
      </div>
    </div>

    <div class="min-w-0 border border-hairline-strong bg-[linear-gradient(90deg,rgba(12,14,17,0.035)_1px,transparent_1px),linear-gradient(180deg,rgba(12,14,17,0.035)_1px,transparent_1px),var(--op-surface)] bg-[size:3rem_3rem]">
      {items.map((item, index) => {
        const number = (index + 1).toString().padStart(2, "0");

        return (
          <article
            class:list={["min-h-[28rem] p-[clamp(1.5rem,4vw,3.5rem)] max-[720px]:min-h-[30rem] max-[720px]:p-5 hidden [&.is-active]:grid [&.is-active]:grid-rows-[auto_auto_1fr] [&.is-active]:gap-7", index === 0 && "is-active"]}
            data-use-case-card={index}
            hidden={index !== 0}
          >
            <div class="flex items-center justify-between gap-6 border-b border-hairline pb-4 max-[720px]:flex-col max-[720px]:items-start">
              <span class="text-accent font-display text-[clamp(4rem,8vw,7rem)] italic leading-[0.85]">{number}</span>
              <p class="text-subdued font-mono text-xs tracking-wide text-right uppercase max-[720px]:text-left">{item.audience}</p>
            </div>

            <h3 class="max-w-[15ch] text-[clamp(2.35rem,5vw,5rem)] tracking-normal leading-[0.98] max-[720px]:max-w-none max-[720px]:text-[clamp(2.25rem,12vw,3.5rem)]">{item.documents}</h3>

            <p class="border-t border-hairline-strong pt-4 text-subdued-strong text-lg leading-[1.45]">{item.outcome}</p>

            <figure class="m-0 border-t border-hairline pt-5">
              <figcaption class="text-subdued font-mono text-xs tracking-wide uppercase">Example prompt</figcaption>
              <blockquote class="m-0 mt-3 text-ink-strong font-display text-xl leading-[1.35] max-[720px]:text-lg">{item.prompt}</blockquote>
            </figure>
          </article>
        );
      })}
    </div>
  </div>
</section>

<script>
  const useCaseCarousels = Array.from(document.querySelectorAll<HTMLElement>("[data-use-case-carousel]"));

  useCaseCarousels.forEach((carousel) => {
    const cards = Array.from(carousel.querySelectorAll<HTMLElement>("[data-use-case-card]"));
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-use-case-dot]"));
    const previous = carousel.querySelector<HTMLButtonElement>("[data-use-case-prev]");
    const next = carousel.querySelector<HTMLButtonElement>("[data-use-case-next]");
    const count = carousel.querySelector<HTMLOutputElement>("[data-use-case-count]");

    if (cards.length === 0) return;

    let activeIndex = 0;

    const format = (value: number) => String(value).padStart(2, "0");

    const activate = (index: number) => {
      activeIndex = (index + cards.length) % cards.length;

      cards.forEach((card, cardIndex) => {
        const active = cardIndex === activeIndex;
        card.hidden = !active;
        card.classList.toggle("is-active", active);
        card.setAttribute("aria-hidden", String(!active));
      });

      dots.forEach((dot, dotIndex) => {
        const active = dotIndex === activeIndex;
        dot.classList.toggle("is-active", active);
        dot.setAttribute("aria-current", String(active));
      });

      if (count) {
        count.textContent = `${format(activeIndex + 1)} / ${format(cards.length)}`;
      }
    };

    previous?.addEventListener("click", () => activate(activeIndex - 1));
    next?.addEventListener("click", () => activate(activeIndex + 1));
    dots.forEach((dot, dotIndex) => {
      dot.addEventListener("click", () => activate(dotIndex));
    });

    carousel.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") activate(activeIndex - 1);
      if (event.key === "ArrowRight") activate(activeIndex + 1);
    });

    activate(0);
  });
</script>
