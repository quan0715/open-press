---
import SectionHeading from "./SectionHeading.astro";

interface Props {
  agents: string[];
}

const { agents } = Astro.props;
---

<section class="py-24 border-t border-hairline max-[720px]:py-16" id="agents" aria-labelledby="agents-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="Agent collaboration"
      title="Use the AI agent you already trust."
      id="agents-title"
      split
      body="Works with agents that can edit files and run checks."
    />

    <div class="grid grid-cols-4 gap-4 mt-12 max-[1080px]:grid-cols-2 max-[720px]:grid-cols-1" aria-label="AI agents that can collaborate with OpenPress">
      {agents.map((agent) => (
        <span class="grid place-items-center min-h-[7rem] border border-hairline-strong bg-[linear-gradient(135deg,color-mix(in_srgb,var(--op-surface)_90%,var(--op-paper)),var(--op-surface))] text-ink-strong font-display text-xl text-center [&:nth-child(3n)]:border-accent-soft">{agent}</span>
      ))}
    </div>
  </div>
</section>
