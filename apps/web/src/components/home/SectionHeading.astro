---
interface Props {
  eyebrow: string;
  title: string;
  body?: string;
  id?: string;
  split?: boolean;
}

const { eyebrow, title, body, id, split = false } = Astro.props;
---

<div class:list={["max-w-[50rem] [&_h2]:mt-4 [&_h2]:tracking-normal [&_p:not(.op-eyebrow)]:mt-5 [&_p:not(.op-eyebrow)]:text-subdued-strong [&_p:not(.op-eyebrow)]:text-lg", split && "grid max-w-none grid-cols-[minmax(0,1fr)_minmax(18rem,0.72fr)] gap-10 items-end max-[1080px]:grid-cols-1 [&_p:not(.op-eyebrow)]:mt-0 max-[1080px]:[&_p:not(.op-eyebrow)]:mt-5 [&_[slot=action]]:justify-self-end max-[1080px]:[&_[slot=action]]:justify-self-start"]}>
  <div>
    <p class="op-eyebrow">{eyebrow}</p>
    <h2 id={id}>{title}</h2>
  </div>
  {body && <p>{body}</p>}
  <slot name="action" />
</div>
