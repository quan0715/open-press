---
import LogoMark from "./LogoMark.astro";
import { getRelativeLocaleUrl } from "astro:i18n";

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links: NavLink[];
}

const { links } = Astro.props;
const currentLocale = Astro.currentLocale || "zh-tw";
const getPath = (href: string) => {
  if (href.startsWith("http")) return href;
  let p = href.replace(/^\//, "");
  let relUrl = getRelativeLocaleUrl(currentLocale, p);
  return relUrl.endsWith("/") && relUrl !== "/" ? relUrl.slice(0, -1) : relUrl;
};

const getLangUrl = (targetLang: string) => {
  const currentPath = Astro.url.pathname;
  const segments = currentPath.split("/").filter(Boolean);
  if (["zh-tw", "en", "ja"].includes(segments[0])) {
    segments[0] = targetLang;
  } else {
    segments.unshift(targetLang);
  }
  const newPath = "/" + segments.join("/");
  return newPath.endsWith("/") && newPath !== "/" ? newPath.slice(0, -1) : newPath;
};
---

<header class="sticky z-20 top-0 border-b border-hairline bg-[color-mix(in_srgb,var(--op-paper)_86%,var(--op-surface))] backdrop-blur-[18px] max-[720px]:static">
  <div class="op-page flex items-center justify-between gap-8 min-h-[4.75rem] max-[720px]:items-start max-[720px]:flex-col max-[720px]:py-5">
    <a class="text-ink-strong no-underline" href="/" aria-label="OpenPress home">
      <LogoMark />
    </a>
    <nav class="flex flex-wrap justify-end gap-3 items-center font-body text-sm font-medium max-[720px]:justify-start" aria-label="Primary navigation">
      {
        links.map((link) => (
          <a
            class:list={[
              "text-ink no-underline",
              link.label === "Star" && "inline-flex relative items-center gap-[0.42rem] min-h-[2.45rem] px-[0.95rem] py-[0.48rem] rounded-full border border-ink-strong bg-ink-strong !text-ink-on-dark hover:bg-accent hover:border-accent hover:!text-ink-on-dark",
              link.label === "npm" && "inline-flex relative items-center min-h-[2.45rem] rounded-full gap-0 overflow-hidden border border-[color-mix(in_srgb,var(--op-hairline-strong)_82%,transparent)] bg-[color-mix(in_srgb,var(--op-surface)_78%,transparent)] !text-ink p-0 shadow-[0_0.55rem_1.25rem_rgba(53,43,30,0.08)] hover:border-accent-soft hover:bg-surface",
              link.label !== "Star" && link.label !== "npm" && "px-[0.85rem] py-[0.45rem] rounded-md transition-colors duration-fast ease font-semibold hover:bg-paper-soft"
            ]}
            href={getPath(link.href)}
            data-github-star-link={link.label === "Star" ? true : undefined}
            aria-label={
              link.label === "Star"
                ? "Star OpenPress on GitHub, 5 stars"
                : link.label === "npm"
                  ? "Open @open-press/cli on npm"
                  : undefined
            }
          >
            {link.label === "Star" ? (
              <>
                <svg aria-hidden="true" class="w-4 h-4 fill-current drop-shadow-[0_0_8px_rgba(255,246,231,0.18)]" viewBox="0 0 20 20">
                  <path d="m10 1.7 2.45 5.05 5.55.8-4.02 3.9.95 5.5L10 14.35l-4.93 2.6.95-5.5L2 7.55l5.55-.8L10 1.7Z" />
                </svg>
                <span>{link.label}</span>
                <strong class="inline-flex items-center justify-center min-w-[1.32rem] border border-[color-mix(in_srgb,var(--op-ink-on-dark)_34%,transparent)] rounded-full bg-[color-mix(in_srgb,var(--op-ink-on-dark)_12%,transparent)] px-[0.42rem] pb-[0.08rem] pt-[0.06rem] text-ink-on-dark font-mono text-[0.7rem] font-semibold leading-none" data-github-stars aria-label="5 GitHub stars">5</strong>
              </>
            ) : link.label === "npm" ? (
              <>
                <span class="grid self-stretch place-items-center min-w-[3rem] bg-ink-strong text-ink-on-dark font-mono text-[0.76rem] tracking-normal">npm</span>
                <span class="inline-flex items-baseline gap-[0.38rem] px-[0.7rem] py-[0.48rem] text-subdued-strong font-mono text-[0.68rem] leading-none uppercase">
                  <span>downloads</span>
                  <strong class="text-accent text-[0.78rem] font-semibold normal-case" data-npm-downloads>1.4k/mo</strong>
                </span>
              </>
            ) : (
              <span>{link.label}</span>
            )}
          </a>
        ))
      }
      <div class="flex gap-1 ml-4 pl-4 border-l border-hairline">
        <a href={getLangUrl("zh-tw")} class:list={["px-[0.4rem] py-[0.2rem] text-subdued text-[0.75rem] rounded-[4px] transition-colors duration-200 hover:bg-paper-soft hover:text-ink no-underline", currentLocale === "zh-tw" && "text-ink-strong font-bold"]}>繁</a>
        <a href={getLangUrl("en")} class:list={["px-[0.4rem] py-[0.2rem] text-subdued text-[0.75rem] rounded-[4px] transition-colors duration-200 hover:bg-paper-soft hover:text-ink no-underline", currentLocale === "en" && "text-ink-strong font-bold"]}>EN</a>
        <a href={getLangUrl("ja")} class:list={["px-[0.4rem] py-[0.2rem] text-subdued text-[0.75rem] rounded-[4px] transition-colors duration-200 hover:bg-paper-soft hover:text-ink no-underline", currentLocale === "ja" && "text-ink-strong font-bold"]}>日</a>
      </div>
      <button class="flex items-center justify-center bg-transparent border-none text-subdued cursor-pointer p-[0.45rem] rounded-md ml-2 transition-colors duration-200 hover:bg-paper-soft hover:text-ink" id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="w-[1.1rem] h-[1.1rem] hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <svg class="w-[1.1rem] h-[1.1rem] block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const starCounter = document.querySelector("[data-github-stars]");
  const starLink = document.querySelector("[data-github-star-link]");
  const downloadsCounter = document.querySelector("[data-npm-downloads]");
  const formatCompactCount = (count: number) => {
    if (count >= 1000000) return `${(count / 1000000).toFixed(1)}m`;
    if (count >= 1000) return `${(count / 1000).toFixed(1)}k`;
    return String(count);
  };

  const formatDownloads = (downloads: number) => {
    return `${formatCompactCount(downloads)}/mo`;
  };

  if (starCounter instanceof HTMLElement) {
    fetch("https://api.github.com/repos/quan0715/open-press")
      .then((response) => (response.ok ? response.json() : null))
      .then((data: { stargazers_count?: number } | null) => {
        if (typeof data?.stargazers_count === "number") {
          const starText = formatCompactCount(data.stargazers_count);
          starCounter.textContent = starText;
          starCounter.setAttribute("aria-label", `${data.stargazers_count} GitHub stars`);
          starLink?.setAttribute("aria-label", `Star OpenPress on GitHub, ${data.stargazers_count} stars`);
        }
      })
      .catch(() => {
        // Keep the static fallback when GitHub's API is unavailable.
      });
  }

  if (downloadsCounter instanceof HTMLElement) {
    fetch("https://api.npmjs.org/downloads/point/last-month/@open-press/cli")
      .then((response) => (response.ok ? response.json() : null))
      .then((data: { downloads?: number } | null) => {
        if (typeof data?.downloads === "number") {
          downloadsCounter.textContent = formatDownloads(data.downloads);
        }
      })
      .catch(() => {
        // Keep the static fallback when npm's API is unavailable.
      });
  }

  const themeToggle = document.getElementById("theme-toggle");
  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark";
      if (isDark) {
        document.documentElement.removeAttribute("data-theme");
        localStorage.setItem("op-theme", "light");
      } else {
        document.documentElement.setAttribute("data-theme", "dark");
        localStorage.setItem("op-theme", "dark");
      }
    });
  }
</script>
