---
import SectionHeading from "./SectionHeading.astro";

interface ShowcaseItem {
  slug: string;
  title: string;
  href: string;
  description: string;
  cover: string;
}

interface Props {
  items: ShowcaseItem[];
}

const { items } = Astro.props;
---

<section class="py-24 bg-paper-soft border-y border-hairline max-[720px]:py-16" id="showcase" aria-labelledby="showcase-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="Real output"
      title="Judge the workspace by the documents it ships."
      id="showcase-title"
      split
    >
      <a class="text-ink-strong font-semibold" href="/showcase" slot="action">Open the full showcase</a>
    </SectionHeading>

    <div class="grid grid-cols-3 gap-8 mt-12 max-[1080px]:grid-cols-2 max-[720px]:grid-cols-1">
      {items.map((item) => (
        <article class="grid gap-5">
          <a class="block aspect-[1/1.414] border border-hairline-strong bg-surface overflow-hidden hover:border-accent" href={`/showcase#${item.slug}`} aria-label={`View ${item.title} on the OpenPress showcase`}>
            <img class="w-full h-full object-contain" src={item.cover} alt={`${item.title} cover`} loading="eager" width="1190" height="1684" />
          </a>
          <div>
            <h3 class="text-xl tracking-normal">{item.title}</h3>
            <p class="mt-2 text-subdued-strong">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
