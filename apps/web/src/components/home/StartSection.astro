---
import CodeBlock from "../CodeBlock.astro";
---

<section class="py-24 max-[720px]:py-16" id="start" aria-labelledby="start-title">
  <div class="op-page grid grid-cols-[minmax(0,0.85fr)_minmax(24rem,1fr)] gap-10 items-end max-[1080px]:grid-cols-1 max-[720px]:gap-8 [&_.cb]:min-w-0 [&_.cb__pre]:text-sm">
    <div>
      <p class="op-eyebrow">Start with a workspace, not a blank export</p>
      <h2 class="mt-4 tracking-normal" id="start-title">Create a maintainable document project.</h2>
      <p class="mt-5 text-subdued-strong text-lg">
        One command creates a workspace your agent can edit, render, and check.
      </p>
    </div>
    <CodeBlock command="npm create @open-press my-deck -- --type slides" />
  </div>
</section>
