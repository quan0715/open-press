---
import CodeBlock from "../CodeBlock.astro";
---

<section class="start" id="start" aria-labelledby="start-title">
  <div class="op-page start__inner">
    <div>
      <p class="op-eyebrow">Start with a workspace, not a blank export</p>
      <h2 id="start-title">Create a maintainable document project.</h2>
      <p>
        One command creates a workspace your agent can edit, render, and check.
      </p>
    </div>
    <CodeBlock command="npx @open-press/cli init my-doc --pack editorial-monograph" />
  </div>
</section>

<style>
  .start {
    padding-block: var(--op-space-24);
  }
  .start__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(24rem, 1fr);
    gap: var(--op-space-10);
    align-items: end;
  }
  .start h2 {
    margin-top: var(--op-space-4);
    letter-spacing: 0;
  }
  .start p:not(.op-eyebrow) {
    margin-top: var(--op-space-5);
    color: var(--op-subdued-strong);
    font-size: var(--op-text-lg);
  }
  .start :global(.cb) {
    min-width: 0;
  }
  .start :global(.cb__pre) {
    font-size: var(--op-text-sm);
  }

  @media (max-width: 1080px) {
    .start__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .start {
      padding-block: var(--op-space-16);
    }
    .start__inner {
      gap: var(--op-space-8);
    }
  }
</style>
