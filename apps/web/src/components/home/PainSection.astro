---
import SectionHeading from "./SectionHeading.astro";

interface Props {
  items: string[][];
}

const { items } = Astro.props;
---

<section class="py-24 bg-paper-soft border-b border-hairline max-[720px]:py-16" aria-labelledby="pain-title">
  <div class="op-page">
    <SectionHeading
      eyebrow="The real pain"
      title="The problem is not drafting. The problem is delivery."
      id="pain-title"
      body="Non-engineering users already know how to ask AI for text. What breaks is the next step: turning that text, evidence, and feedback into a formal document that can keep changing without falling apart."
    />

    <div class="grid grid-cols-4 gap-5 mt-12 max-[1080px]:grid-cols-2 max-[720px]:grid-cols-1">
      {items.map(([name, problem, detail]) => (
        <article class="flex flex-col justify-between min-h-[15rem] border-t-[3px] border-ink-strong bg-surface p-5 max-[720px]:min-h-[12rem]">
          <p class="text-accent font-mono text-xs tracking-wide uppercase">{name}</p>
          <h3 class="my-6 text-xl tracking-normal">{problem}</h3>
          <span class="text-subdued-strong text-sm">{detail}</span>
        </article>
      ))}
    </div>

    <p class="max-w-[58rem] mt-10 text-ink-strong font-display text-2xl leading-[1.28] max-[720px]:text-xl">
      OpenPress treats PDF and reader as build artifacts. The living work is
      the workspace: chapters, sources, assets, components, theme, and review
      steps that your AI agent can safely edit.
    </p>
  </div>
</section>
