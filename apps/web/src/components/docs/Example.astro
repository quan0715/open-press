---
import { Code } from "astro:components";

type ShikiLang = Parameters<typeof Code>[0]["lang"];

interface Props {
  title?: string;
  language?: ShikiLang;
  code: string;
}

const { title, language = "tsx", code } = Astro.props;
---

<figure class="min-w-0 max-w-full mb-5">
  {title && <figcaption class="mb-2 text-subdued font-mono text-xs font-semibold tracking-[0.06em] uppercase">{title}</figcaption>}
  <div class="relative max-w-full rounded-[6px] overflow-x-auto overflow-y-hidden bg-[#0d1117] before:content-[attr(data-language)] before:absolute before:top-[0.55rem] before:right-[0.85rem] before:z-10 before:text-[rgba(230,237,243,0.45)] before:font-mono before:text-[0.65rem] before:font-semibold before:tracking-[0.08em] before:uppercase before:pointer-events-none [&_pre.astro-code]:m-0 [&_pre.astro-code]:max-w-full [&_pre.astro-code]:py-4 [&_pre.astro-code]:px-5 [&_pre.astro-code]:overflow-x-auto [&_pre.astro-code]:!bg-transparent [&_pre.astro-code]:font-mono [&_pre.astro-code]:text-sm [&_pre.astro-code]:leading-mono [&_pre.astro-code_code]:bg-transparent [&_pre.astro-code_code]:font-[inherit] [&_pre.astro-code_code]:text-[inherit]" data-language={language}>
    <Code code={code} lang={language} theme="github-dark" />
  </div>
</figure>
