---
import Badge from "./Badge.astro";

type Status = "impl" | "planned" | "experimental" | "deprecated";

interface Props {
  name: string;
  id?: string;
  kind:
    | "component"
    | "hook"
    | "function"
    | "type"
    | "context"
    | "symbol"
    | "module"
    | "command"
    | "skill"
    | "endpoint"
    | "config"
    | "css-var";
  status?: Status;
  since?: string;
  importFrom?: string;
  signature?: string;
  summary?: string;
}

const { name, id, kind, status, since, importFrom, signature, summary } = Astro.props;
const anchorId = id ?? slugify(name);
const effectiveStatus: Status = status ?? "impl";

const statusLabel: Record<Status, string> = {
  impl: "Impl",
  planned: since ? `Plan · ${since}` : "Plan",
  experimental: "Experimental",
  deprecated: "Deprecated",
};

const statusClasses: Record<Status, string> = {
  impl: "text-[#166534] bg-[color-mix(in_srgb,#dcfce7_72%,transparent)]",
  planned: "text-[#b45309] bg-[color-mix(in_srgb,#fef3c7_70%,transparent)]",
  experimental: "text-[#7c3aed] bg-[color-mix(in_srgb,#ede9fe_70%,transparent)]",
  deprecated: "text-[#b91c1c] bg-[color-mix(in_srgb,#fee2e2_70%,transparent)]",
};

function slugify(value: string): string {
  return value
    .replace(/[<>]/g, "")
    .replace(/[^a-zA-Z0-9_\-./]/g, "-")
    .replace(/-+/g, "-")
    .toLowerCase()
    .replace(/^-|-$/g, "");
}
---

<section id={anchorId} class:list={["py-6 border-t border-hairline first-of-type:border-t-0 first-of-type:pt-0 group/entry", `is-${effectiveStatus}`]}>
  <header class="mb-4">
    <div class="flex flex-wrap items-center gap-3 group/title">
      <Badge kind={kind} />
      <span class={`inline-flex items-center px-[0.55em] py-[0.18em] border border-current rounded-full font-mono text-[0.72rem] font-semibold tracking-[0.04em] uppercase leading-none ${statusClasses[effectiveStatus]}`}>{statusLabel[effectiveStatus]}</span>
      <h3 class="m-0 font-body text-xl font-semibold leading-[1.25]">
        <a class="mr-[0.3rem] text-hairline-strong font-mono font-normal no-underline opacity-0 transition-[opacity,color] duration-120 ease-ease group-hover/title:opacity-100 group-hover/title:text-accent focus:opacity-100 focus:text-accent" href={`#${anchorId}`} aria-label={`Link to ${name}`}>#</a>
        <code class="bg-transparent p-0 text-ink-strong font-mono text-inherit group-[.is-deprecated]/entry:line-through group-[.is-deprecated]/entry:text-subdued">{name}</code>
      </h3>
    </div>
    {summary && <p class="mt-3 mb-0 text-subdued-strong text-base leading-body">{summary}</p>}
  </header>

  {
    importFrom && (
      <pre class="my-3 py-[0.55rem] px-[0.9rem] rounded-[6px] bg-ink-strong text-ink-on-dark font-mono text-sm leading-mono overflow-x-auto group-[.is-planned]/entry:opacity-70"><code>{importFrom}</code></pre>
    )
  }

  {
    signature && (
      <pre class="my-3 py-[0.55rem] px-[0.9rem] rounded-[6px] bg-[color-mix(in_srgb,var(--op-ink-strong)_92%,var(--op-accent)_12%)] text-ink-on-dark font-mono text-sm leading-mono overflow-x-auto group-[.is-planned]/entry:opacity-70"><code>{signature}</code></pre>
    )
  }

  <div class="grid gap-4 min-w-0 [&_p]:m-0 [&_p]:text-ink [&_p]:text-base [&_p]:leading-body [&_.props-table]:m-0 [&_pre]:m-0">
    <slot />
  </div>
</section>
