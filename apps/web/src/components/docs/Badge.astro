---
interface Props {
  kind:
    | "component"
    | "hook"
    | "function"
    | "type"
    | "context"
    | "symbol"
    | "module"
    | "command"
    | "skill"
    | "endpoint"
    | "config"
    | "css-var";
}
const { kind } = Astro.props;

const labels: Record<string, string> = {
  component: "Component",
  hook: "Hook",
  function: "Function",
  type: "Type",
  context: "Context",
  symbol: "Symbol",
  module: "Module",
  command: "Command",
  skill: "Skill",
  endpoint: "Endpoint",
  config: "Config",
  "css-var": "CSS variable",
};

const kindClasses: Record<string, string> = {
  component: "border-[color-mix(in_srgb,var(--op-accent)_50%,var(--op-hairline))] text-accent",
  hook: "border-[color-mix(in_srgb,#2563eb_40%,var(--op-hairline))] text-[#1d4ed8]",
  function: "border-[color-mix(in_srgb,#047857_40%,var(--op-hairline))] text-[#047857]",
  context: "border-[color-mix(in_srgb,#7c3aed_40%,var(--op-hairline))] text-[#7c3aed]",
  symbol: "border-[color-mix(in_srgb,#7c3aed_40%,var(--op-hairline))] text-[#7c3aed]",
  command: "border-[color-mix(in_srgb,#b45309_40%,var(--op-hairline))] text-[#b45309]",
  skill: "border-[color-mix(in_srgb,#b45309_40%,var(--op-hairline))] text-[#b45309]",
  endpoint: "border-[color-mix(in_srgb,#b45309_40%,var(--op-hairline))] text-[#b45309]",
};

const specificClasses = kindClasses[kind] || "border-hairline-strong text-subdued-strong";
---

<span class={`inline-flex items-center px-[0.55em] py-[0.18em] border rounded-full bg-surface font-mono text-[0.72rem] font-semibold tracking-[0.04em] uppercase leading-none ${specificClasses}`}>{labels[kind]}</span>
