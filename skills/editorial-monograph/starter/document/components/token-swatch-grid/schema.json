{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Token Swatch Grid",
  "type": "object",
  "required": ["swatches"],
  "properties": {
    "ariaLabel": { "type": "string" },
    "swatches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "hex", "summary", "swatchVar"],
        "properties": {
          "name": { "type": "string" },
          "hex": { "type": "string", "pattern": "^#[0-9a-fA-F]{3,8}$" },
          "summary": { "type": "string" },
          "swatchVar": { "type": "string", "pattern": "^var\\(--[a-z0-9-]+(?:\\s*,\\s*[^()]*)?\\)$|^#[0-9a-fA-F]{3,8}$" },
          "swatchBorderVar": { "type": "string", "pattern": "^var\\(--[a-z0-9-]+(?:\\s*,\\s*[^()]*)?\\)$|^#[0-9a-fA-F]{3,8}$" },
          "dark": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
