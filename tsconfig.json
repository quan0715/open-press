{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["node", "vite/client"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@open-press/core": ["./packages/core/src/openpress/core/index.tsx"],
      "@open-press/core/mdx": ["./packages/core/src/openpress/mdx/index.ts"],
      "@open-press/core/manuscript": ["./packages/core/src/openpress/manuscript/index.tsx"],
      "@open-press/core/numbering": ["./packages/core/src/openpress/numbering/index.ts"],
      "@/components": ["./document/components/index.ts", "./document/components/index.tsx"],
      "@/components/*": ["./document/components/*"],
      "@/*": ["./packages/core/src/*"]
    }
  },
  "include": [
    "packages/core/src",
    "document/**/*.ts",
    "document/**/*.tsx",
    "vite.config.ts"
  ]
}
