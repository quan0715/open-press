{
  "name": "open-press-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "open-press monorepo root — pnpm workspaces for @open-press/cli, @open-press/core, and apps.",
  "license": "MIT",
  "author": "quan0715",
  "homepage": "https://github.com/quan0715/open-press#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quan0715/open-press.git"
  },
  "bugs": {
    "url": "https://github.com/quan0715/open-press/issues"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --filter @open-press/core dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:react": "pnpm --filter @open-press/core test:react",
    "test:node": "pnpm --filter @open-press/core test:node",
    "openpress:validate": "pnpm --filter @open-press/core openpress:validate",
    "openpress:render": "pnpm --filter @open-press/core openpress:render",
    "openpress:export": "pnpm --filter @open-press/core openpress:export",
    "openpress:pdf": "pnpm --filter @open-press/core openpress:pdf",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.5.6"
  }
}
