{
  "name": "open-press-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "open-press monorepo root — pnpm workspaces for @open-press/cli, @open-press/core, and apps.",
  "license": "MIT",
  "author": "quan0715",
  "homepage": "https://github.com/quan0715/open-press#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quan0715/open-press.git"
  },
  "bugs": {
    "url": "https://github.com/quan0715/open-press/issues"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm run dev:workspace",
    "dev:workspace": "node packages/core/engine/cli.mjs dev . --renderer react",
    "dev:web": "pnpm --filter web dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:react": "pnpm --filter @open-press/core test:react",
    "test:node": "pnpm --filter @open-press/core test:node",
    "openpress:typecheck": "node packages/core/engine/cli.mjs typecheck .",
    "openpress:validate": "node packages/core/engine/cli.mjs validate .",
    "openpress:render": "node packages/core/engine/cli.mjs render . --renderer react",
    "openpress:export": "node packages/core/engine/cli.mjs export .",
    "openpress:pdf": "node packages/core/engine/cli.mjs pdf .",
    "openpress:preview": "node packages/core/engine/cli.mjs preview . --renderer react",
    "openpress:deploy": "node packages/core/engine/cli.mjs deploy .",
    "openpress:deploy:dry-run": "node packages/core/engine/cli.mjs deploy . --confirm --dry-run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.5.6"
  }
}
