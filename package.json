{
  "name": "qdoc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "QDoc — AI-first fixed-layout document workspace. Markdown source, React workbench, A4 PDF output.",
  "license": "MIT",
  "bin": {
    "qdoc": "engine/cli.mjs"
  },
  "scripts": {
    "dev": "node engine/cli.mjs dev . --renderer react",
    "build": "node engine/cli.mjs render . --renderer react",
    "preview": "node engine/cli.mjs preview . --renderer react",
    "typecheck": "node engine/cli.mjs typecheck .",
    "test": "node --test tests/*.test.mjs",
    "test:ci": "npm run typecheck && npm run qdoc:validate && npm run qdoc:render && npm test",
    "qdoc:validate": "node engine/cli.mjs validate .",
    "qdoc:export": "node engine/cli.mjs export .",
    "qdoc:pdf": "node engine/cli.mjs pdf .",
    "qdoc:render": "node engine/cli.mjs render . --renderer react",
    "qdoc:preview": "node engine/cli.mjs preview . --renderer react"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "markdown-it": "^14.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
