    "prepack": "pnpm sync:template && pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tar": "^7.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
